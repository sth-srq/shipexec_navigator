    private async Task ConfirmSummarizeAsync()
    {
        _showSummarizeConfirm = false;
        _isSummarizing    = true;
        _summarizePdfBytes = null;
        _summarizeError   = null;
        _summarizePercent = 0;
        _summarizeStatus  = "Preparing…";
        StateHasChanged();

        try
        {
            var company = ShipExecService.GetCurrentCompany();
            if (company is null)
            {
                _summarizeError = "No company connected.";
                return;
            }

            // ── Phase 1: load company XML ──
            await UpdateProgressAsync(10, "Loading company data…");
            var companyXml = await ShipExecService.GetCompanyXmlAsync(company.Id, company.Name ?? "");
            await UpdateProgressAsync(30, "Company data loaded. Sending to AI…");

            // ── Phase 2: AI analysis (long) — run a timer to simulate progress ──
            var cts = new CancellationTokenSource();
            var progressTask = SimulateProgressAsync(35, 85, "Generating summary…", cts.Token);

            var prompt = $"Generate a comprehensive summary report for this ShipExec company configuration. " +
                $"Include sections for: Company Overview, Profiles, Shippers, Users, Business Rules (SBR and CBR), " +
                $"Adapter Registrations, Clients, and any notable configuration items. " +
                $"Format as a well-structured plain-text report with headers and bullet points. " +
                $"Use markdown-style headers (## Section) and bold (**text**) for emphasis.\n\n" +
                $"Company XML:\n{companyXml}";

            var response = await CbrAnalysisService.AnalyzeCbrAsync(prompt);

            await cts.CancelAsync();
            try { await progressTask; } catch (OperationCanceledException) { }

            // ── Phase 3: generate PDF ──
            await UpdateProgressAsync(90, "Generating PDF report…");
            var companySlug = (company.Name ?? "company").Replace(" ", "_");
            _summarizeFilename = $"{companySlug}_Summary_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";
            _summarizePdfBytes = await Task.Run(() => PdfService.GenerateSummaryPdf(company.Name ?? "Company", response));

            await UpdateProgressAsync(100, "Complete!");
        }
        catch (Exception ex)
        {
            _summarizeError = ex.Message;
        }
        finally
        {
            _isSummarizing = false;
            StateHasChanged();
        }
    }

    private async Task SimulateProgressAsync(int from, int to, string status, CancellationToken ct)
    {
        var current = from;
        while (current < to && !ct.IsCancellationRequested)
        {
            await Task.Delay(2500, ct);
            current = Math.Min(current + 5, to);
            await InvokeAsync(() =>
            {
                _summarizePercent = current;
                _summarizeStatus  = status;
                StateHasChanged();
            });
        }
    }

    private async Task UpdateProgressAsync(int pct, string status)
    {
        _summarizePercent = pct;
        _summarizeStatus  = status;
        StateHasChanged();
        await Task.Delay(50); // yield so UI renders
    }

    private async Task DownloadSummarizeResult()
    {
        if (_summarizePdfBytes is null || _summarizeFilename is null) return;
        var base64 = Convert.ToBase64String(_summarizePdfBytes);
        await JS.InvokeVoidAsync("downloadBase64File", _summarizeFilename, base64, "application/pdf");
    }

    private void CloseSummarizeProgress()
    {
        _summarizePdfBytes = null;
        _summarizeError    = null;
        _summarizeFilename = null;
        _summarizePercent  = 0;
        _summarizeStatus   = string.Empty;
    }

    private void HandleShippersAppliedAsync(List<ApplyResultItem> results)
    {
        if (!results.Any(r => r.Success)) return;
        _showImportShippersDialog = false;
        PendingImportService.HighlightCategory = "Shippers";
        NavigationManager.NavigateTo("/studio", forceLoad: false);
    }

    private void HandleShipperVariancesForStudio(List<ShipExecNavigator.BusinessLogic.EntityComparison.Variance> variances)
    {
        if (variances.Count == 0) return;
        _showImportShippersDialog = false;
        PendingImportService.SetPendingShipperVariances(variances);
        NavigationManager.NavigateTo("/studio", forceLoad: false);
    }
