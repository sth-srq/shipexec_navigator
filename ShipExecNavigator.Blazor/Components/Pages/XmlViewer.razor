    private readonly HashSet<Guid> _userVarianceIds = [];

    private void HandleUserVariancesChanged(List<UserVariance> userVariances)
    {
        // Remove previous user-variance entries from the main panel
        _varianceEntries.RemoveAll(v => _userVarianceIds.Contains(v.Id));
        _userVarianceIds.Clear();

        // Convert each UserVariance into a Variance entry for the main panel
        foreach (var uv in userVariances)
        {
            var changeType = uv.Kind switch
            {
                UserVarianceKind.Create => "Added",
                UserVarianceKind.Delete => "Removed",
                UserVarianceKind.Edit   => "Modified",
                _                       => "Modified",
            };
            _varianceEntries.Insert(0, new Variance
            {
                Id              = uv.Id,
                PathDescription = "Users",
                Description     = uv.Description,
                ChangeType      = changeType,
            });
            _userVarianceIds.Add(uv.Id);
        }

        InvokeAsync(StateHasChanged);
    }

