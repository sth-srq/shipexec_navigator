@page "/studio"
@page "/xml-viewer"
@rendermode InteractiveServer
@implements IDisposable

@using ShipExecNavigator.BusinessLogic.EntityComparison
@using ShipExecNavigator.Shared.Models
@using System.Xml.Linq
@inject IXmlViewerService XmlViewerService
@inject IXmlSchemaService XmlSchemaService
@inject IShipExecService ShipExecService
@inject IXmlRefLookupService XmlRefLookupService
@inject IJSRuntime JSRuntime
@inject AlertService AlertService
@inject IAiChatService AiChatService
@inject ICbrAnalysisService CbrAnalysisService

<PageTitle>Management Studio Pro</PageTitle>

<div class="viewer-page">

    <div class="page-tab-bar">
        <a class="page-tab" href="/">&#x1F916; ShipExec Copilot</a>
        <span class="page-tab page-tab--active">&#x1F5FA; Navigator</span>
        <a class="page-tab" href="/tools">&#x2B07;&#xFE0F; Downloads</a>
        <a class="page-tab" href="/debug">&#x1F41B; Debug</a>
    </div>

    <div class="load-panel @(rootNode != null ? "load-panel--compact" : "")">
        @if (rootNode == null)
        {
            <div class="hero">
                <h1 class="hero-title">ShipExec Navigator</h1>
                <p class="hero-subtitle">Connect to ShipExec to explore and manage a company configuration.</p>
            </div>
        }

        <div class="input-row @(rootNode == null ? "input-row--centered" : "")">
            <button class="btn-load" @onclick="OpenConnectDialog" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                <span>&#x1F517; Connect to ShipExec</span>
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-banner" role="alert">
                <span class="error-icon">&#9888;</span>
                <span>@errorMessage</span>
            </div>
        }
    </div>

    @if (rootNode != null)
    {
        <div class="viewer-content-row">

        <div class="viewer-main-area">
        <div class="viewer-tabs">
            <button class='viewer-tab @(_activeMainTab == "company" ? "viewer-tab--active" : "")'
                    @onclick='() => _activeMainTab = "company"'>&#x1F3E2; Company</button>
            <button class='viewer-tab @(_activeMainTab == "business-rules" ? "viewer-tab--active" : "")'
                    @onclick='SwitchToBusinessRulesTab'>&#x1F4DC; Business Rules</button>
            <button class='viewer-tab @(_activeMainTab == "users" ? "viewer-tab--active" : "")'
                    @onclick='() => _activeMainTab = "users"'>&#x1F464; Users</button>
            <button class='viewer-tab @(_activeMainTab == "logs" ? "viewer-tab--active" : "")'
                    @onclick='() => _activeMainTab = "logs"'>&#x1F4CB; Logs</button>
        </div>

        <div class="viewer-body-row">
            <VariancePanel Entries="_varianceEntries"
                           @bind-IsVisible="_variancePanelVisible"
                           OnEntryClicked="NavigateToNode"
                           OnEntryUndo="UndoVariance"
                           OnLoadHistory="LoadHistoryAsync"
                           HistoryError="@_historyError"
                           CanLoadHistory="@_canLoadHistory" />

            <div class="viewer-main">
        <div class="viewer-workspace" style="@(_activeMainTab != "company" ? "display:none" : "")">
        <div class="tree-panel">
            <div class="tree-toolbar">
                <div class="toolbar-info">
                    <span class="root-tag">@rootNode.NodeName</span>
                    @if (!string.IsNullOrEmpty(loadedFileName))
                    {
                        <span class="company-name">@loadedFileName</span>
                    }
                    <span class="stat-pill">@nodeCount nodes</span>
                    <span class="stat-pill">@rootNode.Children.Count sections</span>
                    @if (_isDirty)
                    {
                        <span class="dirty-pill">&#x25CF; unsaved</span>
                    }
                    <span class="source-badge source-badge--live">
                        &#x1F7E2; Live
                    </span>
                </div>
                <div class="toolbar-actions">
                    <button class="btn-export" @onclick="ViewChanges"
                            disabled="@(_isComputingDiff ? "disabled" : null)"
                            title="Compute variances and requests against the live server">
                        @if (_isComputingDiff)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        }
                        &#x1F4CA; View Changes
                    </button>
                    <button class="btn-action" @onclick="() => _showImportShippersDialog = true">&#x1F69A; Import Shippers</button>
                    <button class="btn-action" @onclick="ExportShippersAsync" disabled="@_isExportingShippers">&#x2B07; Export Shippers</button>
                    <button class="btn-action" @onclick="() => _showCompareProfilesDialog = true">&#x1F4CA; Compare Profiles</button>
                    <button class="btn-action" @onclick="ExpandAll">Expand All</button>
                    <button class="btn-action" @onclick="CollapseAll">Collapse All</button>
                    <span class="depth-label">Depth</span>
                    <div class="depth-group">
                        <button class="btn-depth @(activeDepth == 1 ? "active" : "")" @onclick="() => ExpandToDepth(1)">1</button>
                        <button class="btn-depth @(activeDepth == 2 ? "active" : "")" @onclick="() => ExpandToDepth(2)">2</button>
                        <button class="btn-depth @(activeDepth == 3 ? "active" : "")" @onclick="() => ExpandToDepth(3)">3</button>
                        <button class="btn-depth @(activeDepth == 4 ? "active" : "")" @onclick="() => ExpandToDepth(4)">4</button>
                    </div>
                    <button class="btn-close-tree" @onclick="CloseTree" title="Close tree">&#x2715;</button>
                    <button class="btn-action btn-action--chat @(_chatVisible ? "btn-action--chat-active" : "")" @onclick="() => _chatVisible = !_chatVisible" title="@(_chatVisible ? "Hide AI chat" : "Show AI chat")">&#x1F916; Chat</button>
                </div>
            </div>

            <div class="tree-body">
                <CascadingValue Name="TreeVersion" Value="_version" IsFixed="false">
                    <CascadingValue Name="NodeContextMenu" Value="_contextMenuHandler" IsFixed="true">
                        <CascadingValue Name="OnNodeModified" Value="_modifiedHandler" IsFixed="true">
                            <CascadingValue Name="OnNodeEdited" Value="_nodeEditedHandler" IsFixed="true">
                                <CascadingValue Name="HighlightedNodeId" Value="_highlightedNodeId" IsFixed="false">
                                    <CascadingValue Name="OnLazyLoadAsync" Value="_lazyLoadHandler" IsFixed="true">
                                        <XmlNodeTree Node="rootNode" />
                                    </CascadingValue>
                                </CascadingValue>
                            </CascadingValue>
                        </CascadingValue>
                    </CascadingValue>
                </CascadingValue>
            </div>
        </div>
        </div>
        @if (_activeMainTab == "business-rules")
        {
            <div class="br-tab-content">
                <div class="br-section @(_sbrExpanded ? "" : "br-section--collapsed")">
                    <button class="br-section-header br-section-header--toggle" @onclick="() => _sbrExpanded = !_sbrExpanded">
                        <span class="br-chevron @(_sbrExpanded ? "br-chevron--open" : "")">&#x25B6;</span>
                        &#x1F5A5;&#xFE0F; Server Business Rules
                        @if (_sbrLoading)
                        {
                            <span class="spinner-border spinner-border-sm ms-2" role="status"></span>
                        }
                        else if (_sbrs.Count > 0)
                        {
                            <span class="br-count-badge">@_sbrs.Count</span>
                        }
                    </button>
                    @if (_sbrExpanded)
                    {
                        <div class="br-section-body">
                            @if (_sbrLoading)
                            {
                                <div class="br-loading">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                    Loading server business rules&hellip;
                                </div>
                            }
                            else if (_sbrError is not null)
                            {
                                <div class="br-error">&#9888; @_sbrError</div>
                            }
                            else if (!_sbrLoaded)
                            {
                                <div class="br-empty">No server business rules loaded.</div>
                            }
                            else if (_sbrs.Count == 0)
                            {
                                <div class="br-empty">No server business rules found for this company.</div>
                            }
                            else
                            {
                                <div class="sbr-list">
                                    @foreach (var sbr in _sbrs)
                                    {
                                        <div class="sbr-card">
                                            <div class="sbr-card-header">
                                                <span class="sbr-name">@sbr.Name</span>
                                                @if (!string.IsNullOrEmpty(sbr.FileBase64))
                                                {
                                                    <button class="sbr-download-btn" @onclick="() => DownloadSbrAsync(sbr)" title="Download @(sbr.Name).dll">
                                                        &#x2B07;&#xFE0F; Download .dll
                                                    </button>
                                                }
                                            </div>
                                            <div class="sbr-details">
                                                @if (!string.IsNullOrWhiteSpace(sbr.Description))
                                                {
                                                    <div class="sbr-detail-row">
                                                        <span class="sbr-detail-label">Description</span>
                                                        <span class="sbr-detail-value">@sbr.Description</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(sbr.Version))
                                                {
                                                    <div class="sbr-detail-row">
                                                        <span class="sbr-detail-label">Version</span>
                                                        <span class="sbr-detail-value">@sbr.Version</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(sbr.Author))
                                                {
                                                    <div class="sbr-detail-row">
                                                        <span class="sbr-detail-label">Author</span>
                                                        <span class="sbr-detail-value">@sbr.Author@(!string.IsNullOrWhiteSpace(sbr.AuthorEmail) ? $" &lt;{sbr.AuthorEmail}&gt;" : "")</span>
                                                    </div>
                                                }
                                                <div class="sbr-detail-row">
                                                    <span class="sbr-detail-label">Profiles</span>
                                                    <span class="sbr-detail-value">
                                                        @if (sbr.UsedByProfiles.Count > 0)
                                                        {
                                                            @foreach (var profile in sbr.UsedByProfiles)
                                                            {
                                                                <span class="sbr-profile-tag">@profile</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span class="sbr-none">Not assigned to any profile</span>
                                                        }
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="br-section @(_cbrExpanded ? (_selectedCbr is not null ? "br-section--viewer" : "") : "br-section--collapsed")">
                    <button class="br-section-header br-section-header--toggle" @onclick="() => _cbrExpanded = !_cbrExpanded">
                        <span class="br-chevron @(_cbrExpanded ? "br-chevron--open" : "")">&#x25B6;</span>
                        &#x1F4BB; Client Business Rules
                        @if (_cbrLoading)
                        {
                            <span class="spinner-border spinner-border-sm ms-2" role="status"></span>
                        }
                        else if (_cbrs.Count > 0)
                        {
                            <span class="br-count-badge">@_cbrs.Count</span>
                        }
                    </button>
                    @if (_cbrExpanded)
                    {
                        <div class="br-section-body">
                            @if (_cbrLoading)
                            {
                                <div class="br-loading">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                    Loading client business rules&hellip;
                                </div>
                            }
                            else if (_cbrError is not null)
                            {
                                <div class="br-error">&#9888; @_cbrError</div>
                            }
                            else if (!_cbrLoaded)
                            {
                                <div class="br-empty">No client business rules loaded.</div>
                            }
                            else if (_cbrs.Count == 0)
                            {
                                <div class="br-empty">No client business rules found for this company.</div>
                            }
                            else
                            {
                                <div class="cbr-body">
                                    <div class="cbr-sidebar">
                                        @foreach (var cbr in _cbrs)
                                        {
                                            <button class="cbr-item @(_selectedCbr?.Id == cbr.Id ? "cbr-item--active" : "")"
                                                    @onclick="() => SelectCbr(cbr)">
                                                <span class="cbr-item-name">@cbr.Name</span>
                                                @if (!string.IsNullOrWhiteSpace(cbr.Version))
                                                {
                                                    <span class="cbr-item-version">@cbr.Version</span>
                                                }
                                                @if (cbr.UsedByProfiles.Count > 0)
                                                {
                                                    <span class="cbr-item-profiles">@string.Join(", ", cbr.UsedByProfiles)</span>
                                                }
                                            </button>
                                        }
                                    </div>
                                    <div class="cbr-viewer">
                                        @if (_selectedCbr is null)
                                        {
                                            <div class="cbr-viewer-empty">&#x2190; Select a rule to view its script</div>
                                        }
                                        else
                                        {
                                            <div class="cbr-viewer-header">
                                                <span class="cbr-viewer-name">@_selectedCbr.Name</span>
                                                @if (!string.IsNullOrWhiteSpace(_selectedCbr.Version))
                                                {
                                                    <span class="cbr-viewer-version">@_selectedCbr.Version</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(_selectedCbr.Description))
                                                {
                                                    <span class="cbr-viewer-desc">@_selectedCbr.Description</span>
                                                }
                                            </div>
                                            <div class="cbr-code-wrap">
                                                <textarea class="cbr-editor" spellcheck="false"
                                                          @bind="_cbrEditedScript"
                                                          @bind:event="oninput"></textarea>
                                            </div>
                                            <div class="cbr-footer">
                                                <button class="cbr-btn-save"
                                                        @onclick="SaveCbrEdit"
                                                        disabled="@(_cbrEditedScript == _cbrOriginalScript)">
                                                    &#x2714; Save
                                                </button>
                                                <button class="cbr-btn-cancel"
                                                        @onclick="CancelCbrEdit"
                                                        disabled="@(_cbrEditedScript == _cbrOriginalScript)">
                                                    &#x2715; Cancel
                                                </button>
                                                <button class="cbr-btn-analyze"
                                                        @onclick="RunCbrAnalysisAsync"
                                                        disabled="@(_cbrAnalyzing || string.IsNullOrWhiteSpace(_cbrEditedScript))">
                                                    @if (_cbrAnalyzing)
                                                    {
                                                        <span class="cbr-analyze-spinner"></span>
                                                        <span>Analyzing…</span>
                                                    }
                                                    else
                                                    {
                                                        <span>&#x1F9E0; Analyze</span>
                                                    }
                                                </button>
                                            </div>
                                            @if (_cbrAnalysisVisible)
                                            {
                                                <div class="cbr-analysis-panel">
                                                    <div class="cbr-analysis-header">
                                                        <span class="cbr-analysis-title">&#x1F9E0; AI Analysis — @_selectedCbr.Name</span>
                                                        <div class="cbr-analysis-actions">
                                                            @if (_cbrAnalysisResult is not null)
                                                            {
                                                                <button class="cbr-btn-accept" @onclick="AcceptCbrAnalysis">
                                                                    &#x2714; Accept &amp; Replace
                                                                </button>
                                                            }
                                                            <button class="cbr-btn-dismiss" @onclick="DismissCbrAnalysis">
                                                                &#x2715; Dismiss
                                                            </button>
                                                        </div>
                                                    </div>
                                                    @if (_cbrAnalyzing)
                                                    {
                                                        <div class="cbr-analysis-loading">
                                                            <span class="cbr-analyze-spinner cbr-analyze-spinner--lg"></span>
                                                            <span>Sending script and CBRHelper to AI… this may take a moment.</span>
                                                        </div>
                                                    }
                                                    else if (_cbrAnalysisError is not null)
                                                    {
                                                        <div class="cbr-analysis-error">&#9888; @_cbrAnalysisError</div>
                                                    }
                                                    else if (_cbrAnalysisResult is not null)
                                                    {
                                                        <textarea class="cbr-analysis-result" spellcheck="false"
                                                                  readonly
                                                                  value="@_cbrAnalysisResult"></textarea>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
        @if (_activeMainTab == "users")
        {
            <div class="um-tab-content">
                <UserManagementDialog OnUsersJson="HandleUsersJson"
                                      OnUsersMetaJson="HandleUsersMetaJson"
                                      FoundUserIds="_foundUserIds"
                                      OnClearFound="HandleClearFoundUsers"
                                      AiPendingDeletes="_pendingUserDeletes"
                                      OnDeletesHandled="HandleUserDeletesHandled"
                                      AiPendingEdits="_pendingUserEdits"
                                      OnEditsHandled="HandleUserEditsHandled"
                                      AiCreatePrefill="_addUserPrefill"
                                      OnCreateHandled="HandleUserCreateHandled" />
            </div>
        }
        @if (_activeMainTab == "logs")
        {
            <div class="logs-panel">
                <div class="logs-toolbar">
                    <div class="log-mode-toggle">
                        <button class='log-mode-btn @(_logMode == "application" ? "log-mode-btn--active" : "")'
                                @onclick='() => SetLogMode("application")'>&#x1F4CB; Application</button>
                        <button class='log-mode-btn @(_logMode == "security" ? "log-mode-btn--active" : "")'
                                @onclick='() => SetLogMode("security")'>&#x1F512; Security</button>
                        <button class='log-mode-btn @(_logMode == "both" ? "log-mode-btn--active" : "")'
                                @onclick='() => SetLogMode("both")'>&#x1F50D; Both</button>
                    </div>
                    <div class="logs-search-bar">
                        <label class="logs-label">From</label>
                        <input type="date" class="logs-date-input" @bind="_logStart" @bind:format="yyyy-MM-dd" />
                        <label class="logs-label">To</label>
                        <input type="date" class="logs-date-input" @bind="_logEnd" @bind:format="yyyy-MM-dd" />
                        <button class="btn-load logs-search-btn" @onclick="SearchLogsAsync" disabled="@_logsSearching">
                            @if (_logsSearching)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            }
                            Search
                        </button>
                    </div>
                    @if (_logsSearched)
                    {
                        @if (_logMode == "application")
                        {
                            <span class="stat-pill">@_logs.Count of @_logTotal records</span>
                        }
                        else if (_logMode == "security")
                        {
                            <span class="stat-pill">@_secLogs.Count of @_secLogTotal records</span>
                        }
                        else
                        {
                            <span class="stat-pill">@_combLogs.Count records</span>
                            <span class="log-source log-source--app">App</span>
                            <span class="log-source log-source--security">Security</span>
                        }
                        <button class="btn-export" @onclick="ExportLogsCsvAsync" disabled="@_logsExporting">
                            @if (_logsExporting)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            }
                            &#x2B07; Export CSV
                        </button>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_logsError))
                {
                    <div class="error-banner" role="alert">
                        <span class="error-icon">&#9888;</span>
                        <span>@_logsError</span>
                    </div>
                }

                @if (_logMode == "application" && _logs.Count > 0)
                {
                    <div class="logs-table-wrap">
                        <table class="logs-table">
                            <thead>
                                <tr>
                                    <th>Date / Time</th>
                                    <th>Level</th>
                                    <th>Logger</th>
                                    <th>Message</th>
                                    <th>Server</th>
                                    <th>Transaction ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in _logs)
                                {
                                    <tr>
                                        <td class="log-date">@log.LogDate?.ToString("MM/dd HH:mm:ss.fff")</td>
                                        <td><span class="log-level log-level--@(log.LogLevel.ToLower())">@log.LogLevel</span></td>
                                        <td class="log-logger">@log.Logger</td>
                                        <td class="log-message">@log.Message</td>
                                        <td class="log-server">@log.ServerAddress</td>
                                        <td class="log-txid">@log.TransactionId</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (_logMode == "security" && _secLogs.Count > 0)
                {
                    <div class="logs-table-wrap">
                        <table class="logs-table">
                            <thead>
                                <tr>
                                    <th>Date / Time</th>
                                    <th>Level</th>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Entity</th>
                                    <th>Entity Name</th>
                                    <th>Current Value</th>
                                    <th>Previous Value</th>
                                    <th>Message</th>
                                    <th>Server</th>
                                    <th>Transaction ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in _secLogs)
                                {
                                    <tr>
                                        <td class="log-date">@log.LogDate?.ToString("MM/dd HH:mm:ss.fff")</td>
                                        <td><span class="log-level log-level--@(log.LogLevel.ToLower())">@log.LogLevel</span></td>
                                        <td class="log-logger">@log.UserName</td>
                                        <td class="log-logger">@log.ActionType</td>
                                        <td class="log-logger">@log.Entity</td>
                                        <td class="log-logger">@log.EntityName</td>
                                        <td class="log-message">@log.CurrentValue</td>
                                        <td class="log-message">@log.PreviousValue</td>
                                        <td class="log-message">@log.Message</td>
                                        <td class="log-server">@log.ServerAddress</td>
                                        <td class="log-txid">@log.TransactionId</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (_logMode == "both" && _combLogs.Count > 0)
                {
                    <div class="logs-table-wrap">
                        <table class="logs-table">
                            <thead>
                                <tr>
                                    <th>Date / Time</th>
                                    <th>Source</th>
                                    <th>Level</th>
                                    <th>Logger / User</th>
                                    <th>Action</th>
                                    <th>Entity</th>
                                    <th>Entity Name</th>
                                    <th>Message</th>
                                    <th>Server</th>
                                    <th>Transaction ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in _combLogs)
                                {
                                    <tr class="comb-row comb-row--@(log.Source.ToLower())">
                                        <td class="log-date">@log.LogDate?.ToString("MM/dd HH:mm:ss.fff")</td>
                                        <td><span class="log-source log-source--@(log.Source.ToLower())">@log.Source</span></td>
                                        <td><span class="log-level log-level--@(log.LogLevel.ToLower())">@log.LogLevel</span></td>
                                        <td class="log-logger">@(log.Source == "Security" ? log.UserName : log.Logger)</td>
                                        <td class="log-logger">@log.ActionType</td>
                                        <td class="log-logger">@log.Entity</td>
                                        <td class="log-logger">@log.EntityName</td>
                                        <td class="log-message">@log.Message</td>
                                        <td class="log-server">@log.ServerAddress</td>
                                        <td class="log-txid">@log.TransactionId</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (!_logsSearching && _logsSearched)
                {
                    <div class="logs-empty">No log entries found for the selected date range.</div>
                }
            </div>
        }
            </div>
        </div>
    </div>@* /viewer-main-area *@

    </div>@* /viewer-content-row *@
    }

    @* ── Studio chat panel ── *@
    <StudioChatPanel OnToggle="() => _chatVisible = false" IsVisible="_chatVisible" XmlRoot="rootNode" OnDeleteShippers="HandleAiShipperDeletions" OnEditShippers="HandleAiShipperEdits" OnAddShipper="HandleAiShipperAdd" UsersJson="@_usersJson" UsersMetaJson="@_usersMetaJson" OnFindUsers="HandleAiFindUsers" OnDeleteUsers="HandleAiUserDeletions" OnEditUsers="HandleAiUserEdits" OnAddUser="HandleAiUserAdd" />

</div>

@* ── Import Shippers dialog ── *@
<ImportShippersDialog IsVisible="_showImportShippersDialog"
                      CanApply="true"
                      OnClose="() => _showImportShippersDialog = false"
                      OnShippersApplied="HandleShippersAppliedAsync"
                      OnAddToVarianceList="HandleShipperVariancesForPanel" />

@* ── Add Shipper dialog ── *@
<AddShipperDialog IsVisible="_showAddShipperDialog"
                  Prefill="_addShipperPrefill"
                  OnClose="CloseAddShipperDialog"
                  OnShipperAdded="HandleNewShipperAdded" />

@* ── Compare Profiles dialog ── *@
<CompareProfilesDialog IsVisible="_showCompareProfilesDialog"
                       OnClose="() => _showCompareProfilesDialog = false"
                       OnGoToProfile="HandleGoToProfileAsync" />

@* ── Context menu (rendered outside the tree-body to avoid clipping) ── *@
<XmlContextMenu Node="_contextMenuNode"
                X="_menuX" Y="_menuY"
                IsVisible="_showContextMenu"
                CanPaste="_canPaste"
                OnClose="CloseContextMenu"
                OnAdd="OpenAddChildDialog"
                OnRemove="ExecuteRemove"
                OnCopy="ExecuteCopy"
                OnPaste="ExecutePaste" />

@* ── Add-child dialog ── *@
<XmlAddChildDialog ParentNode="_addChildTarget"
                   IsVisible="_showAddChildDialog"
                   OnAdd="ExecuteAddChild"
                   OnClose="CloseAddChildDialog" />

@* ── ShipExec connect dialog ── *@
<ConnectDialog IsVisible="_showConnectDialog"
               OnClose="() => _showConnectDialog = false"
               OnCompanyConnected="HandleCompanyConnected" />

@* ── Diff result dialog ── *@
<DiffResultDialog IsVisible="_showDiffDialog"
                  Result="_diffResult"
                  CanApply="true"
                  OnClose="() => _showDiffDialog = false" />

