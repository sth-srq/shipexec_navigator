            await Task.Yield();
            await JSRuntime.InvokeVoidAsync("renderCbrDiff", "cbrChatDiffDisplay", _cbrChatPreCode, _cbrChatPendingCode);
        }
        catch { }
    }

    private string FormatCbrChatMessage(string content)
    {
        // Simple HTML-safe rendering with code block support
        var escaped = System.Net.WebUtility.HtmlEncode(content);
        escaped = System.Text.RegularExpressions.Regex.Replace(escaped, @"`([^`]+)`", "<code>$1</code>");
        escaped = escaped.Replace("\n", "<br />");
        return escaped;
    }

