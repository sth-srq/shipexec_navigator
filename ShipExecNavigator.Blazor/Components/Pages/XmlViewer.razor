        UpdateShipperFieldInTree(shipperNode, "StateProvince", shipper.StateProvince);
        UpdateShipperFieldInTree(shipperNode, "PostalCode",    shipper.PostalCode);
        UpdateShipperFieldInTree(shipperNode, "Country",       shipper.Country);
        UpdateShipperFieldInTree(shipperNode, "Company",       shipper.Company);
