            _cbrLoading = false;
        }
    }

    private void SelectCbr(CbrInfo cbr)
    {
        _selectedCbr        = cbr;
        _cbrOriginalScript  = cbr.Script ?? string.Empty;
        _cbrEditedScript    = cbr.Script ?? string.Empty;
        _cbrAnalysisResult  = null;
        _cbrAnalysisError   = null;
        _cbrAnalysisVisible = false;
        _cbrAnalyzing       = false;
    }

    private void SaveCbrEdit()
    {
        if (_selectedCbr is null) return;
        if (_cbrEditedScript == _cbrOriginalScript) return;
        _varianceEntries.Insert(0, new Variance
        {
            NodeId          = Guid.Empty,
            PathDescription = $"Client Business Rules \u203a {_selectedCbr.Name}",
            Description     = "Script modified",
            ChangeType      = "Modified",
            OriginalXML     = _cbrOriginalScript,
            NewXML          = _cbrEditedScript,
        });
        _selectedCbr.Script = _cbrEditedScript;
        _cbrOriginalScript  = _cbrEditedScript;
        _variancePanelVisible = true;
    }

    private void CancelCbrEdit()
    {
        _cbrEditedScript = _cbrOriginalScript;
    }

    private async Task RunCbrAnalysisAsync()
    {
        if (_selectedCbr is null || _cbrAnalyzing) return;

        _cbrAnalyzing       = true;
        _cbrAnalysisError   = null;
        _cbrAnalysisResult  = null;
        _cbrAnalysisVisible = true;
        StateHasChanged();

        try
        {
            _cbrAnalysisResult = await CbrAnalysisService.AnalyzeCbrAsync(_cbrEditedScript);
        }
        catch (Exception ex)
        {
            _cbrAnalysisError = ex.Message;
        }
        finally
        {
            _cbrAnalyzing = false;
        }
    }

    private void AcceptCbrAnalysis()
    {
        if (string.IsNullOrWhiteSpace(_cbrAnalysisResult)) return;
        _cbrEditedScript    = _cbrAnalysisResult;
        _cbrAnalysisVisible = false;
        _cbrAnalysisResult  = null;
    }

    private void DismissCbrAnalysis()
    {
        _cbrAnalysisVisible = false;
        _cbrAnalysisResult  = null;
        _cbrAnalysisError   = null;
    }

    private async Task DownloadSbrAsync(SbrInfo sbr)
    {
        if (string.IsNullOrEmpty(sbr.FileBase64)) return;
        var safeName = string.IsNullOrWhiteSpace(sbr.Name)
            ? "sbr"
            : sbr.Name.Replace(" ", "_");
        await JSRuntime.InvokeVoidAsync(
            "downloadBase64File", $"{safeName}.dll", sbr.FileBase64, "application/octet-stream");
    }

    private async Task SearchLogsAsync()
    {
        _logsSearching = true;
        _logsError = null;
        _logsSearched = false;
        try
        {
            var endOfDay = _logEnd.Date.AddHours(23).AddMinutes(59).AddSeconds(59);
            var appTask = ShipExecService.GetApplicationLogsAsync(_logStart.Date, endOfDay);
            var secTask = ShipExecService.GetSecurityLogsAsync(_logStart.Date, endOfDay);
            await Task.WhenAll(appTask, secTask);

            var (appTotal, appLogs) = await appTask;
            var (secTotal, secLogs) = await secTask;

            _logTotal    = appTotal;
            _logs        = appLogs;
            _secLogTotal = secTotal;
            _secLogs     = secLogs;
            _combLogs    = appLogs
                .Select(l => new CombinedLogEntry
                {
                    Source        = "App",
                    Id            = l.Id,
                    LogLevel      = l.LogLevel,
                    Logger        = l.Logger,
                    LogDate       = l.LogDate,
                    Message       = l.Message,
                    TransactionId = l.TransactionId,
                    ServerAddress = l.ServerAddress,
                })
                .Concat(secLogs.Select(l => new CombinedLogEntry
                {
                    Source        = "Security",
                    Id            = l.Id,
                    LogLevel      = l.LogLevel,
                    Logger        = l.Logger,
                    LogDate       = l.LogDate,
                    Message       = l.Message,
                    TransactionId = l.TransactionId,
                    ServerAddress = l.ServerAddress,
                    UserName      = l.UserName,
                    ActionType    = l.ActionType,
                    Entity        = l.Entity,
                    EntityName    = l.EntityName,
                    CurrentValue  = l.CurrentValue,
                    PreviousValue = l.PreviousValue,
                }))
                .OrderByDescending(l => l.LogDate ?? DateTime.MinValue)
                .ToList();

            _logsSearched = true;
        }
        catch (Exception ex)
        {
            _logsError = ex.Message;
        }
        finally
        {
            _logsSearching = false;
        }
    }

    private async Task ExportShippersAsync()
    {
        _isExportingShippers = true;
        try
        {
            var csv = await ShipExecService.ExportShippersCsvAsync();
            var companySlug = (ShipExecService.GetCurrentCompany()?.Name ?? "shippers").Replace(" ", "_");
            var filename = $"{companySlug}_shippers_{DateTime.Now:yyyyMMdd}.csv";
            await JSRuntime.InvokeVoidAsync("downloadFile", filename, csv, "text/csv");
        }
        catch (Exception ex)
        {
            await AlertService.ShowAlertAsync($"Export failed: {ex.Message}");
        }
        finally
        {
            _isExportingShippers = false;
        }
    }

    private async Task ExportLogsCsvAsync()
    {
        _logsExporting = true;
        try
        {
            var sb = new System.Text.StringBuilder();
            var dateSuffix = $"{_logStart:yyyyMMdd}_{_logEnd:yyyyMMdd}";

            if (_logMode == "application")
            {
                sb.AppendLine("Date/Time,Level,Logger,Message,Server,Transaction ID");
                foreach (var log in _logs)
                    sb.AppendLine(string.Join(",",
                        EscapeLogCsv(log.LogDate?.ToString("yyyy-MM-dd HH:mm:ss.fff")),
                        EscapeLogCsv(log.LogLevel),
                        EscapeLogCsv(log.Logger),
                        EscapeLogCsv(log.Message),
                        EscapeLogCsv(log.ServerAddress),
                        EscapeLogCsv(log.TransactionId)));
                await JSRuntime.InvokeVoidAsync("downloadFile", $"logs_application_{dateSuffix}.csv", sb.ToString(), "text/csv");
            }
            else if (_logMode == "security")
            {
                sb.AppendLine("Date/Time,Level,User,Action,Entity,Entity Name,Current Value,Previous Value,Message,Server,Transaction ID");
                foreach (var log in _secLogs)
                    sb.AppendLine(string.Join(",",
                        EscapeLogCsv(log.LogDate?.ToString("yyyy-MM-dd HH:mm:ss.fff")),
                        EscapeLogCsv(log.LogLevel),
                        EscapeLogCsv(log.UserName),
                        EscapeLogCsv(log.ActionType),
                        EscapeLogCsv(log.Entity),
                        EscapeLogCsv(log.EntityName),
                        EscapeLogCsv(log.CurrentValue),
                        EscapeLogCsv(log.PreviousValue),
                        EscapeLogCsv(log.Message),
                        EscapeLogCsv(log.ServerAddress),
                        EscapeLogCsv(log.TransactionId)));
                await JSRuntime.InvokeVoidAsync("downloadFile", $"logs_security_{dateSuffix}.csv", sb.ToString(), "text/csv");
            }
            else
            {
                sb.AppendLine("Date/Time,Source,Level,Logger/User,Action,Entity,Entity Name,Message,Server,Transaction ID");
                foreach (var log in _combLogs)
                    sb.AppendLine(string.Join(",",
                        EscapeLogCsv(log.LogDate?.ToString("yyyy-MM-dd HH:mm:ss.fff")),
                        EscapeLogCsv(log.Source),
                        EscapeLogCsv(log.LogLevel),
                        EscapeLogCsv(log.Source == "Security" ? log.UserName : log.Logger),
                        EscapeLogCsv(log.ActionType),
                        EscapeLogCsv(log.Entity),
                        EscapeLogCsv(log.EntityName),
                        EscapeLogCsv(log.Message),
                        EscapeLogCsv(log.ServerAddress),
                        EscapeLogCsv(log.TransactionId)));
                await JSRuntime.InvokeVoidAsync("downloadFile", $"logs_both_{dateSuffix}.csv", sb.ToString(), "text/csv");
            }
        }
        finally
        {
            _logsExporting = false;
        }
    }

    private static string EscapeLogCsv(string? value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n') || value.Contains('\r'))
            return $"\"{value.Replace("\"", "\"\"")}\"";
        return value;
    }

