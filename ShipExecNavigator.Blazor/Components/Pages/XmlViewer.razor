    private async Task ViewChanges()
    {
        if (rootNode is null) return;
        _isComputingDiff = true;
        errorMessage = null;
        try
        {
            // Categories the user never expanded are still unloaded — skip them entirely
            // so they don't produce false "all items deleted" diffs.
            var unloadedCategories = rootNode.Children
                .Where(c => c.IsLazyLoadable && !c.IsLazyLoaded)
                .Select(c => c.NodeName)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            // Only fetch the sections that were actually loaded in the tree.
            var loadedSections = rootNode.Children
                .Where(c => c.IsLazyLoadable && c.IsLazyLoaded)
                .Select(c => c.NodeName)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            var company = ShipExecService.GetCurrentCompany();
            if (company is null) throw new InvalidOperationException("No company connected.");

            // Fetch the live XML for only the loaded sections, and serialize the local tree concurrently.
            var originalXmlTask = ShipExecService.GetCompanyXmlAsync(company.Id, company.Name, loadedSections: loadedSections);
            var modifiedXml = await XmlViewerService.SerializeAsync(rootNode);
            var originalXml = await originalXmlTask;

            // Remove unloaded categories from both sides before diffing.
            if (unloadedCategories.Count > 0)
            {
                modifiedXml = StripChildElements(modifiedXml, unloadedCategories);
                originalXml = StripChildElements(originalXml, unloadedCategories);
            }

            _diffResult = await ShipExecService.GetDiffAsync(originalXml, modifiedXml);

            if (_pendingShipperVariances.Count > 0)
            {
                var opts = new System.Text.Json.JsonSerializerOptions { WriteIndented = true };

                // Register the pending shipper variances into _lastVariances so that
                // ApplyChangesAsync(selectedIndices) can look them up by index.
                var pendingList = _pendingShipperVariances
                    .Where(v => v.NewObject is PSI.Sox.Shipper || (v.IsRemove && v.OriginalObject is PSI.Sox.Shipper))
                    .ToList();
                var startIndex = ShipExecService.AppendPendingVariances(pendingList);

                foreach (var (v, offset) in pendingList.Select((v, i) => (v, i)))
                {
                    if (v.IsRemove && v.OriginalObject is PSI.Sox.Shipper removedShipper)
                    {
                        _diffResult.Variances.Add(new VarianceInfo
                        {
                            VarianceIndex = startIndex + offset,
                            EntityName    = "Shipper",
                            ChangeType    = "Remove",
                            OriginalXML   = System.Text.Json.JsonSerializer.Serialize(removedShipper, opts),
                            NewXML        = string.Empty,
                        });
                    }
                    else if (v.NewObject is PSI.Sox.Shipper incoming)
                    {
                        _diffResult.Variances.Add(new VarianceInfo
                        {
                            VarianceIndex = startIndex + offset,
                            EntityName    = "Shipper",
                            ChangeType    = v.IsAdd ? "Add" : "Update",
                            OriginalXML   = v.OriginalObject is PSI.Sox.Shipper orig
                                ? System.Text.Json.JsonSerializer.Serialize(orig, opts)
                                : string.Empty,
                            NewXML        = System.Text.Json.JsonSerializer.Serialize(incoming, opts),
                        });
                    }
                }
            }

            _showDiffDialog = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to compute changes: {ex.Message}";
        }
        finally
        {
            _isComputingDiff = false;
        }
    }

    private static string StripChildElements(string xml, HashSet<string> elementNames)
    {
        try
        {
            var doc = XDocument.Parse(xml);
            foreach (var name in elementNames)
                doc.Root?.Elements(name).Remove();
            return doc.ToString();
        }
        catch
        {
            return xml;
        }
    }

