    private async Task LoadSbrAsync()
    {
        if (_sbrLoading || _sbrLoaded) return;
        _sbrLoading = true;
        _sbrError   = null;
        StateHasChanged();
        try
        {
            _sbrs      = await ShipExecService.GetServerBusinessRulesAsync();
            _sbrLoaded = true;
        }
        catch (Exception ex)
        {
            _sbrError = ex.Message;
        }
        finally
        {
            _sbrLoading = false;
        }
    }

    private async Task LoadCbrAsync()
    {
        if (_cbrLoading || _cbrLoaded) return;
        _cbrLoading = true;
        _cbrError   = null;
        StateHasChanged();
        try
        {
            _cbrs      = await ShipExecService.GetClientBusinessRulesAsync();
            _cbrLoaded = true;
