@page "/studio"
@page "/xml-viewer"
@rendermode InteractiveServer
@implements IDisposable

@using ShipExecNavigator.BusinessLogic.EntityComparison
@using ShipExecNavigator.Shared.AI
@using ShipExecNavigator.Shared.Models
@using System.Xml.Linq
@inject IXmlViewerService XmlViewerService
@inject IXmlSchemaService XmlSchemaService
@inject IShipExecService ShipExecService
@inject IXmlRefLookupService XmlRefLookupService
@inject IJSRuntime JSRuntime
@inject AlertService AlertService
@inject IAiChatService AiChatService
@inject ICbrAnalysisService CbrAnalysisService

<PageTitle>ShipExec Navigator</PageTitle>

<div class="viewer-page">

    <div class="page-brand-row">
        <span class="page-brand-title">ShipExec<span class="page-brand-accent">Navigator</span></span>
    </div>

    <div class="page-tab-bar">
        <a class="page-tab" href="/">&#x1F916; ShipExec Copilot</a>
        <span class="page-tab page-tab--active">&#x1F5FA; Navigator</span>
        <a class="page-tab" href="/tools">&#x1F527; Tools</a>
        <a class="page-tab" href="/debug" style="display:none">&#x1F41B; Debug</a>
    </div>

    <div class="load-panel @(rootNode != null ? "load-panel--compact" : "")">
        @if (rootNode == null)
        {
            <div class="hero">
                <h1 class="hero-title">ShipExec Navigator</h1>
                <p class="hero-subtitle">Connect to ShipExec to explore and manage a company configuration.</p>
            </div>
        }

        <div class="input-row @(rootNode == null ? "input-row--centered" : "")">
            @if (rootNode != null)
            {
                <select class="company-switcher" value="@_currentCompanyId" @onchange="SwitchCompanyAsync">
                    @foreach (var c in _cachedCompanies)
                    {
                        <option value="@c.Id">@c.DisplayName</option>
                    }
                </select>
                <button class="btn-refresh-icon" @onclick="RefreshCompanyAsync" disabled="@isLoading" title="Refresh the company data from the server">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    }
                    else
                    {
                        <span class="refresh-icon">&#x1F504;</span>
                    }
                </button>
                @if (_managementStudioUrl is not null)
                {
                    <a class="btn-ms-link" href="@($"{_managementStudioUrl}{_currentCompanyId}")" target="_blank" rel="noopener"
                       title="Open in ShipExec Navigator">&#x1F517; Navigator</a>
                    <span class="source-badge source-badge--live">
                        &#x1F7E2; Live
                    </span>
                }
            }
            else
            {
                <button class="btn-load" @onclick="OpenConnectDialog" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    }
                    <span>&#x1F517; Connect to ShipExec</span>
                </button>
            }
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-banner" role="alert">
                <span class="error-icon">&#9888;</span>
                <span>@errorMessage</span>
            </div>
        }
    </div>

    @if (rootNode != null)
    {
        @if (_varianceEntries.Any(e => !e.IsHistorical))
        {
            <div class="apply-changes-bar">
                <button class="apply-changes-bar-btn @(_applyChangesGlow ? "apply-changes-bar-btn--glow" : "")"
                        @onclick="HandleApplyChangesFromBar"
                        disabled="@(_isComputingDiff ? "disabled" : null)">
                    @if (_isComputingDiff)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    }
                    &#x2714; Apply Changes (@_varianceEntries.Count(e => !e.IsHistorical))
                </button>
            </div>
        }

        <div class="preview-import-bar">
            <button class="preview-changes-btn" @onclick="PreviewChanges" title="Open the variance panel to preview changes">
                &#x1F50D; Preview Changes
            </button>
            <button class="import-variances-btn" @onclick="() => _showImportVariancesDialog = true" title="Import variances from a JSON file">
                &#x1F4E5; Import Variances
            </button>
        </div>

        <div class="viewer-content-row">

        <div class="viewer-main-area">
        <div class="viewer-tabs">
            <button class='viewer-tab @(_activeMainTab == "company" ? "viewer-tab--active" : "")'
                    @onclick='SwitchToCompanyTab'>&#x1F3E2; Company</button>
            <button class='viewer-tab @(_activeMainTab == "server-rules" ? "viewer-tab--active" : "")'
                    @onclick='SwitchToServerRulesTab'>&#x1F5A5;&#xFE0F; Server Rules</button>
            <button class='viewer-tab @(_activeMainTab == "client-rules" ? "viewer-tab--active" : "")'
                    @onclick='SwitchToClientRulesTab'>&#x1F4BB; Client Rules</button>
            <button class='viewer-tab @(_activeMainTab == "logs" ? "viewer-tab--active" : "")'
                    @onclick='SwitchToLogsTab'>&#x1F4CB; Logs</button>
        </div>

        <div class="viewer-body-row">
            <VariancePanel Entries="_varianceEntries"
                           @bind-IsVisible="_variancePanelVisible"
                           FlashIds="_flashVarianceIds"
                           OnEntryClicked="NavigateToNode"
                           OnEntryUndo="UndoVariance"
                           OnViewChanges="ViewChanges"
                           OnClearAndRevert="ClearAndRevertAsync"
                           HistoryError="@_historyError" />

            <div class="viewer-main">
        <div class="viewer-workspace" style="@(_activeMainTab != "company" ? "display:none" : "")">
        <div class="tree-panel">
            <div class="tree-toolbar">
                <div class="toolbar-info">
                    <span class="root-tag">@rootNode.NodeName</span>
                    @if (!string.IsNullOrEmpty(loadedFileName))
                    {
                        <span class="company-name">@loadedFileName</span>
                    }
                    @{ var licNode = rootNode.Children.FirstOrDefault(c => c.NodeName.Equals("LicenseId", StringComparison.OrdinalIgnoreCase)); }
                    @if (licNode is not null && !string.IsNullOrWhiteSpace(licNode.NodeValue))
                    {
                        <span class="stat-pill" title="LicenseId">&#x1F511; @licNode.NodeValue</span>
                    }
                    @{ var profNode = rootNode.Children.FirstOrDefault(c => c.NodeName.Equals("ProfileId", StringComparison.OrdinalIgnoreCase)); }
                    @if (profNode is not null && !string.IsNullOrWhiteSpace(profNode.NodeValue))
                    {
                        var profName = XmlRefLookupService.GetRefOptions("ProfileId")?.FirstOrDefault(o => o.Value == profNode.NodeValue)?.Display;
                        <span class="stat-pill" title="ProfileId: @profNode.NodeValue">&#x1F4CB; @(profName ?? profNode.NodeValue)</span>
                    }
                    @if (_isDirty)
                    {
                        <span class="dirty-pill">&#x25CF; unsaved</span>
                    }
                </div>
                <div class="toolbar-actions">
                    <button class="btn-export" @onclick="ViewChanges"
                            disabled="@(_isComputingDiff ? "disabled" : null)"
                            title="Compute variances and requests against the live server">
                        @if (_isComputingDiff)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        }
                        &#x1F4CA; View Changes
                    </button>
                    <button class="btn-action" @onclick="ExpandAll">Expand All</button>
                    <button class="btn-action" @onclick="CollapseAll">Collapse All</button>
                    <span class="depth-label">Depth</span>
                    <div class="depth-group">
                        <button class="btn-depth @(activeDepth == 1 ? "active" : "")" @onclick="() => ExpandToDepth(1)">1</button>
                        <button class="btn-depth @(activeDepth == 2 ? "active" : "")" @onclick="() => ExpandToDepth(2)">2</button>
                        <button class="btn-depth @(activeDepth == 3 ? "active" : "")" @onclick="() => ExpandToDepth(3)">3</button>
                        <button class="btn-depth @(activeDepth == 4 ? "active" : "")" @onclick="() => ExpandToDepth(4)">4</button>
                    </div>
                    <button class="btn-close-tree" @onclick="CloseTree" title="Close tree">&#x2715;</button>
                </div>
            </div>

            <div class="tree-body">
                <CascadingValue Name="TreeVersion" Value="_version" IsFixed="false">
                    <CascadingValue Name="NodeContextMenu" Value="_contextMenuHandler" IsFixed="true">
                        <CascadingValue Name="OnNodeModified" Value="_modifiedHandler" IsFixed="true">
                            <CascadingValue Name="OnNodeEdited" Value="_nodeEditedHandler" IsFixed="true">
                                <CascadingValue Name="HighlightedNodeId" Value="_highlightedNodeId" IsFixed="false">
                                    <CascadingValue Name="OnLazyLoadAsync" Value="_lazyLoadHandler" IsFixed="true">
                                        <CascadingValue Name="TreeFilterCategory" Value="_treeFilterCategory" IsFixed="false">
                                            <XmlNodeTree Node="rootNode" />
                                        </CascadingValue>
                                    </CascadingValue>
                                </CascadingValue>
                            </CascadingValue>
                        </CascadingValue>
                    </CascadingValue>
                </CascadingValue>
            </div>
        </div>
        </div>
        @if (_activeMainTab == "server-rules")
        {
            <div class="br-tab-content">
                <div class="br-section">
                        <div class="br-section-body">
                            @if (_sbrLoading)
                            {
                                <div class="br-loading">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                    Loading server business rules&hellip;
                                </div>
                            }
                            else if (_sbrError is not null)
                            {
                                <div class="br-error">&#9888; @_sbrError</div>
                            }
                            else if (!_sbrLoaded)
                            {
                                <div class="br-empty">No server business rules loaded.</div>
                            }
                            else if (_sbrs.Count == 0)
                            {
                                <div class="br-empty">No server business rules found for this company.</div>
                            }
                            else
                            {
                                <div class="sbr-list">
                                    @foreach (var sbr in _sbrs)
                                    {
                                        <div class="sbr-card">
                                            <div class="sbr-card-header">
                                                <span class="sbr-name">@sbr.Name</span>
                                                <button class="sbr-download-btn @(_sbrDownloadingIds.Contains(sbr.Id) ? "sbr-download-btn--busy" : "")"
                                                        @onclick="() => DownloadSbrAsync(sbr)"
                                                        disabled="@(_sbrDownloadingIds.Contains(sbr.Id))"
                                                        title="Download @(sbr.Name).dll">
                                                    @if (_sbrDownloadingIds.Contains(sbr.Id))
                                                    {
                                                        <span class="gt-spinner-sm"></span>
                                                    }
                                                    else
                                                    {
                                                        <span>&#x2B07; @(sbr.Name).dll</span>
                                                    }
                                                </button>
                                                <button class="sbr-download-btn @(_sbrDecompilingIds.Contains(sbr.Id) ? "sbr-download-btn--busy" : "")"
                                                        @onclick="() => DownloadSbrProjectAsync(sbr)"
                                                        disabled="@(_sbrDecompilingIds.Contains(sbr.Id))"
                                                        title="Decompile and download @(sbr.Name) as a VS project (.zip)">
                                                    @if (_sbrDecompilingIds.Contains(sbr.Id))
                                                    {
                                                        <span class="gt-spinner-sm"></span>
                                                    }
                                                    else
                                                    {
                                                        <span>&#x1F4E6; @(sbr.Name) Project</span>
                                                    }
                                                </button>
                                                <button class="sbr-view-btn @(_sbrViewingIds.Contains(sbr.Id) ? "sbr-download-btn--busy" : "")"
                                                        @onclick="() => ViewSbrProjectAsync(sbr)"
                                                        disabled="@(_sbrViewingIds.Contains(sbr.Id))"
                                                        title="Decompile and view @(sbr.Name) source code">
                                                    @if (_sbrViewingIds.Contains(sbr.Id))
                                                    {
                                                        <span class="gt-spinner-sm"></span>
                                                    }
                                                    else
                                                    {
                                                        <span>&#x1F441; View</span>
                                                    }
                                                </button>
                                            </div>
                                            <div class="sbr-details">
                                                @if (!string.IsNullOrWhiteSpace(sbr.Description))
                                                {
                                                    <div class="sbr-detail-row">
                                                        <span class="sbr-detail-label">Description</span>
                                                        <span class="sbr-detail-value">@sbr.Description</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(sbr.Version))
                                                {
                                                    <div class="sbr-detail-row">
                                                        <span class="sbr-detail-label">Version</span>
                                                        <span class="sbr-detail-value">@sbr.Version</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(sbr.Author))
                                                {
                                                    <div class="sbr-detail-row">
                                                        <span class="sbr-detail-label">Author</span>
                                                        <span class="sbr-detail-value">@sbr.Author@(!string.IsNullOrWhiteSpace(sbr.AuthorEmail) ? $" <{sbr.AuthorEmail}>" : "")</span>
                                                    </div>
                                                }
                                                <div class="sbr-detail-row">
                                                    <span class="sbr-detail-label">Profiles</span>
                                                    <span class="sbr-detail-value">
                                                        @if (sbr.UsedByProfiles.Count > 0)
                                                        {
                                                            @foreach (var profile in sbr.UsedByProfiles)
                                                            {
                                                                <span class="sbr-profile-tag">@profile</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span class="sbr-none">Not assigned to any profile</span>
                                                        }
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                </div>
                @if (_sbrViewerOpen)
                {
                    <div class="sbr-viewer @(_sbrViewerMaximized ? "sbr-viewer--maximized" : "")">
                        <div class="sbr-viewer-header @(!_sbrViewerDark ? "sbr-viewer-header--light" : "")">
                            <button class="sbr-viewer-back" @onclick="CloseSbrViewer">&#x2190; Back</button>
                            <span class="sbr-viewer-title">&#x1F4E6; @_sbrViewerSbr?.Name</span>
                            @if (_sbrViewerSelectedFile is not null)
                            {
                                <span class="sbr-viewer-file-path">@_sbrViewerSelectedFile</span>
                            }
                            <div class="sbr-viewer-header-actions">
                                <button class="sbr-build-btn @(_sbrBuildRunning ? "sbr-build-btn--busy" : "")"
                                        title="Test build the decompiled project"
                                        @onclick="TestBuildSbrAsync"
                                        disabled="@(_sbrBuildRunning || _sbrViewerLoading || _sbrViewerFiles.Count == 0)">
                                    @if (_sbrBuildRunning)
                                    {
                                        <span class="gt-spinner-sm"></span>
                                    }
                                    else
                                    {
                                        <span>&#x1F6E0; Test Build</span>
                                    }
                                </button>
                                @if (_sbrBuildSucceeded)
                                {
                                    <button class="sbr-deploy-btn @(_sbrDeploying ? "sbr-deploy-btn--busy" : "")"
                                            title="Build Release, download DLL, and copy base64 to clipboard"
                                            @onclick="DeploySbrAsync"
                                            disabled="@(_sbrDeploying)">
                                        @if (_sbrDeploying)
                                        {
                                            <span class="gt-spinner-sm"></span>
                                        }
                                        else
                                        {
                                            <span>&#x1F680; Deploy</span>
                                        }
                                    </button>
                                }
                                <button class="sbr-chat-toggle @(_sbrChatVisible ? "sbr-chat-toggle--active" : "")"
                                        title="@(_sbrChatVisible ? "Close AI chat" : "Chat with AI about this SBR")"
                                        @onclick="ToggleSbrChat">
                                    &#x1F4AC; Chat
                                </button>
                                <button class="cbr-btn-theme"
                                        title='@(_sbrViewerDark ? "Switch to light theme" : "Switch to dark theme")'
                                        @onclick="() => ToggleSbrViewerTheme()">
                                    @(_sbrViewerDark ? "\u2600" : "\uD83C\uDF19")
                                </button>
                                <button class="cbr-btn-maximize"
                                        title='@(_sbrViewerMaximized ? "Minimize" : "Maximize")'
                                        @onclick="() => _sbrViewerMaximized = !_sbrViewerMaximized">
                                    @(_sbrViewerMaximized ? "\u22A1" : "\u26F6")
                                </button>
                            </div>
                        </div>
                        <div class="sbr-viewer-body">
                            @if (_sbrViewerLoading)
                            {
                                <div class="sbr-viewer-loading">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                    Decompiling @_sbrViewerSbr?.Name&hellip;
                                </div>
                            }
                            else if (_sbrViewerError is not null)
                            {
                                <div class="br-error" style="margin: 1.5rem;">&#9888; @_sbrViewerError</div>
                            }
                            else
                            {
                                <div class="sbr-file-tree">
                                    @foreach (var filePath in _sbrViewerFilePaths)
                                    {
                                        var fp = filePath;
                                        var ext = Path.GetExtension(fp).ToLowerInvariant();
                                        var icon = ext switch
                                        {
                                            ".cs" => "\uD83D\uDD37",
                                            ".csproj" => "\uD83D\uDCCB",
                                            ".config" => "\u2699\uFE0F",
                                            ".xml" => "\uD83D\uDCC4",
                                            ".json" => "\uD83D\uDCC4",
                                            _ => "\uD83D\uDCC4"
                                        };
                                        <button class="sbr-file-item @(_sbrViewerSelectedFile == fp ? "sbr-file-item--active" : "")"
                                                @onclick="() => SelectSbrFileAsync(fp)">
                                            <span class="sbr-file-icon">@icon</span>
                                            <span class="sbr-file-name">@fp</span>
                                        </button>
                                    }
                                </div>
                                <div class="sbr-code-viewer @(!_sbrViewerDark ? "sbr-code-viewer--light" : "")">
                                    @if (_sbrViewerSelectedFile is null)
                                    {
                                        <div class="cbr-viewer-empty">&#x2190; Select a file to view</div>
                                    }
                                    else if (_sbrEditing)
                                    {
                                        <textarea class="sbr-editor @(!_sbrViewerDark ? "sbr-editor--light" : "")" spellcheck="false"
                                                  @bind="_sbrViewerSelectedContent"
                                                  @bind:event="oninput"></textarea>
                                    }
                                    else
                                    {
                                        <div id="sbrCodeDisplay" class="cbr-code-display"
                                             @ondblclick="EnterSbrEditMode"></div>
                                    }
                                </div>
                                @if (_sbrViewerSelectedFile is not null)
                                {
                                    <div class="sbr-footer @(!_sbrViewerDark ? "sbr-footer--light" : "")">
                                        @if (!_sbrEditing)
                                        {
                                            <button class="sbr-btn-edit" @onclick="EnterSbrEditMode" title="Switch to edit mode">
                                                &#x270F; Edit
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="sbr-btn-save" @onclick="SaveSbrEdit">
                                                &#x2714; Save
                                            </button>
                                            <button class="sbr-btn-cancel" @onclick="CancelSbrEdit">
                                                &#x2715; Cancel
                                            </button>
                                        }
                                    </div>
                                }
                            }
                        </div>
                        @if (_sbrBuildOutput is not null)
                        {
                            <div class="sbr-build-output @(!_sbrViewerDark ? "sbr-build-output--light" : "")">
                                <div class="sbr-build-output-header">
                                    <span>&#x1F6E0; Build Output</span>
                                    <button class="sbr-build-output-close" @onclick="() => _sbrBuildOutput = null">&#x2715;</button>
                                </div>
                                <pre class="sbr-build-output-body">@_sbrBuildOutput</pre>
                            </div>
                        }
                        @* ── SBR Chat Panel ── *@
                        @if (_sbrChatVisible)
                        {
                            <div class="sbr-chat-panel @(!_sbrViewerDark ? "sbr-chat-panel--light" : "")">
                                <div class="sbr-chat-header">
                                    <span class="sbr-chat-title">&#x1F4AC; SBR Chat — @_sbrViewerSbr?.Name</span>
                                    <div class="sbr-chat-actions">
                                        <button class="sbr-chat-clear" @onclick="ClearSbrChat"
                                                disabled="@(_sbrChatHistory.Count == 0)"
                                                title="Clear chat">&#x1F5D1;</button>
                                        <button class="sbr-chat-close" @onclick="ToggleSbrChat"
                                                title="Close chat">&#x2715;</button>
                                    </div>
                                </div>
                                <div class="sbr-chat-messages" id="sbr-chat-messages">
                                    @if (_sbrChatHistory.Count == 0 && !_sbrChatThinking)
                                    {
                                        <div class="sbr-chat-empty">
                                            Ask the AI about this SBR — request changes, ask questions, or describe what you want.
                                        </div>
                                    }
                                    @foreach (var msg in _sbrChatHistory)
                                    {
                                        <div class="sbr-chat-bubble sbr-chat-bubble--@msg.Role">
                                            <span class="sbr-chat-label">@(msg.Role == "user" ? "You" : "SBR Copilot")</span>
                                            <div class="sbr-chat-body">@((MarkupString)FormatCbrChatMessage(msg.Content))</div>
                                        </div>
                                    }
                                    @if (_sbrChatThinking)
                                    {
                                        <div class="sbr-chat-bubble sbr-chat-bubble--assistant">
                                            <span class="sbr-chat-label">SBR Copilot</span>
                                            <div class="sbr-chat-body sbr-chat-thinking">
                                                <span></span><span></span><span></span>
                                            </div>
                                        </div>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(_sbrChatError))
                                {
                                    <div class="sbr-chat-error">&#9888; @_sbrChatError</div>
                                }
                                <div class="sbr-chat-input-row">
                                    <input type="text"
                                           class="sbr-chat-input"
                                           placeholder="Ask about this SBR…"
                                           @bind="_sbrChatInput"
                                           @bind:event="oninput"
                                           @onkeydown="HandleSbrChatKeyDown"
                                           disabled="@_sbrChatThinking" />
                                    <button class="sbr-chat-send"
                                            @onclick="SendSbrChatAsync"
                                            disabled="@(string.IsNullOrWhiteSpace(_sbrChatInput) || _sbrChatThinking)"
                                            title="Send">
                                        &#x27A4;
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        @if (_activeMainTab == "client-rules")
        {
            <div class="br-tab-content">
                <div class="br-section @(_selectedCbr is not null ? "br-section--viewer" : "")">
                        <div class="br-section-body">
                            @if (_cbrLoading)
                            {
                                <div class="br-loading">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                    Loading client business rules&hellip;
                                </div>
                            }
                            else if (_cbrError is not null)
                            {
                                <div class="br-error">&#9888; @_cbrError</div>
                            }
                            else if (!_cbrLoaded)
                            {
                                <div class="br-empty">No client business rules loaded.</div>
                            }
                            else if (_cbrs.Count == 0)
                            {
                                <div class="br-empty">No client business rules found for this company.</div>
                            }
                            else
                            {
                                @if (_selectedCbr is not null)
                                {
                                    <div class="cbr-top-bar @(!_cbrDark ? "cbr-top-bar--light" : "")">
                                        <span class="cbr-viewer-name">@_selectedCbr.Name</span>
                                        @if (!string.IsNullOrWhiteSpace(_selectedCbr.Version))
                                        {
                                            <span class="cbr-viewer-version">@_selectedCbr.Version</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(_selectedCbr.Description))
                                        {
                                            <span class="cbr-viewer-desc">@_selectedCbr.Description</span>
                                        }
                                        <div class="cbr-viewer-header-actions">
                                            <button class="cbr-btn-download"
                                                    @onclick="DownloadCbrAsync"
                                                    title="Download script as .js file">
                                                &#x2B07; .js
                                            </button>
                                            <button class="cbr-btn-theme"
                                                    title='@(_cbrDark ? "Switch to light theme" : "Switch to dark theme")'
                                                    @onclick="() => _cbrDark = !_cbrDark">
                                                @(_cbrDark ? "\u2600" : "\uD83C\uDF19")
                                            </button>
                                            <button class="cbr-btn-maximize"
                                                    title='@(_cbrMaximized ? "Restore" : "Maximize")'
                                                    @onclick="() => _cbrMaximized = !_cbrMaximized">
                                                @(_cbrMaximized ? "\u22A1" : "\u26F6")
                                            </button>
                                        </div>
                                    </div>
                                }
                                <div class="cbr-body">
                                    <div class="cbr-sidebar">
                                        @foreach (var cbr in _cbrs)
                                        {
                                            <button class="cbr-item @(_selectedCbr?.Id == cbr.Id ? "cbr-item--active" : "")"
                                                    @onclick="() => SelectCbr(cbr)">
                                                <span class="cbr-item-name">@cbr.Name</span>
                                                @if (!string.IsNullOrWhiteSpace(cbr.Version))
                                                {
                                                    <span class="cbr-item-version">@cbr.Version</span>
                                                }
                                                @if (cbr.UsedByProfiles.Count > 0)
                                                {
                                                    <span class="cbr-item-profiles">@string.Join(", ", cbr.UsedByProfiles)</span>
                                                }
                                            </button>
                                        }
                                    </div>
                                    <div class="cbr-viewer @(!_cbrDark ? "cbr-viewer--light" : "") @(_cbrMaximized ? "cbr-viewer--maximized" : "")">
                                        @if (_cbrMaximized && _selectedCbr is not null)
                                        {
                                            <div class="cbr-maximized-bar @(!_cbrDark ? "cbr-top-bar--light" : "")">
                                                <span class="cbr-viewer-name">@_selectedCbr.Name</span>
                                                <div class="cbr-viewer-header-actions">
                                                    <button class="cbr-btn-theme"
                                                            title='@(_cbrDark ? "Switch to light theme" : "Switch to dark theme")'
                                                            @onclick="() => _cbrDark = !_cbrDark">
                                                        @(_cbrDark ? "\u2600" : "\uD83C\uDF19")
                                                    </button>
                                                    <button class="cbr-btn-maximize"
                                                            title="Restore"
                                                            @onclick="() => _cbrMaximized = false">
                                                        &#x22A1;
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                        @if (_selectedCbr is null)
                                        {
                                            <div class="cbr-viewer-empty">&#x2190; Select a rule to view its script</div>
                                        }
                                        else
                                        {
                                            <div class="cbr-code-wrap">
                                                @if (_cbrEditing)
                                                {
                                                    <textarea class="cbr-editor" spellcheck="false"
                                                              @bind="_cbrEditedScript"
                                                              @bind:event="oninput"></textarea>
                                                }
                                                else
                                                {
                                                    <div id="cbrCodeDisplay" class="cbr-code-display"
                                                         @ondblclick="() => _cbrEditing = true"></div>
                                                }
                                            </div>
                                            <div class="cbr-footer">
                                                @if (!_cbrEditing)
                                                {
                                                    <button class="cbr-btn-edit"
                                                            @onclick="() => _cbrEditing = true"
                                                            title="Switch to edit mode">
                                                        &#x270F; Edit
                                                    </button>
                                                }
                                                <button class="cbr-btn-save"
                                                        @onclick="SaveCbrEdit"
                                                        disabled="@(_cbrEditedScript == _cbrOriginalScript)">
                                                    &#x2714; Save
                                                </button>
                                                <button class="cbr-btn-cancel"
                                                        @onclick="CancelCbrEdit"
                                                        disabled="@(_cbrEditedScript == _cbrOriginalScript)">
                                                    &#x2715; Cancel
                                                </button>
                                                <button class="cbr-btn-analyze"
                                                        @onclick="RunCbrAnalysisAsync"
                                                        disabled="@(_cbrAnalyzing || string.IsNullOrWhiteSpace(_cbrEditedScript))">
                                                    @if (_cbrAnalyzing)
                                                    {
                                                        <span class="cbr-analyze-spinner"></span>
                                                        <span>Analyzing…</span>
                                                    }
                                                    else
                                                    {
                                                        <span>&#x1F9E0; Analyze</span>
                                                    }
                                                </button>
                                                <button class="cbr-btn-chat @(_cbrChatVisible ? "cbr-btn-chat--active" : "")"
                                                        @onclick="ToggleCbrChat"
                                                        title="@(_cbrChatVisible ? "Close AI chat" : "Chat with AI about this script")">
                                                    &#x1F4AC; Chat
                                                </button>
                                            </div>
                                            @if (_cbrAnalysisVisible)
                                            {
                                                <div class="cbr-analysis-panel">
                                                    <div class="cbr-analysis-header">
                                                        <span class="cbr-analysis-title">&#x1F9E0; AI Analysis — @_selectedCbr.Name</span>
                                                        <div class="cbr-analysis-actions">
                                                            @if (_cbrAnalysisResult is not null)
                                                            {
                                                                <button class="cbr-btn-accept" @onclick="AcceptCbrAnalysis">
                                                                    &#x2714; Accept &amp; Replace
                                                                </button>
                                                            }
                                                            <button class="cbr-btn-dismiss" @onclick="DismissCbrAnalysis">
                                                                &#x2715; Dismiss
                                                            </button>
                                                        </div>
                                                    </div>
                                                    @if (_cbrAnalyzing)
                                                    {
                                                        <div class="cbr-analysis-loading">
                                                            <span class="cbr-analyze-spinner cbr-analyze-spinner--lg"></span>
                                                            <span>Sending script and CBRHelper to AI… this may take a moment.</span>
                                                        </div>
                                                    }
                                                    else if (_cbrAnalysisError is not null)
                                                    {
                                                        <div class="cbr-analysis-error">&#9888; @_cbrAnalysisError</div>
                                                    }
                                                    else if (_cbrAnalysisResult is not null)
                                                    {
                                                        <div id="cbrAnalysisDisplay" class="cbr-analysis-display"></div>
                                                    }
                                                </div>
                                            }
                                            @* ── CBR Chat Panel (#2-4) ── *@
                                            @if (_cbrChatVisible)
                                            {
                                                <div class="cbr-chat-panel">
                                                    <div class="cbr-chat-header">
                                                        <span class="cbr-chat-title">&#x1F4AC; CBR Chat — @_selectedCbr.Name</span>
                                                        <div class="cbr-chat-actions">
                                                            <button class="cbr-chat-clear" @onclick="ClearCbrChat"
                                                                    disabled="@(_cbrChatHistory.Count == 0)"
                                                                    title="Clear chat">&#x1F5D1;</button>
                                                            <button class="cbr-chat-close" @onclick="ToggleCbrChat"
                                                                    title="Close chat">&#x2715;</button>
                                                        </div>
                                                    </div>
                                                    <div class="cbr-chat-messages" id="cbr-chat-messages">
                                                        @if (_cbrChatHistory.Count == 0 && !_cbrChatThinking)
                                                        {
                                                            <div class="cbr-chat-empty">
                                                                Type a message to chat with AI about this script.
                                                                You can ask questions, request changes, or describe what you want —
                                                                the AI will respond and can suggest code changes shown as a diff.
                                                            </div>
                                                        }
                                                        @foreach (var msg in _cbrChatHistory)
                                                        {
                                                            <div class="cbr-chat-bubble cbr-chat-bubble--@msg.Role">
                                                                <span class="cbr-chat-label">@(msg.Role == "user" ? "You" : "CBR Copilot")</span>
                                                                <div class="cbr-chat-body">@((MarkupString)FormatCbrChatMessage(msg.Content))</div>
                                                            </div>
                                                        }
                                                        @if (_cbrChatThinking)
                                                        {
                                                            <div class="cbr-chat-bubble cbr-chat-bubble--assistant">
                                                                <span class="cbr-chat-label">CBR Copilot</span>
                                                                <div class="cbr-chat-body cbr-chat-thinking">
                                                                    <span></span><span></span><span></span>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                    @if (_cbrChatPendingCode is not null)
                                                    {
                                                        <div class="cbr-chat-diff-section">
                                                            <div class="cbr-chat-diff-header">
                                                                <span>&#x1F504; Proposed Changes</span>
                                                                <div class="cbr-chat-diff-actions">
                                                                    <button class="cbr-btn-accept" @onclick="AcceptCbrChatCode">
                                                                        &#x2714; Accept
                                                                    </button>
                                                                    <button class="cbr-btn-dismiss" @onclick="DismissCbrChatCode">
                                                                        &#x2715; Dismiss
                                                                    </button>
                                                                </div>
                                                            </div>
                                                            <div id="cbrChatDiffDisplay" class="cbr-analysis-display"></div>
                                                        </div>
                                                    }
                                                    @if (!string.IsNullOrEmpty(_cbrChatError))
                                                    {
                                                        <div class="cbr-chat-error">&#9888; @_cbrChatError</div>
                                                    }
                                                    <div class="cbr-chat-input-row">
                                                        <input type="text"
                                                               class="cbr-chat-input"
                                                               placeholder="Describe a change or ask about the script…"
                                                               @bind="_cbrChatInput"
                                                               @bind:event="oninput"
                                                               @onkeydown="HandleCbrChatKeyDown"
                                                               disabled="@_cbrChatThinking" />
                                                        <button class="cbr-chat-send"
                                                                @onclick="SendCbrChatAsync"
                                                                disabled="@(string.IsNullOrWhiteSpace(_cbrChatInput) || _cbrChatThinking)"
                                                                title="Send">
                                                            &#x27A4;
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                </div>
            </div>
        }
        @if (_showUserManagement)
        {
            <div class="um-tab-content">
                <div class="um-tab-header">
                    <span>&#x1F464; User Management</span>
                    <button class="um-tab-close" @onclick="() => _showUserManagement = false" title="Close">&#x2715;</button>
                </div>
                <UserManagementDialog OnUsersJson="HandleUsersJson"
                                       OnUsersMetaJson="HandleUsersMetaJson"
                                       FoundUserIds="_foundUserIds"
                                       OnClearFound="HandleClearFoundUsers"
                                       AiPendingDeletes="_pendingUserDeletes"
                                       OnDeletesHandled="HandleUserDeletesHandled"
                                       AiPendingEdits="_pendingUserEdits"
                                       OnEditsHandled="HandleUserEditsHandled"
                                       AiCreatePrefill="_addUserPrefill"
                                       OnCreateHandled="HandleUserCreateHandled"
                                       OnVariancesChanged="HandleUserVariancesChanged" />
            </div>
        }
        @if (_activeMainTab == "logs")
        {
            <div class="logs-panel">
                <div class="logs-toolbar">
                    <div class="log-mode-toggle">
                        <button class='log-mode-btn @(_logMode == "application" ? "log-mode-btn--active" : "")'
                                @onclick='() => SetLogMode("application")'>&#x1F4CB; Application</button>
                        <button class='log-mode-btn @(_logMode == "security" ? "log-mode-btn--active" : "")'
                                @onclick='() => SetLogMode("security")'>&#x1F512; Security</button>
                        <button class='log-mode-btn @(_logMode == "both" ? "log-mode-btn--active" : "")'
                                @onclick='() => SetLogMode("both")'>&#x1F50D; Both</button>
                    </div>
                    <div class="logs-search-bar">
                        <label class="logs-label">From</label>
                        <input type="date" class="logs-date-input" @bind="_logStart" @bind:format="yyyy-MM-dd" />
                        <label class="logs-label">To</label>
                        <input type="date" class="logs-date-input" @bind="_logEnd" @bind:format="yyyy-MM-dd" />
                        <button class="btn-load logs-search-btn" @onclick="SearchLogsAsync" disabled="@_logsSearching">
                            @if (_logsSearching)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            }
                            Search
                        </button>
                    </div>
                    @if (_logsSearched)
                    {
                        @if (_logMode == "application")
                        {
                            <span class="stat-pill">@_logs.Count of @_logTotal records</span>
                        }
                        else if (_logMode == "security")
                        {
                            <span class="stat-pill">@_secLogs.Count of @_secLogTotal records</span>
                        }
                        else
                        {
                            <span class="stat-pill">@_combLogs.Count records</span>
                            <span class="log-source log-source--app">App</span>
                            <span class="log-source log-source--security">Security</span>
                        }
                        <button class='log-mode-btn @(_logExportExtended ? "log-mode-btn--active" : "")'
                                @onclick="() => _logExportExtended = !_logExportExtended"
                                title="@(_logExportExtended ? "ShipExec format — works with ShipExec API Log Viewer (includes extended fields)" : "CSV format — works with Log Viewer")">
                            @(_logExportExtended ? "&#x1F527; ShipExec" : "&#x1F4CB; CSV")
                        </button>
                        <button class="btn-export" @onclick="ExportLogsCsvAsync" disabled="@_logsExporting">
                            @if (_logsExporting)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            }
                            &#x2B07; Export @(_logExportExtended ? ".log" : "CSV")
                        </button>
                        @if (_foundLogIds is not null)
                        {
                                <button class="btn-clear-filter" @onclick="ClearLogFilter">&#x2715; Clear Filter</button>
                                }
                                <button class="logs-chat-toggle @(_logsChatVisible ? "logs-chat-toggle--active" : "")"
                                        title="@(_logsChatVisible ? "Close AI chat" : "Chat with AI about these logs")"
                                        @onclick="ToggleLogsChat">
                                    &#x1F4AC; Chat
                                </button>
                            }
                </div>

                @if (!string.IsNullOrEmpty(_logsError))
                {
                    <div class="error-banner" role="alert">
                        <span class="error-icon">&#9888;</span>
                        <span>@_logsError</span>
                    </div>
                }

                @if (_logMode == "application" && _logs.Count > 0)
                {
                    <div class="logs-table-wrap">
                        <table class="logs-table">
                            <thead>
                                <tr>
                                    <th>Date / Time</th>
                                    <th>Level</th>
                                    <th>Logger</th>
                                    <th>Message</th>
                                    <th>Server</th>
                                    <th>Transaction ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in (_foundLogIds is null ? _logs : _logs.Where(l => _foundLogIds.Contains((l.Id, "App"))).ToList()))
                                {
                                    <tr>
                                        <td class="log-date">@log.LogDate?.ToString("MM/dd HH:mm:ss.fff")</td>
                                        <td><span class="log-level log-level--@(log.LogLevel.ToLower())">@log.LogLevel</span></td>
                                        <td class="log-logger">@log.Logger</td>
                                        <td class="log-message">@log.Message</td>
                                        <td class="log-server">@log.ServerAddress</td>
                                        <td class="log-txid">@log.TransactionId</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (_logMode == "security" && _secLogs.Count > 0)
                {
                    <div class="logs-table-wrap">
                        <table class="logs-table">
                            <thead>
                                <tr>
                                    <th>Date / Time</th>
                                    <th>Level</th>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Entity</th>
                                    <th>Entity Name</th>
                                    <th>Current Value</th>
                                    <th>Previous Value</th>
                                    <th>Message</th>
                                    <th>Server</th>
                                    <th>Transaction ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in (_foundLogIds is null ? _secLogs : _secLogs.Where(l => _foundLogIds.Contains((l.Id, "Security"))).ToList()))
                                {
                                    <tr>
                                        <td class="log-date">@log.LogDate?.ToString("MM/dd HH:mm:ss.fff")</td>
                                        <td><span class="log-level log-level--@(log.LogLevel.ToLower())">@log.LogLevel</span></td>
                                        <td class="log-logger">@log.UserName</td>
                                        <td class="log-logger">@log.ActionType</td>
                                        <td class="log-logger">@log.Entity</td>
                                        <td class="log-logger">@log.EntityName</td>
                                        <td class="log-message">@log.CurrentValue</td>
                                        <td class="log-message">@log.PreviousValue</td>
                                        <td class="log-message">@log.Message</td>
                                        <td class="log-server">@log.ServerAddress</td>
                                        <td class="log-txid">@log.TransactionId</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (_logMode == "both" && _combLogs.Count > 0)
                {
                    <div class="logs-table-wrap">
                        <table class="logs-table">
                            <thead>
                                <tr>
                                    <th>Date / Time</th>
                                    <th>Source</th>
                                    <th>Level</th>
                                    <th>Logger / User</th>
                                    <th>Action</th>
                                    <th>Entity</th>
                                    <th>Entity Name</th>
                                    <th>Message</th>
                                    <th>Server</th>
                                    <th>Transaction ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in (_foundLogIds is null ? _combLogs : _combLogs.Where(l => _foundLogIds.Contains((l.Id, l.Source))).ToList()))
                                {
                                    <tr class="comb-row comb-row--@(log.Source.ToLower())">
                                        <td class="log-date">@log.LogDate?.ToString("MM/dd HH:mm:ss.fff")</td>
                                        <td><span class="log-source log-source--@(log.Source.ToLower())">@log.Source</span></td>
                                        <td><span class="log-level log-level--@(log.LogLevel.ToLower())">@log.LogLevel</span></td>
                                        <td class="log-logger">@(log.Source == "Security" ? log.UserName : log.Logger)</td>
                                        <td class="log-logger">@log.ActionType</td>
                                        <td class="log-logger">@log.Entity</td>
                                        <td class="log-logger">@log.EntityName</td>
                                        <td class="log-message">@log.Message</td>
                                        <td class="log-server">@log.ServerAddress</td>
                                        <td class="log-txid">@log.TransactionId</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (!_logsSearching && _logsSearched)
                {
                    <div class="logs-empty">No log entries found for the selected date range.</div>
                }
                @* ── Logs Chat Panel ── *@
                @if (_logsChatVisible)
                {
                    <div class="logs-chat-panel">
                        <div class="logs-chat-header">
                            <span class="logs-chat-title">&#x1F4AC; Logs Chat</span>
                            <div class="logs-chat-actions">
                                <button class="logs-chat-clear" @onclick="ClearLogsChat"
                                        disabled="@(_logsChatHistory.Count == 0)"
                                        title="Clear chat">&#x1F5D1;</button>
                                <button class="logs-chat-close" @onclick="ToggleLogsChat"
                                        title="Close chat">&#x2715;</button>
                            </div>
                        </div>
                        <div class="logs-chat-messages" id="logs-chat-messages">
                            @if (_logsChatHistory.Count == 0 && !_logsChatThinking)
                            {
                                <div class="logs-chat-empty">
                                    Ask the AI to analyze, summarize, or investigate patterns in the current log data.
                                </div>
                            }
                            @foreach (var msg in _logsChatHistory)
                            {
                                <div class="logs-chat-bubble logs-chat-bubble--@msg.Role">
                                    <span class="logs-chat-label">@(msg.Role == "user" ? "You" : "Logs Copilot")</span>
                                    <div class="logs-chat-body">@((MarkupString)FormatCbrChatMessage(msg.Content))</div>
                                </div>
                            }
                            @if (_logsChatThinking)
                            {
                                <div class="logs-chat-bubble logs-chat-bubble--assistant">
                                    <span class="logs-chat-label">Logs Copilot</span>
                                    <div class="logs-chat-body logs-chat-thinking">
                                        <span></span><span></span><span></span>
                                    </div>
                                </div>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_logsChatError))
                        {
                            <div class="logs-chat-error">&#9888; @_logsChatError</div>
                        }
                        <div class="logs-chat-input-row">
                            <input type="text"
                                   class="logs-chat-input"
                                   placeholder="Ask about these logs…"
                                   @bind="_logsChatInput"
                                   @bind:event="oninput"
                                   @onkeydown="HandleLogsChatKeyDown"
                                   disabled="@_logsChatThinking" />
                            <button class="logs-chat-send"
                                    @onclick="SendLogsChatAsync"
                                    disabled="@(string.IsNullOrWhiteSpace(_logsChatInput) || _logsChatThinking)"
                                    title="Send">
                                &#x27A4;
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
            </div>
        </div>
    </div>@* /viewer-main-area *@

    </div>@* /viewer-content-row *@
    }

    @* ── Studio chat panel (always-on left side) ── *@
    <StudioChatPanel IsVisible="true" XmlRoot="rootNode" EntityIndex="_entityIndex" OnDeleteShippers="HandleAiShipperDeletions" OnEditShippers="HandleAiShipperEdits" OnAddShipper="HandleAiShipperAdd" UsersJson="@_usersJson" UsersMetaJson="@_usersMetaJson" OnFindUsers="HandleAiFindUsers" OnDeleteUsers="HandleAiUserDeletions" OnEditUsers="HandleAiUserEdits" OnAddUser="HandleAiUserAdd" OnDeleteAdapterRegistrations="HandleAiAdapterRegistrationDeletions" OnEditAdapterRegistrations="HandleAiAdapterRegistrationEdits" OnDeleteClients="HandleAiClientDeletions" OnEditClients="HandleAiClientEdits" OnEditCbr="HandleAiCbrEditAsync" CbrsJson="@_cbrsJson" LogsJson="@_logsJson" OnFindLogs="HandleAiFindLogs" OnDeleteEntities="HandleAiEntityDeletions" OnEditEntities="HandleAiEntityEdits" OnNavigateToEntity="HandleAiNavigateToEntity" />

</div>

@* ── Import Shippers dialog ── *@
<ImportShippersDialog IsVisible="_showImportShippersDialog"
                      CanApply="true"
                      OnClose="() => _showImportShippersDialog = false"
                      OnShippersApplied="HandleShippersAppliedAsync"
                      OnAddToVarianceList="HandleShipperVariancesForPanel" />

@* ── Import Users dialog (from toolbar dropdown) ── *@
<ImportUsersDialog IsVisible="_showImportUsersFromToolbar"
                   CanApply="true"
                   OnClose="() => _showImportUsersFromToolbar = false" />

@* ── Add Shipper dialog ── *@
<AddShipperDialog IsVisible="_showAddShipperDialog"
                  Prefill="_addShipperPrefill"
                  OnClose="CloseAddShipperDialog"
                  OnShipperAdded="HandleNewShipperAdded" />

@* ── Compare Profiles dialog ── *@
<CompareProfilesDialog IsVisible="_showCompareProfilesDialog"
                       OnClose="() => _showCompareProfilesDialog = false"
                       OnGoToProfile="HandleGoToProfileAsync" />

@* ── Context menu (rendered outside the tree-body to avoid clipping) ── *@
<XmlContextMenu Node="_contextMenuNode"
                X="_menuX" Y="_menuY"
                IsVisible="_showContextMenu"
                CanPaste="_canPaste"
                OnClose="CloseContextMenu"
                OnAdd="OpenAddChildDialog"
                OnRemove="ExecuteRemove"
                OnCopy="ExecuteCopy"
                OnPaste="ExecutePaste" />

@* ── Add-child dialog ── *@
<XmlAddChildDialog ParentNode="_addChildTarget"
                   IsVisible="_showAddChildDialog"
                   OnAdd="ExecuteAddChild"
                   OnClose="CloseAddChildDialog" />

@* ── ShipExec connect dialog ── *@
<ConnectDialog IsVisible="_showConnectDialog"
               OnClose="() => _showConnectDialog = false"
               OnCompanyConnected="HandleCompanyConnected" />

@* ── Diff result dialog ── *@
<DiffResultDialog IsVisible="_showDiffDialog"
                  Result="_diffResult"
                  CanApply="true"
                  OnClose="() => _showDiffDialog = false" />

@* ── Import Variances dialog ── *@
@if (_showImportVariancesDialog)
{
    <div class="import-var-backdrop" @onclick="() => _showImportVariancesDialog = false">
        <div class="import-var-modal" @onclick:stopPropagation>
            <div class="import-var-header">
                <span class="import-var-title">&#x1F4E5; Import Variances</span>
                <button class="import-var-close" @onclick="() => _showImportVariancesDialog = false">&#x2715;</button>
            </div>
            <div class="import-var-body">
                <p class="import-var-desc">Paste a JSON array of variances below to import them into the variance panel.</p>
                <textarea class="import-var-textarea" spellcheck="false"
                          @bind="_importVariancesJson"
                          @bind:event="oninput"
                          placeholder='[{"PathDescription":"...", "Description":"...", "ChangeType":"Modified", "OriginalXML":"...", "NewXML":"..."}]'></textarea>
                @if (!string.IsNullOrEmpty(_importVariancesError))
                {
