    private bool CanPasteOnNode(XmlNodeViewModel node)
    {
        var clipboard = XmlViewerService.Clipboard;
        if (clipboard is null) return false;

        var schema = XmlSchemaService.GetChildTemplate(node.NodeName);
        if (schema is not null)
            return clipboard.NodeName.Equals(schema.ElementName, StringComparison.OrdinalIgnoreCase);

        return node.Children.Any(c => c.NodeName.Equals(clipboard.NodeName, StringComparison.OrdinalIgnoreCase));
    }

