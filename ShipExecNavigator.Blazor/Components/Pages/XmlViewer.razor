    private async Task NavigateToNode(Guid nodeId)
    {
        if (rootNode is null) return;
        var node = FindNode(rootNode, nodeId);
        if (node is null) return;

        var ancestor = node.Parent;
        while (ancestor is not null)
        {
            ancestor.IsExpanded = true;
            ancestor = ancestor.Parent;
        }

        _highlightedNodeId = nodeId;
        _version++;
        await InvokeAsync(StateHasChanged);

        try { await JSRuntime.InvokeVoidAsync("scrollToNode", $"node-{nodeId}"); } catch { }

        await Task.Delay(2000);
        _highlightedNodeId = null;
        await InvokeAsync(StateHasChanged);
    }

    private static XmlNodeViewModel? FindNode(XmlNodeViewModel root, Guid id)
    {
        if (root.Id == id) return root;
        foreach (var child in root.Children)
        {
            var found = FindNode(child, id);
            if (found is not null) return found;
        }
        return null;
    }

    private static string BuildNodePath(XmlNodeViewModel node)
    {
        var parts = new List<string>();
        var current = node;
        while (current is not null)
        {
            var idAttr = current.Attributes.FirstOrDefault(a => a.Name.Equals("id", StringComparison.OrdinalIgnoreCase))?.Value;
            var label = idAttr is not null ? $"{current.NodeName}[{idAttr}]" : current.NodeName;
            parts.Insert(0, label);
            current = current.Parent;
        }
        return parts.Count > 3
            ? "\u2026 \u203a " + string.Join(" \u203a ", parts.Skip(parts.Count - 3))
            : string.Join(" \u203a ", parts);
    }

    private async Task LoadHistoryAsync()
    {
        _historyError = null;
        _isLoadingHistory = true;
        try
        {
            var history = await ShipExecService.GetCompanyVarianceHistoryAsync();
            _varianceEntries.RemoveAll(e => e.IsHistorical);
            _varianceEntries.AddRange(history);
            _variancePanelVisible = true;
        }
        catch
        {
            // Database is unreachable — continue working normally without historical variances.
            _canLoadHistory = false;
        }
        finally
        {
            _isLoadingHistory = false;
            StateHasChanged();
        }
    }

    private void UndoVariance(Variance entry)
    {
        //System.Diagnostics/.Debugger.Break();
        if (rootNode is null) return;

        // Historical entries and JSON-payload-only entries (e.g., shipper imports)
        // don't have a NodeId anchor – use JSON-based entity lookup instead.
        if (entry.NodeId == Guid.Empty)
        {
            UndoJsonBasedVariance(entry);
            return;
        }

        switch (entry.ChangeType)
        {
            case "Modified":
            {
                var node = FindNode(rootNode, entry.NodeId);
                if (node is null)
                {
                    entry.IsUndone = true;
                    break;
                }
                _varianceEntries.Insert(0, CreateRevertEntry(entry));
                //System.Diagnostics.Debugger.Break();
                if (entry.UndoAttributeName is not null)
                {
                    var attr = node.Attributes.FirstOrDefault(a => a.Name == entry.UndoAttributeName);
                    if (attr is not null) attr.Value = attr.OriginalValue;
                    foreach (var e in _varianceEntries
                        .Where(e => e.NodeId == entry.NodeId &&
                                    e.UndoAttributeName == entry.UndoAttributeName &&
                                    e.ChangeType == "Modified")
                        .ToList())
                    {
                        e.IsUndone = true;
                    }
                }
                else
                {
                    var origTrimmed = node.OriginalNodeValue?.Trim();
                    node.NodeValue = string.IsNullOrEmpty(origTrimmed) ? null : origTrimmed;
                    foreach (var e in _varianceEntries
                        .Where(e => e.NodeId == entry.NodeId &&
                                    e.UndoAttributeName is null &&
                                    e.ChangeType == "Modified")
                        .ToList())
                    {
                        e.IsUndone = true;
                    }
                }
                break;
            }
            case "Added":
            {
                _varianceEntries.Insert(0, CreateRevertEntry(entry));
                //System.Diagnostics.Debugger.Break();
                var addedNode = FindNode(rootNode, entry.NodeId);
                if (addedNode?.Parent is not null)
                    addedNode.Parent.Children.Remove(addedNode);
                entry.IsUndone = true;
                break;
            }
            case "Removed":
            {
                if (entry.SnapshotNode is null) break;
                var parentId = entry.SnapshotParentId ?? entry.NodeId;
                var parent = FindNode(rootNode, parentId);
                if (parent is null) break;
                _varianceEntries.Insert(0, CreateRevertEntry(entry));
                //System.Diagnostics.Debugger.Break();
                var insertIdx = entry.SnapshotIndex >= 0
                    ? Math.Min(entry.SnapshotIndex, parent.Children.Count)
                    : parent.Children.Count;
                var snap = (XmlNodeViewModel)entry.SnapshotNode;
                snap.Parent = parent;
                parent.Children.Insert(insertIdx, snap);
                parent.IsExpanded = true;
                entry.IsUndone = true;
                break;
            }
        }

        XmlRefLookupService.Rebuild(rootNode!);
        MarkDirty();
        _version++;
    }

    // ── JSON-based undo (historical + import entries) ─────────────────────────

    private void UndoJsonBasedVariance(Variance entry)
    {
        if (rootNode is null) return;

        var inverseVariance = CreateRevertEntry(entry);
        //System.Diagnostics.Debugger.Break();

        try
        {
            switch (entry.ChangeType)
            {
                case "Modified":
                {
                    if (string.IsNullOrEmpty(entry.NewXML) || string.IsNullOrEmpty(entry.OriginalXML))
                    {
                        errorMessage = "Cannot undo: original entity data is not available for this variance.";
                        return;
                    }
                    if (entry.PathDescription.StartsWith("Shippers", StringComparison.OrdinalIgnoreCase) ||
                        entry.PathDescription.Equals("Shipper", StringComparison.OrdinalIgnoreCase))
                    {
                        var origShipper = System.Text.Json.JsonSerializer.Deserialize<PSI.Sox.Shipper>(entry.OriginalXML);
                        var newShipper  = System.Text.Json.JsonSerializer.Deserialize<PSI.Sox.Shipper>(entry.NewXML);
                        if (origShipper is null || newShipper is null)
                        {
                            errorMessage = "Cannot undo: shipper data could not be parsed.";
                            return;
                        }
                        var shipperNode = FindShipperNodeBySymbol(newShipper.Symbol ?? origShipper.Symbol);
                        if (shipperNode is null)
                        {
                            errorMessage = "Cannot undo: could not locate the shipper in the current XML tree.";
                            return;
                        }
                        ApplyShipperToShipperNode(shipperNode, origShipper);
                        break;
                    }
                    var newObj  = System.Text.Json.Nodes.JsonNode.Parse(entry.NewXML)?.AsObject();
                    var origObj = System.Text.Json.Nodes.JsonNode.Parse(entry.OriginalXML)?.AsObject();
                    if (newObj is null || origObj is null)
                    {
                        errorMessage = "Cannot undo: entity data could not be parsed.";
                        return;
                    }
                    var entityNode = FindEntityNodeByJson(rootNode, entry.PathDescription, newObj);
                    if (entityNode is null)
                    {
                        errorMessage = "Cannot undo: could not locate the entity in the current XML tree.";
                        return;
                    }
                    ApplyJsonObjectToNode(entityNode, origObj);
                    break;
                }
                case "Added":
                {
                    if (string.IsNullOrEmpty(entry.NewXML))
                    {
                        errorMessage = "Cannot undo: entity data is not available for this variance.";
                        return;
                    }
                    if (entry.PathDescription.StartsWith("Shippers", StringComparison.OrdinalIgnoreCase) ||
                        entry.PathDescription.Equals("Shipper", StringComparison.OrdinalIgnoreCase))
                    {
                        var newShipper = System.Text.Json.JsonSerializer.Deserialize<PSI.Sox.Shipper>(entry.NewXML);
                        if (newShipper is null)
                        {
                            errorMessage = "Cannot undo: shipper data could not be parsed.";
                            return;
                        }
                        var shipperNode = FindShipperNodeBySymbol(newShipper.Symbol);
                        if (shipperNode is null)
                        {
                            errorMessage = "Cannot undo: could not locate the shipper in the current XML tree.";
                            return;
                        }
                        XmlViewerService.RemoveNode(shipperNode);
                        break;
                    }
                    var newObj = System.Text.Json.Nodes.JsonNode.Parse(entry.NewXML)?.AsObject();
                    if (newObj is null)
                    {
                        errorMessage = "Cannot undo: entity data could not be parsed.";
                        return;
                    }
                    var entityNode = FindEntityNodeByJson(rootNode, entry.PathDescription, newObj);
                    if (entityNode is null)
                    {
                        errorMessage = "Cannot undo: could not locate the entity in the current XML tree.";
                        return;
                    }
                    XmlViewerService.RemoveNode(entityNode);
                    break;
                }
                default:
                    errorMessage = "Cannot undo this type of variance – the original XML snapshot is not available.";
                    return;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Undo failed: {ex.Message}";
            return;
        }

        entry.IsUndone = true;
        _varianceEntries.Insert(0, inverseVariance);
        XmlRefLookupService.Rebuild(rootNode!);
        MarkDirty();
        _version++;
    }

    private static Variance CreateRevertEntry(Variance source) =>
        new()
        {
            NodeId          = source.NodeId,
            PathDescription = source.PathDescription,
            Description     = $"Reverted: {source.Description}",
            ChangeType      = "Reverted",
            IsRevert        = true,
            // Swap original ↔ new so the inline diff shows what was restored
            OriginalXML    = source.NewXML,
            NewXML         = source.OriginalXML,
        };

    private static XmlNodeViewModel? FindEntityNodeByJson(
        XmlNodeViewModel root,
        string pathDescription,
        System.Text.Json.Nodes.JsonObject jsonObj)
    {
        // Build candidate node names from the path (e.g., "Shippers › UPS" -> ["Shippers","Shipper","UPS"])
        // Also add the singularized form of any plural token (strip trailing 's').
        var tokens = pathDescription
            .Split([' ', ':', '\u203a', '>'], StringSplitOptions.RemoveEmptyEntries)
            .SelectMany(t =>
            {
                var list = new List<string> { t };
                if (t.Length > 2 && t.EndsWith('s'))
                    list.Add(t[..^1]);
                return list;
            })
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        foreach (var token in tokens)
        {
            foreach (var node in EnumerateDescendants(root))
            {
                if (!node.NodeName.Equals(token, StringComparison.OrdinalIgnoreCase)) continue;
                if (NodeMatchesJsonObject(node, jsonObj)) return node;
            }
        }
        return null;
    }

    private static bool NodeMatchesJsonObject(
        XmlNodeViewModel node,
        System.Text.Json.Nodes.JsonObject jsonObj)
    {
        int matched = 0, totalChecked = 0;
        foreach (var (key, val) in jsonObj)
        {
            // Only compare scalar (leaf) properties
            if (val is null
                || val is System.Text.Json.Nodes.JsonObject
                || val is System.Text.Json.Nodes.JsonArray)
                continue;

            var childNode = node.Children.FirstOrDefault(c =>
                c.NodeName.Equals(key, StringComparison.OrdinalIgnoreCase));
            if (childNode is null) continue;

            totalChecked++;

            string? jsonVal;
            if (val is System.Text.Json.Nodes.JsonValue jv && jv.TryGetValue<bool>(out var boolVal))
                jsonVal = boolVal ? "true" : "false";
            else
                jsonVal = val.ToString();

            if (string.Equals(childNode.NodeValue?.Trim(), jsonVal?.Trim(), StringComparison.OrdinalIgnoreCase))
                matched++;
        }

        // Need at least 2 matching scalar fields, covering ≥ 2/3 of checked fields.
        int required = Math.Max(2, totalChecked * 2 / 3);
        return totalChecked >= 2 && matched >= required;
    }

    private void ApplyJsonObjectToNode(
        XmlNodeViewModel node,
        System.Text.Json.Nodes.JsonObject jsonObj)
    {
        foreach (var (key, val) in jsonObj)
        {
            if (val is null
                || val is System.Text.Json.Nodes.JsonObject
                || val is System.Text.Json.Nodes.JsonArray)
                continue;

            var childNode = node.Children.FirstOrDefault(c =>
                c.NodeName.Equals(key, StringComparison.OrdinalIgnoreCase));
            if (childNode is null) continue;

            string newValue;
            if (val is System.Text.Json.Nodes.JsonValue jv && jv.TryGetValue<bool>(out var boolVal))
                newValue = boolVal ? "true" : "false";
            else
                newValue = val.ToString();

            XmlViewerService.UpdateNodeValue(childNode, newValue);
        }
    }

    private static IEnumerable<XmlNodeViewModel> EnumerateDescendants(XmlNodeViewModel node)
    {
        yield return node;
        foreach (var child in node.Children)
            foreach (var desc in EnumerateDescendants(child))
                yield return desc;
    }
}

