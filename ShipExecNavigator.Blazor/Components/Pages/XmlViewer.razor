    private async Task DownloadSbrProjectAsync(SbrInfo sbr)
    {
        if (_sbrDecompilingIds.Contains(sbr.Id)) return;
        _sbrDecompilingIds.Add(sbr.Id);
        StateHasChanged();

        string? outputDir = null;
        string? zipPath   = null;
        try
        {
            var fileBase64 = await ShipExecService.GetServerBusinessRuleFileBase64Async(sbr.Name, sbr.Version);
            if (string.IsNullOrEmpty(fileBase64))
            {
                _sbrError = $"No file data available for '{sbr.Name}'.";
                return;
            }

            var dllBytes = Convert.FromBase64String(fileBase64);
            var tempDir  = Path.GetTempPath();
            var dllPath  = Path.Combine(tempDir, $"{sbr.Name}.dll");
            await File.WriteAllBytesAsync(dllPath, dllBytes);

            outputDir = Path.Combine(tempDir, $"sbr_project_{sbr.Id}_{Guid.NewGuid():N}");
            Directory.CreateDirectory(outputDir);

            await Task.Run(() =>
            {
                using var module = new ICSharpCode.Decompiler.Metadata.PEFile(dllPath);
                var targetFramework = ICSharpCode.Decompiler.Metadata.DotNetCorePathFinderExtensions
                    .DetectTargetFrameworkId(module);
                var resolver = new ICSharpCode.Decompiler.Metadata.UniversalAssemblyResolver(
                    dllPath, throwOnError: false, targetFramework);
                var decompiler = new ICSharpCode.Decompiler.CSharp.ProjectDecompiler.WholeProjectDecompiler(resolver);
                decompiler.DecompileProject(module, outputDir);
            });

            zipPath = Path.Combine(tempDir, $"{sbr.Name}_Project.zip");
            if (File.Exists(zipPath)) File.Delete(zipPath);
            System.IO.Compression.ZipFile.CreateFromDirectory(outputDir, zipPath);

            var zipBytes = await File.ReadAllBytesAsync(zipPath);
            var safeName = string.IsNullOrWhiteSpace(sbr.Name)
                ? "sbr_project"
                : sbr.Name.Replace(" ", "_");
            using var stream = new DotNetStreamReference(new MemoryStream(zipBytes));
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", $"{safeName}_Project.zip", stream);
        }
        catch (Exception ex)
        {
            _sbrError = $"Failed to decompile '{sbr.Name}': {ex.Message}";
        }
        finally
        {
            _sbrDecompilingIds.Remove(sbr.Id);
            try { if (outputDir is not null && Directory.Exists(outputDir)) Directory.Delete(outputDir, true); } catch { }
            try { if (zipPath is not null && File.Exists(zipPath)) File.Delete(zipPath); } catch { }
            StateHasChanged();
        }
    }

    /// <summary>Decompile an SBR and display its files in the viewer panel.</summary>
    private async Task ViewSbrProjectAsync(SbrInfo sbr)
    {
        if (_sbrViewingIds.Contains(sbr.Id)) return;
        _sbrViewingIds.Add(sbr.Id);

        _sbrViewerOpen    = true;
        _sbrViewerLoading = true;
        _sbrViewerError   = null;
        _sbrViewerSbr     = sbr;
        _sbrViewerFiles.Clear();
        _sbrViewerFilePaths.Clear();
        _sbrViewerSelectedFile    = null;
        _sbrViewerSelectedContent = null;
        StateHasChanged();

        string? outputDir = null;
        try
        {
            var fileBase64 = await ShipExecService.GetServerBusinessRuleFileBase64Async(sbr.Name, sbr.Version);
            if (string.IsNullOrEmpty(fileBase64))
            {
                _sbrViewerError = $"No file data available for '{sbr.Name}'.";
                return;
            }

            var dllBytes = Convert.FromBase64String(fileBase64);
            var tempDir  = Path.GetTempPath();
            var dllPath  = Path.Combine(tempDir, $"{sbr.Name}.dll");
            await File.WriteAllBytesAsync(dllPath, dllBytes);

            outputDir = Path.Combine(tempDir, $"sbr_view_{sbr.Id}_{Guid.NewGuid():N}");
            Directory.CreateDirectory(outputDir);

            await Task.Run(() =>
            {
                using var module = new ICSharpCode.Decompiler.Metadata.PEFile(dllPath);
                var targetFramework = ICSharpCode.Decompiler.Metadata.DotNetCorePathFinderExtensions
                    .DetectTargetFrameworkId(module);
                var resolver = new ICSharpCode.Decompiler.Metadata.UniversalAssemblyResolver(
                    dllPath, throwOnError: false, targetFramework);
                var decompiler = new ICSharpCode.Decompiler.CSharp.ProjectDecompiler.WholeProjectDecompiler(resolver);
                decompiler.DecompileProject(module, outputDir);
            });

            // Read all decompiled files into memory
            var baseUri = new Uri(outputDir + Path.DirectorySeparatorChar);
            foreach (var fullPath in Directory.EnumerateFiles(outputDir, "*", SearchOption.AllDirectories))
            {
                var relativePath = Uri.UnescapeDataString(baseUri.MakeRelativeUri(new Uri(fullPath)).ToString())
                    .Replace('/', Path.DirectorySeparatorChar);
                var content = await File.ReadAllTextAsync(fullPath);
                _sbrViewerFiles[relativePath] = content;
            }

            // Sort: .cs files first, then by name
            _sbrViewerFilePaths = [.. _sbrViewerFiles.Keys
                .OrderByDescending(f => Path.GetExtension(f).Equals(".cs", StringComparison.OrdinalIgnoreCase))
                .ThenBy(f => f, StringComparer.OrdinalIgnoreCase)];

            // Auto-select the first .cs file (or the first file if none)
            var firstCs = _sbrViewerFilePaths.FirstOrDefault(f =>
                Path.GetExtension(f).Equals(".cs", StringComparison.OrdinalIgnoreCase));
            var autoSelect = firstCs ?? _sbrViewerFilePaths.FirstOrDefault();
            if (autoSelect is not null)
            {
                _sbrViewerSelectedFile    = autoSelect;
                _sbrViewerSelectedContent = _sbrViewerFiles[autoSelect];
            }
        }
        catch (Exception ex)
        {
            _sbrViewerError = $"Failed to decompile '{sbr.Name}': {ex.Message}";
        }
        finally
        {
            _sbrViewerLoading = false;
            _sbrViewingIds.Remove(sbr.Id);
            try { if (outputDir is not null && Directory.Exists(outputDir)) Directory.Delete(outputDir, true); } catch { }
            StateHasChanged();

            // Render the auto-selected file after the UI has updated
            if (_sbrViewerSelectedFile is not null)
                await RenderSbrCodeAsync();
        }
    }

    /// <summary>Select a file in the SBR viewer and render its content.</summary>
    private async Task SelectSbrFileAsync(string filePath)
    {
        if (!_sbrViewerFiles.TryGetValue(filePath, out var content)) return;
