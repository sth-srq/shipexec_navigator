    {
        _showConnectDialog = false;
        _canLoadHistory = true;
        loadedFileName = company.Name;
        isLoading = true;
        errorMessage = null;
        rootNode = null;
        _isDirty = false;
        _activeMainTab = "company";
        _usersJson = null;
        _usersMetaJson = null;
        _foundUserIds = null;
        _pendingUserDeletes = null;
        _pendingUserEdits = null;
        _addUserPrefill = null;
        _sbrs        = [];
        _sbrError    = null;
        _sbrLoaded   = false;
        _sbrLoading  = false;
        _cbrs        = [];
        _cbrError    = null;
        _cbrLoaded   = false;
        _cbrLoading  = false;
        _selectedCbr        = null;
        _cbrEditedScript   = string.Empty;
        _cbrOriginalScript = string.Empty;
        _cbrAnalysisResult  = null;
        _cbrAnalysisError   = null;
        _cbrAnalysisVisible = false;
        _cbrAnalyzing       = false;
        try
        {
            rootNode = await ShipExecService.BuildCompanySkeletonAsync();
            XmlViewerService.ExpandToDepth(rootNode, 1);
            nodeCount = CountNodes(rootNode);
            activeDepth = 1;
            _version++;
