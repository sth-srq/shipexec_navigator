    private void ExecuteRemove(XmlNodeViewModel node)
    {
        CloseContextMenu();
        var removePath = BuildNodePath(node);
        var nodeName = node.NodeName;
        var parent = node.Parent;
        var parentId = parent?.Id ?? Guid.Empty;
        var snapshotIndex = parent is not null ? parent.Children.IndexOf(node) : -1;
        XmlViewerService.RemoveNode(node);
        XmlRefLookupService.Rebuild(rootNode!);
        _varianceEntries.Insert(0, new Variance
        {
            NodeId = parentId,
            PathDescription = removePath,
            Description = $"Removed <{nodeName}>",
            ChangeType = "Removed",
            SnapshotNode = node,
            SnapshotParentId = parentId,
            SnapshotIndex = snapshotIndex
        });
        MarkDirty();
        _version++;
    }

    private void ExecuteCopy(XmlNodeViewModel node)
    {
