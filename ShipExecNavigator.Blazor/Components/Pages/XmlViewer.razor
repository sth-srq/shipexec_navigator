    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Match code-editor themes to the site's current light/dark setting
            var siteTheme = await JSRuntime.InvokeAsync<string?>("eval", "localStorage.getItem('theme')");
            var siteIsDark = siteTheme == "dark";
            _sbrViewerDark = siteIsDark;
            _cbrDark = siteIsDark;

            _showConnectDialog = true;
            StateHasChanged();
