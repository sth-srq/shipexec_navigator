    private void AddVarianceEntry(Variance entry)
    {
        // Task 11: If a "Modified" variance already exists for the same NodeId,
        // merge descriptions and update the new value rather than adding a duplicate.
        if (entry.ChangeType == "Modified" && entry.NodeId != Guid.Empty)
        {
            var existing = _varianceEntries.FirstOrDefault(e =>
                e.NodeId == entry.NodeId &&
                e.ChangeType == "Modified" &&
                !e.IsUndone &&
                !e.IsHistorical &&
                e.UndoAttributeName == entry.UndoAttributeName);
            if (existing is not null)
            {
                // Keep the original OriginalXML but update the new state
                existing.NewXML      = entry.NewXML;
                existing.Description = entry.Description;
                existing.Timestamp   = DateTime.Now;
                // Move to top of list for visibility
                _varianceEntries.Remove(existing);
                _varianceEntries.Insert(0, existing);
                InvokeAsync(StateHasChanged);
                return;
            }
        }

        _varianceEntries.Insert(0, entry);
        InvokeAsync(StateHasChanged);
    }

    private async Task ClearAndRevertAsync()
    {
        // Preserve historical entries
        var historical = _varianceEntries.Where(e => e.IsHistorical).ToList();
        _varianceEntries.Clear();
        _varianceEntries.AddRange(historical);
        _userVarianceIds.Clear();

        // Rebuild the tree from the live server
        try
        {
            isLoading = true;
            errorMessage = null;
            rootNode = await ShipExecService.BuildCompanySkeletonAsync();
            XmlViewerService.ExpandToDepth(rootNode, 1);
            nodeCount = CountNodes(rootNode);
            _isDirty = false;
            _version++;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to reload company: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task NavigateToNode(Guid nodeId)
    {
        if (rootNode is null) return;
        var node = FindNode(rootNode, nodeId);
        if (node is null) return;

        var ancestor = node.Parent;
        while (ancestor is not null)
        {
            ancestor.IsExpanded = true;
            ancestor = ancestor.Parent;
        }

        _highlightedNodeId = nodeId;
        _version++;
        await InvokeAsync(StateHasChanged);

        try { await JSRuntime.InvokeVoidAsync("scrollToNode", $"node-{nodeId}"); } catch { }

        await Task.Delay(2000);
        _highlightedNodeId = null;
        await InvokeAsync(StateHasChanged);
    }

    private static XmlNodeViewModel? FindNode(XmlNodeViewModel root, Guid id)
    {
        if (root.Id == id) return root;
        foreach (var child in root.Children)
        {
            var found = FindNode(child, id);
            if (found is not null) return found;
        }
        return null;
    }

    /// <summary>
    /// Handles a clickable node-link from the AI chat panel.
    /// Lazy-loads the category if needed, then expands and highlights
    /// the target node (specific entity or category root).
    /// </summary>
    private async Task HandleAiNavigateToEntity(EntityNodeLink link)
    {
        if (rootNode is null) return;

        // Switch to the appropriate tab so the tree is visible
        if (string.Equals(link.Category, "Users", StringComparison.OrdinalIgnoreCase))
        {
            _activeMainTab = "company";
            _treeFilterCategory = "Users";
        }
        else
        {
            _activeMainTab = "company";
            _treeFilterCategory = null;
        }

        var categoryNode = rootNode.Children.FirstOrDefault(c =>
            string.Equals(c.NodeName, link.Category, StringComparison.OrdinalIgnoreCase));
        if (categoryNode is null) return;

        // Lazy-load the category if not yet populated
        if (categoryNode.IsLazyLoadable && !categoryNode.IsLazyLoaded)
            await HandleLazyLoadAsync(categoryNode);

        categoryNode.IsExpanded = true;

        // If a specific entity name is given, find and highlight that child
        if (!string.IsNullOrEmpty(link.EntityName))
        {
            var entityNode = categoryNode.Children.FirstOrDefault(c =>
                c.Children.Any(gc =>
                    (string.Equals(gc.NodeName, "Name", StringComparison.OrdinalIgnoreCase)
                     || string.Equals(gc.NodeName, "Symbol", StringComparison.OrdinalIgnoreCase)
                     || string.Equals(gc.NodeName, "UserName", StringComparison.OrdinalIgnoreCase)
                     || string.Equals(gc.NodeName, "Email", StringComparison.OrdinalIgnoreCase))
                    && string.Equals(gc.NodeValue, link.EntityName, StringComparison.OrdinalIgnoreCase)));

            if (entityNode is not null)
            {
                entityNode.IsExpanded = true;
                _highlightedNodeId = entityNode.Id;
                _version++;
                await InvokeAsync(StateHasChanged);
                try { await JSRuntime.InvokeVoidAsync("scrollToNode", $"node-{entityNode.Id}"); } catch { }
                await Task.Delay(2000);
                _highlightedNodeId = null;
                await InvokeAsync(StateHasChanged);
                return;
            }
        }

        // Otherwise highlight the category root
        _highlightedNodeId = categoryNode.Id;
        _version++;
        await InvokeAsync(StateHasChanged);
        try { await JSRuntime.InvokeVoidAsync("scrollToNode", $"node-{categoryNode.Id}"); } catch { }
        await Task.Delay(2000);
        _highlightedNodeId = null;
        await InvokeAsync(StateHasChanged);
    }

    private static string BuildNodePath(XmlNodeViewModel node)
    {
        var parts = new List<string>();
        var current = node;
        while (current is not null)
        {
            var idAttr = current.Attributes.FirstOrDefault(a => a.Name.Equals("id", StringComparison.OrdinalIgnoreCase))?.Value;
            var label = idAttr is not null ? $"{current.NodeName}[{idAttr}]" : current.NodeName;
            parts.Insert(0, label);
            current = current.Parent;
        }
        return parts.Count > 3
            ? "\u2026 \u203a " + string.Join(" \u203a ", parts.Skip(parts.Count - 3))
            : string.Join(" \u203a ", parts);
    }

    private async Task LoadHistoryAsync()
    {
        _historyError = null;
        _isLoadingHistory = true;
        try
        {
            var history = await ShipExecService.GetCompanyVarianceHistoryAsync();
            _varianceEntries.RemoveAll(e => e.IsHistorical);
            _varianceEntries.AddRange(history);
            _variancePanelVisible = true; // User explicitly requested history — keep open
        }
        catch
        {
            // Database is unreachable — continue working normally without historical variances.
            _canLoadHistory = false;
        }
        finally
        {
            _isLoadingHistory = false;
            StateHasChanged();
        }
    }

    private void UndoVariance(Variance entry)
    {
        if (rootNode is null) return;

        // #5: Undoing an unapplied, non-historical variance removes it from the list
        var removeInsteadOfRevert = !entry.IsApplied && !entry.IsHistorical;

        // Historical entries and JSON-payload-only entries (e.g., shipper imports)
        // don't have a NodeId anchor – use JSON-based entity lookup instead.
        if (entry.NodeId == Guid.Empty)
        {
            UndoJsonBasedVariance(entry, removeInsteadOfRevert);
            return;
        }

        switch (entry.ChangeType)
        {
            case "Modified":
            {
                var node = FindNode(rootNode, entry.NodeId);
                if (node is null)
                {
                    entry.IsUndone = true;
                    break;
                }
                if (!removeInsteadOfRevert)
                    _varianceEntries.Insert(0, CreateRevertEntry(entry));
                if (entry.UndoAttributeName is not null)
                {
                    var attr = node.Attributes.FirstOrDefault(a => a.Name == entry.UndoAttributeName);
                    if (attr is not null) attr.Value = attr.OriginalValue;
                    foreach (var e in _varianceEntries
                        .Where(e => e.NodeId == entry.NodeId &&
                                    e.UndoAttributeName == entry.UndoAttributeName &&
                                    e.ChangeType == "Modified")
                        .ToList())
                    {
                        e.IsUndone = true;
                    }
                }
                else
                {
                    var origTrimmed = node.OriginalNodeValue?.Trim();
                    node.NodeValue = string.IsNullOrEmpty(origTrimmed) ? null : origTrimmed;
                    foreach (var e in _varianceEntries
                        .Where(e => e.NodeId == entry.NodeId &&
                                    e.UndoAttributeName is null &&
                                    e.ChangeType == "Modified")
                        .ToList())
                    {
                        e.IsUndone = true;
                    }
                }
                if (removeInsteadOfRevert)
                    _varianceEntries.Remove(entry);
                break;
            }
            case "Added":
            {
                if (!removeInsteadOfRevert)
                    _varianceEntries.Insert(0, CreateRevertEntry(entry));
                var addedNode = FindNode(rootNode, entry.NodeId);
                if (addedNode?.Parent is not null)
                    addedNode.Parent.Children.Remove(addedNode);
                if (removeInsteadOfRevert)
                    _varianceEntries.Remove(entry);
                else
                    entry.IsUndone = true;
                break;
            }
            case "Removed":
            {
                if (entry.SnapshotNode is null) break;
                var parentId = entry.SnapshotParentId ?? entry.NodeId;
                var parent = FindNode(rootNode, parentId);
                if (parent is null) break;
                if (!removeInsteadOfRevert)
                    _varianceEntries.Insert(0, CreateRevertEntry(entry));
                var insertIdx = entry.SnapshotIndex >= 0
                    ? Math.Min(entry.SnapshotIndex, parent.Children.Count)
                    : parent.Children.Count;
                var snap = (XmlNodeViewModel)entry.SnapshotNode;
                snap.Parent = parent;
                parent.Children.Insert(insertIdx, snap);
                parent.IsExpanded = true;
                if (removeInsteadOfRevert)
                    _varianceEntries.Remove(entry);
                else
                    entry.IsUndone = true;
                break;
            }
        }

        XmlRefLookupService.Rebuild(rootNode!);
        MarkDirty();
        _version++;
    }

    // ── JSON-based undo (historical + import entries) ─────────────────────────

    private void UndoJsonBasedVariance(Variance entry, bool removeInsteadOfRevert = false)
    {
        if (rootNode is null) return;

        var inverseVariance = CreateRevertEntry(entry);

        try
        {
            switch (entry.ChangeType)
            {
                case "Modified":
                {
                    if (string.IsNullOrEmpty(entry.NewXML) || string.IsNullOrEmpty(entry.OriginalXML))
                    {
                        errorMessage = "Cannot undo: original entity data is not available for this variance.";
                        return;
                    }
                    if (entry.PathDescription.StartsWith("Shippers", StringComparison.OrdinalIgnoreCase) ||
                        entry.PathDescription.Equals("Shipper", StringComparison.OrdinalIgnoreCase))
                    {
                        var origShipper = System.Text.Json.JsonSerializer.Deserialize<PSI.Sox.Shipper>(entry.OriginalXML);
                        var newShipper  = System.Text.Json.JsonSerializer.Deserialize<PSI.Sox.Shipper>(entry.NewXML);
                        if (origShipper is null || newShipper is null)
                        {
                            errorMessage = "Cannot undo: shipper data could not be parsed.";
                            return;
                        }
                        var shipperNode = FindShipperNodeBySymbol(newShipper.Symbol ?? origShipper.Symbol);
                        if (shipperNode is null)
                        {
                            errorMessage = "Cannot undo: could not locate the shipper in the current XML tree.";
                            return;
                        }
                        ApplyShipperToShipperNode(shipperNode, origShipper);
                        break;
                    }
                    var newObj  = System.Text.Json.Nodes.JsonNode.Parse(entry.NewXML)?.AsObject();
                    var origObj = System.Text.Json.Nodes.JsonNode.Parse(entry.OriginalXML)?.AsObject();
                    if (newObj is null || origObj is null)
                    {
                        errorMessage = "Cannot undo: entity data could not be parsed.";
                        return;
                    }
                    var entityNode = FindEntityNodeByJson(rootNode, entry.PathDescription, newObj);
                    if (entityNode is null)
                    {
                        errorMessage = "Cannot undo: could not locate the entity in the current XML tree.";
                        return;
                    }
                    ApplyJsonObjectToNode(entityNode, origObj);
                    break;
                }
                case "Added":
                {
                    if (string.IsNullOrEmpty(entry.NewXML))
                    {
                        errorMessage = "Cannot undo: entity data is not available for this variance.";
                        return;
                    }
                    if (entry.PathDescription.StartsWith("Shippers", StringComparison.OrdinalIgnoreCase) ||
                        entry.PathDescription.Equals("Shipper", StringComparison.OrdinalIgnoreCase))
                    {
                        var newShipper = System.Text.Json.JsonSerializer.Deserialize<PSI.Sox.Shipper>(entry.NewXML);
                        if (newShipper is null)
                        {
                            errorMessage = "Cannot undo: shipper data could not be parsed.";
                            return;
                        }
                        var shipperNode = FindShipperNodeBySymbol(newShipper.Symbol);
                        if (shipperNode is null)
                        {
                            errorMessage = "Cannot undo: could not locate the shipper in the current XML tree.";
                            return;
                        }
                        XmlViewerService.RemoveNode(shipperNode);
                        // Record a Removed variance so the deletion is tracked
                        inverseVariance.ChangeType = "Removed";
                        break;
                    }
                    var newObj = System.Text.Json.Nodes.JsonNode.Parse(entry.NewXML)?.AsObject();
                    if (newObj is null)
                    {
                        errorMessage = "Cannot undo: entity data could not be parsed.";
                        return;
                    }
                    var entityNode = FindEntityNodeByJson(rootNode, entry.PathDescription, newObj);
                    if (entityNode is null)
                    {
                        errorMessage = "Cannot undo: could not locate the entity in the current XML tree.";
                        return;
                    }
                    XmlViewerService.RemoveNode(entityNode);
                    // Record a Removed variance so the deletion is tracked
                    inverseVariance.ChangeType = "Removed";
                    break;
                }
                case "Removed":
                {
                    // Re-add the deleted entity to the tree from the original snapshot
                    var sourceJson = !string.IsNullOrEmpty(entry.OriginalXML) ? entry.OriginalXML : entry.NewXML;
                    if (string.IsNullOrEmpty(sourceJson))
                    {
                        errorMessage = "Cannot undo: original entity data is not available for this variance.";
                        return;
                    }
                    if (entry.PathDescription.StartsWith("Shippers", StringComparison.OrdinalIgnoreCase) ||
                        entry.PathDescription.Equals("Shipper", StringComparison.OrdinalIgnoreCase))
                    {
                        var origShipper = System.Text.Json.JsonSerializer.Deserialize<PSI.Sox.Shipper>(sourceJson);
                        if (origShipper is null)
                        {
                            errorMessage = "Cannot undo: shipper data could not be parsed.";
                            return;
                        }
                        var shippersNode = rootNode.Children.FirstOrDefault(c =>
                            c.NodeName.Equals("Shippers", StringComparison.OrdinalIgnoreCase));
                        if (shippersNode is null)
                        {
                            errorMessage = "Cannot undo: Shippers category not found in the XML tree.";
                            return;
                        }
                        XmlViewerService.AddChild(shippersNode, "Shipper",
                            Enumerable.Empty<(string, string)>(), null,
                            Enumerable.Empty<(string, string)>());
                        var addedShipper = shippersNode.Children.Last();
                        ApplyShipperToShipperNode(addedShipper, origShipper);
                        // Record an Added variance so the re-addition is tracked
                        inverseVariance.ChangeType = "Added";
                        break;
                    }
                    var origObj = System.Text.Json.Nodes.JsonNode.Parse(sourceJson)?.AsObject();
                    if (origObj is null)
                    {
                        errorMessage = "Cannot undo: entity data could not be parsed.";
                        return;
                    }
                    // Determine the parent category from the path description
                    var categoryToken = entry.PathDescription
                        .Split([' ', ':', '\u203a', '>'], StringSplitOptions.RemoveEmptyEntries)
                        .FirstOrDefault();
                    if (categoryToken is null)
                    {
                        errorMessage = "Cannot undo: unable to determine entity category from path.";
                        return;
                    }
                    var parentCategory = rootNode.Children.FirstOrDefault(c =>
                        c.NodeName.Equals(categoryToken, StringComparison.OrdinalIgnoreCase));
                    if (parentCategory is null)
                    {
                        // Try singularized name
                        var singular = categoryToken.Length > 2 && categoryToken.EndsWith('s')
                            ? categoryToken[..^1] : categoryToken;
                        parentCategory = rootNode.Children.FirstOrDefault(c =>
                            c.NodeName.Equals(singular, StringComparison.OrdinalIgnoreCase));
                    }
                    if (parentCategory is null)
                    {
                        errorMessage = $"Cannot undo: could not find '{categoryToken}' category in the XML tree.";
                        return;
                    }
                    // Determine child element name (singularize the category name)
                    var childElementName = parentCategory.NodeName.EndsWith('s')
                        ? parentCategory.NodeName[..^1]
                        : parentCategory.NodeName;
                    XmlViewerService.AddChild(parentCategory, childElementName,
                        Enumerable.Empty<(string, string)>(), null,
                        Enumerable.Empty<(string, string)>());
                    var restoredNode = parentCategory.Children.Last();
                    ApplyJsonObjectToNode(restoredNode, origObj);
                    // Record an Added variance so the re-addition is tracked
                    inverseVariance.ChangeType = "Added";
                    break;
                }
                default:
                    errorMessage = "Cannot undo this type of variance – the original XML snapshot is not available.";
                    return;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Undo failed: {ex.Message}";
            return;
        }

        if (removeInsteadOfRevert)
        {
            _varianceEntries.Remove(entry);
        }
        else
        {
            entry.IsUndone = true;
            _varianceEntries.Insert(0, inverseVariance);
        }
        XmlRefLookupService.Rebuild(rootNode!);
        MarkDirty();
        _version++;
    }

    private static Variance CreateRevertEntry(Variance source) =>
        new()
        {
            NodeId          = source.NodeId,
            PathDescription = source.PathDescription,
            Description     = $"Reverted: {source.Description}",
            ChangeType      = "Reverted",
            IsRevert        = true,
            // Swap original ↔ new so the inline diff shows what was restored
            OriginalXML    = source.NewXML,
            NewXML         = source.OriginalXML,
        };

    private static XmlNodeViewModel? FindEntityNodeByJson(
        XmlNodeViewModel root,
        string pathDescription,
        System.Text.Json.Nodes.JsonObject jsonObj)
    {
        // Build candidate node names from the path (e.g., "Shippers › UPS" -> ["Shippers","Shipper","UPS"])
        // Also add the singularized form of any plural token (strip trailing 's').
        var tokens = pathDescription
            .Split([' ', ':', '\u203a', '>'], StringSplitOptions.RemoveEmptyEntries)
            .SelectMany(t =>
            {
                var list = new List<string> { t };
                if (t.Length > 2 && t.EndsWith('s'))
                    list.Add(t[..^1]);
                return list;
            })
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        // First pass: try matching against nodes whose names match path tokens
        foreach (var token in tokens)
        {
            foreach (var node in EnumerateDescendants(root))
            {
                if (!node.NodeName.Equals(token, StringComparison.OrdinalIgnoreCase)) continue;
                if (NodeMatchesJsonObject(node, jsonObj)) return node;
            }
        }

        // Second pass (Task 10a): if path-based lookup failed, try to find
        // entities by their identity fields (Name, Symbol, UserName, Email, Id)
        string[] identityFields = ["Name", "Symbol", "UserName", "Email", "Id"];
        foreach (var idField in identityFields)
        {
            if (jsonObj.TryGetPropertyValue(idField, out var idVal) && idVal is not null)
            {
                var idStr = idVal.ToString();
                if (string.IsNullOrWhiteSpace(idStr)) continue;
                foreach (var node in EnumerateDescendants(root))
                {
                    if (node.Children.Count == 0) continue;
                    var fieldChild = node.Children.FirstOrDefault(c =>
                        c.NodeName.Equals(idField, StringComparison.OrdinalIgnoreCase));
                    if (fieldChild is null) continue;
                    if (!string.Equals(fieldChild.NodeValue?.Trim(), idStr.Trim(), StringComparison.OrdinalIgnoreCase)) continue;
                    if (NodeMatchesJsonObject(node, jsonObj)) return node;
                }
            }
        }

        return null;
    }

    private static bool NodeMatchesJsonObject(
        XmlNodeViewModel node,
        System.Text.Json.Nodes.JsonObject jsonObj)
    {
        int matched = 0, totalChecked = 0;
        foreach (var (key, val) in jsonObj)
        {
            // Only compare scalar (leaf) properties
            if (val is null
                || val is System.Text.Json.Nodes.JsonObject
                || val is System.Text.Json.Nodes.JsonArray)
                continue;

            var childNode = node.Children.FirstOrDefault(c =>
                c.NodeName.Equals(key, StringComparison.OrdinalIgnoreCase));
            if (childNode is null) continue;

            totalChecked++;

            string? jsonVal;
            if (val is System.Text.Json.Nodes.JsonValue jv && jv.TryGetValue<bool>(out var boolVal))
                jsonVal = boolVal ? "true" : "false";
            else
                jsonVal = val.ToString();

            if (string.Equals(childNode.NodeValue?.Trim(), jsonVal?.Trim(), StringComparison.OrdinalIgnoreCase))
                matched++;
        }

        // Need at least 2 matching scalar fields, covering ≥ 2/3 of checked fields.
        int required = Math.Max(2, totalChecked * 2 / 3);
        return totalChecked >= 2 && matched >= required;
    }

    private void ApplyJsonObjectToNode(
        XmlNodeViewModel node,
        System.Text.Json.Nodes.JsonObject jsonObj)
    {
        foreach (var (key, val) in jsonObj)
        {
            if (val is null
                || val is System.Text.Json.Nodes.JsonObject
                || val is System.Text.Json.Nodes.JsonArray)
                continue;

            var childNode = node.Children.FirstOrDefault(c =>
                c.NodeName.Equals(key, StringComparison.OrdinalIgnoreCase));

            string newValue;
            if (val is System.Text.Json.Nodes.JsonValue jv && jv.TryGetValue<bool>(out var boolVal))
                newValue = boolVal ? "true" : "false";
            else
                newValue = val.ToString();

            if (childNode is null)
            {
                // Create the child if it doesn't exist yet (e.g., restoring a removed entity)
                if (!string.IsNullOrWhiteSpace(newValue))
                {
                    XmlViewerService.AddChild(node, key,
                        Enumerable.Empty<(string, string)>(), newValue,
                        Enumerable.Empty<(string, string)>());
                }
                continue;
            }

            XmlViewerService.UpdateNodeValue(childNode, newValue);
            // Reset the original value to match the restored value so the
            // field is no longer marked dirty after undo (Task 10d)
            childNode.OriginalNodeValue = newValue;
            childNode.IsModified = false;
        }
    }

    private static IEnumerable<XmlNodeViewModel> EnumerateDescendants(XmlNodeViewModel node)
    {
        yield return node;
        foreach (var child in node.Children)
            foreach (var desc in EnumerateDescendants(child))
                yield return desc;
    }
}

