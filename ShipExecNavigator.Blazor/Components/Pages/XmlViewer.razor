    // ── Lazy-load helper for AI handlers ────────────────────────────────────────

    /// <summary>
    /// Ensures a category node has its children loaded before AI handlers try to
    /// find entities inside it.  Without this, lazy-loadable categories that the
    /// user hasn't expanded in the tree have zero children, causing all
    /// FindEntityNode lookups to silently fail.
    /// </summary>
    private async Task EnsureCategoryLoadedAsync(XmlNodeViewModel categoryNode)
    {
        if (categoryNode.IsLazyLoadable && !categoryNode.IsLazyLoaded)
            await HandleLazyLoadAsync(categoryNode);
    }

    // ── Generic entity field helper ───────────────────────────────────────────

    private void UpdateEntityFieldInTree(XmlNodeViewModel entityNode, string fieldName, string? value)
    {
        var fieldNode = entityNode.Children.FirstOrDefault(c =>
            c.NodeName.Equals(fieldName, StringComparison.OrdinalIgnoreCase));
        var trimmed = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
        if (fieldNode is null)
        {
            if (trimmed is null) return;
            XmlViewerService.AddChild(entityNode, fieldName,
                Enumerable.Empty<(string, string)>(), trimmed,
                Enumerable.Empty<(string, string)>());
            return;
        }
        if (string.Equals(fieldNode.NodeValue, trimmed, StringComparison.Ordinal)) return;
        XmlViewerService.UpdateNodeValue(fieldNode, value ?? string.Empty);
        if (string.Equals(trimmed, fieldNode.OriginalNodeValue?.Trim(), StringComparison.Ordinal))
            fieldNode.IsModified = false;
    }

    private static XmlNodeViewModel? FindEntityNode(
        XmlNodeViewModel parentNode, string childElementName,
        string? idValue, string? nameValue)
    {
        XmlNodeViewModel? node = null;
        if (!string.IsNullOrEmpty(nameValue))
        {
            node = parentNode.Children.FirstOrDefault(c =>
                c.NodeName.Equals(childElementName, StringComparison.OrdinalIgnoreCase) &&
                c.Children.Any(gc =>
                    gc.NodeName.Equals("Name", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(gc.NodeValue, nameValue, StringComparison.OrdinalIgnoreCase)));
        }
        if (node is null && !string.IsNullOrEmpty(idValue))
        {
            node = parentNode.Children.FirstOrDefault(c =>
                c.NodeName.Equals(childElementName, StringComparison.OrdinalIgnoreCase) &&
                c.Children.Any(gc =>
                    gc.NodeName.Equals("Id", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(gc.NodeValue, idValue, StringComparison.OrdinalIgnoreCase)));
        }
        return node;
    }

