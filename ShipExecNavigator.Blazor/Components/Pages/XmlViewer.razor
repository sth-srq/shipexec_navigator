    /// <summary>Write decompiled sources to a temp dir, run dotnet build, and capture output.</summary>
    private async Task TestBuildSbrAsync()
    {
        if (_sbrBuildRunning || _sbrViewerFiles.Count == 0) return;
        _sbrBuildRunning = true;
        _sbrBuildOutput = null;
        _sbrBuildSucceeded = false;
        StateHasChanged();

        string? buildDir = null;
        try
        {
            buildDir = Path.Combine(Path.GetTempPath(), $"sbr_build_{Guid.NewGuid():N}");
            Directory.CreateDirectory(buildDir);

            // Write all decompiled files to disk
            foreach (var (relPath, content) in _sbrViewerFiles)
            {
                var fullPath = Path.Combine(buildDir, relPath);
                var dir = Path.GetDirectoryName(fullPath);
                if (dir is not null) Directory.CreateDirectory(dir);
                await File.WriteAllTextAsync(fullPath, content);
            }

            // Run dotnet build and capture output
            var psi = new System.Diagnostics.ProcessStartInfo("dotnet", "build --nologo --no-restore")
            {
                WorkingDirectory = buildDir,
                RedirectStandardOutput = true,
                RedirectStandardError = true,
                UseShellExecute = false,
                CreateNoWindow = true
            };

            using var proc = System.Diagnostics.Process.Start(psi);
            if (proc is null)
            {
                _sbrBuildOutput = "Failed to start dotnet build process.";
                return;
            }

            var stdout = await proc.StandardOutput.ReadToEndAsync();
            var stderr = await proc.StandardError.ReadToEndAsync();
            await proc.WaitForExitAsync();

            var result = new System.Text.StringBuilder();
            if (!string.IsNullOrWhiteSpace(stdout)) result.AppendLine(stdout.TrimEnd());
            if (!string.IsNullOrWhiteSpace(stderr)) result.AppendLine(stderr.TrimEnd());
            result.AppendLine();
            _sbrBuildSucceeded = proc.ExitCode == 0;
            result.AppendLine(_sbrBuildSucceeded ? "✅ Build succeeded." : "❌ Build failed.");

            _sbrBuildOutput = result.ToString();
        }
        catch (Exception ex)
        {
            _sbrBuildOutput = $"Build error: {ex.Message}";
        }
        finally
        {
            _sbrBuildRunning = false;
            try { if (buildDir is not null && Directory.Exists(buildDir)) Directory.Delete(buildDir, true); } catch { }
            StateHasChanged();
        }
    }

    private async Task SearchLogsAsync()
    {
        _logsSearching = true;
        _logsError = null;
        _logsSearched = false;
        _foundLogIds = null;
        try
        {
            var endOfDay = _logEnd.Date.AddHours(23).AddMinutes(59).AddSeconds(59);
            var appTask = ShipExecService.GetApplicationLogsAsync(_logStart.Date, endOfDay);
            var secTask = ShipExecService.GetSecurityLogsAsync(_logStart.Date, endOfDay);
            await Task.WhenAll(appTask, secTask);

            var (appTotal, appLogs) = await appTask;
            var (secTotal, secLogs) = await secTask;

            _logTotal    = appTotal;
            _logs        = appLogs;
            _secLogTotal = secTotal;
            _secLogs     = secLogs;
            _combLogs    = appLogs
                .Select(l => new CombinedLogEntry
                {
                    Source        = "App",
                    Id            = l.Id,
                    LogLevel      = l.LogLevel,
                    Logger        = l.Logger,
                    LogDate       = l.LogDate,
                    Message       = l.Message,
                    TransactionId = l.TransactionId,
                    ServerAddress = l.ServerAddress,
                })
                .Concat(secLogs.Select(l => new CombinedLogEntry
                {
                    Source        = "Security",
                    Id            = l.Id,
                    LogLevel      = l.LogLevel,
                    Logger        = l.Logger,
                    LogDate       = l.LogDate,
                    Message       = l.Message,
                    TransactionId = l.TransactionId,
                    ServerAddress = l.ServerAddress,
                    UserName      = l.UserName,
                    ActionType    = l.ActionType,
                    Entity        = l.Entity,
                    EntityName    = l.EntityName,
                    CurrentValue  = l.CurrentValue,
                    PreviousValue = l.PreviousValue,
                }))
                .OrderByDescending(l => l.LogDate ?? DateTime.MinValue)
                .ToList();

            _logsSearched = true;
            _logsJson = System.Text.Json.JsonSerializer.Serialize(
                _combLogs,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = false, PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
        }
        catch (Exception ex)
        {
            _logsError = ex.Message;
        }
        finally
        {
            _logsSearching = false;
        }
    }

