    private async Task HandleCompanyConnected((Guid Id, string Name) company)
    {
        _showConnectDialog = false;
        _canLoadHistory = true;
        _currentCompanyId = company.Id;
        loadedFileName = company.Name;
        isLoading = true;
        errorMessage = null;
        rootNode = null;
        _isDirty = false;
        _activeMainTab = "company";
        _usersJson = null;
        _usersMetaJson = null;
        _foundUserIds = null;
        _pendingUserDeletes = null;
        _pendingUserEdits = null;
        _addUserPrefill = null;
        _userVarianceIds.Clear();
        _sbrs             = [];
        _sbrError         = null;
        _sbrLoaded        = false;
        _sbrLoading       = false;
        _sbrDownloadingIds = [];
        CloseSbrViewer();
        _cbrs        = [];
        _cbrError    = null;
        _cbrLoaded   = false;
        _cbrLoading  = false;
        _selectedCbr        = null;
        _cbrEditedScript   = string.Empty;
        _cbrOriginalScript = string.Empty;
        _cbrPreAnalysisScript = string.Empty;
        _cbrAnalysisResult  = null;
        _cbrAnalysisError   = null;
        _cbrAnalysisVisible = false;
        _cbrAnalyzing       = false;
        _cbrEditing         = false;
        _cbrsJson    = null;
        _logsJson    = null;
        _foundLogIds = null;
        _entityIndex = null;
        try
        {
            rootNode = await ShipExecService.BuildCompanySkeletonAsync();
            XmlViewerService.ExpandToDepth(rootNode, 1);
            nodeCount = CountNodes(rootNode);
            activeDepth = 1;
            _version++;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading company: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
        await LoadHistoryAsync();

        // #14: Auto-collapse the variance panel 0.6s after loading
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(600);
                await InvokeAsync(() =>
                {
                    _variancePanelVisible = false;
                    StateHasChanged();
                });
            }
            catch { }
        });

        // Build the entity index in the background
        // from the API so the AI chatbot has complete data regardless of which tree
        // nodes the user has expanded.
        _ = Task.Run(async () =>
        {
            try
            {
                _entityIndex = await ShipExecService.BuildEntityIndexAsync();
                await InvokeAsync(StateHasChanged);
            }
            catch { /* non-fatal — AI will fall back to serialized XML */ }
        });
    }

    private async Task RefreshCompanyAsync()
    {
        if (_currentCompanyId == Guid.Empty || string.IsNullOrEmpty(loadedFileName)) return;

        // Check if the JWT has expired before attempting a refresh
        try
        {
            var expired = await JSRuntime.InvokeAsync<bool>("isJwtExpired");
            if (expired)
            {
                _showConnectDialog = true;
                return;
            }
        }
        catch { /* JS interop may fail — proceed anyway */ }

        await HandleCompanyConnected((_currentCompanyId, loadedFileName));
    }

    private async Task SwitchCompanyAsync(ChangeEventArgs e)
    {
        if (e.Value is not string val || !Guid.TryParse(val, out var newId)) return;
        if (newId == _currentCompanyId) return;

        // Check JWT expiry before switching
        try
        {
            var expired = await JSRuntime.InvokeAsync<bool>("isJwtExpired");
            if (expired)
            {
                _showConnectDialog = true;
                return;
            }
        }
        catch { /* proceed anyway */ }

        var companies = ShipExecService.GetCachedCompanies();
        var company = companies.FirstOrDefault(c => c.Id == newId);
        if (company is null) return;
        await ShipExecService.SetupCompanyAsync(company.Id, company.Name);
        await HandleCompanyConnected((company.Id, company.Name));
    }

    private async Task HandleLazyLoadAsync(XmlNodeViewModel node)
    {
        try
        {
            await ShipExecService.LoadCategoryChildrenAsync(node);
            if (rootNode is not null)
            {
                XmlRefLookupService.Rebuild(rootNode);
                nodeCount = CountNodes(rootNode);
            }
            _version++;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load {node.NodeName}: {ex.Message}";
            node.IsLazyLoaded = true; // prevent retry
            await InvokeAsync(StateHasChanged);
        }
    }

