    {
        if (rootNode is null || items.Count == 0) return;

        foreach (var group in items.GroupBy(i => i.EntityType, StringComparer.OrdinalIgnoreCase))
        {
            var entityType = group.Key;
            if (!_entityCollectionMap.TryGetValue(entityType, out var collectionName)) continue;

            var parentNode = rootNode.Children
                .FirstOrDefault(c => c.NodeName.Equals(collectionName, StringComparison.OrdinalIgnoreCase));
            if (parentNode is null) continue;
            await EnsureCategoryLoadedAsync(parentNode);

            foreach (var item in group)
            {
                var entityNode = FindEntityNode(parentNode, entityType, item.Id, item.Name);
                if (entityNode is null) continue;

                var name = entityNode.Children
                    .FirstOrDefault(c => c.NodeName.Equals("Name", StringComparison.OrdinalIgnoreCase))
                    ?.NodeValue ?? item.Name;
                var parentId      = parentNode.Id;
                var snapshotIndex = parentNode.Children.IndexOf(entityNode);

                _varianceEntries.Insert(0, new Variance
                {
                    NodeId           = parentId,
                    PathDescription  = $"{collectionName} \u203a {name}",
                    Description      = $"AI Delete: {name}",
                    ChangeType       = "Removed",
                    SnapshotNode     = entityNode,
                    SnapshotParentId = parentId,
                    SnapshotIndex    = snapshotIndex,
                });

                XmlViewerService.RemoveNode(entityNode);
            }
        }

        XmlRefLookupService.Rebuild(rootNode);
        MarkDirty();
        _version++;
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleAiEntityEdits(List<EntityEditItem> items)
    {
        if (rootNode is null || items.Count == 0) return;

        var opts = new System.Text.Json.JsonSerializerOptions { WriteIndented = false };
        foreach (var group in items.GroupBy(i => i.EntityType, StringComparer.OrdinalIgnoreCase))
        {
            var entityType = group.Key;
            if (!_entityCollectionMap.TryGetValue(entityType, out var collectionName)) continue;

            var parentNode = rootNode.Children
                .FirstOrDefault(c => c.NodeName.Equals(collectionName, StringComparison.OrdinalIgnoreCase));
            if (parentNode is null) continue;
            await EnsureCategoryLoadedAsync(parentNode);

            foreach (var item in group)
            {
                if (item.Edits is null || item.Edits.Count == 0) continue;

                var entityNode = FindEntityNode(parentNode, entityType, item.Id, item.Name);
                if (entityNode is null) continue;

                var originalFields = entityNode.Children.ToDictionary(
                    c => c.NodeName, c => c.NodeValue ?? string.Empty, StringComparer.OrdinalIgnoreCase);

                foreach (var (field, value) in item.Edits)
                    UpdateEntityFieldInTree(entityNode, field, value);

                var modifiedFields = entityNode.Children.ToDictionary(
                    c => c.NodeName, c => c.NodeValue ?? string.Empty, StringComparer.OrdinalIgnoreCase);

                var name = originalFields.TryGetValue("Name", out var n) ? n : item.Name;
                var changedFields = string.Join(", ", item.Edits.Select(e => $"{e.Key}=\"{e.Value}\""));

                _varianceEntries.Insert(0, new Variance
                {
                    NodeId          = Guid.Empty,
                    PathDescription = $"{collectionName} \u203a {name}",
                    Description     = $"AI Edit: {changedFields}",
                    ChangeType      = "Modified",
                    OriginalXML     = System.Text.Json.JsonSerializer.Serialize(originalFields, opts),
                    NewXML          = System.Text.Json.JsonSerializer.Serialize(modifiedFields, opts),
                });
            }
        }

        XmlRefLookupService.Rebuild(rootNode);
        MarkDirty();
        _version++;
        InvokeAsync(StateHasChanged);
    }

