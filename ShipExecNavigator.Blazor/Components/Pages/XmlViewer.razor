    private async Task HandleGoToProfileAsync(string profileName)
    {
        _showCompareProfilesDialog = false;
        if (rootNode is null) return;

        // Switch to the Company tab so the tree is visible
        _activeMainTab = "company";

        var profilesNode = rootNode.Children.FirstOrDefault(c =>
            string.Equals(c.NodeName, "Profiles", StringComparison.OrdinalIgnoreCase));
        if (profilesNode is null) return;

        // Lazy-load the Profiles category if not yet populated
        if (!profilesNode.IsLazyLoaded)
            await HandleLazyLoadAsync(profilesNode);

        profilesNode.IsExpanded = true;

        // Find the profile node whose Name child matches the requested profile
        var profileNode = profilesNode.Children.FirstOrDefault(c =>
            string.Equals(c.NodeName, "Profile", StringComparison.OrdinalIgnoreCase) &&
            c.Children.Any(gc =>
                string.Equals(gc.NodeName, "Name", StringComparison.OrdinalIgnoreCase) &&
                string.Equals(gc.NodeValue, profileName, StringComparison.OrdinalIgnoreCase)));

        if (profileNode is not null)
        {
            profileNode.IsExpanded = true;
            _highlightedNodeId = profileNode.Id;
            _version++;
        }

        await InvokeAsync(StateHasChanged);
    }

