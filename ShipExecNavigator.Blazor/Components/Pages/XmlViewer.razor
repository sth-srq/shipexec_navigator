    // ── SBR Deploy (build + DLL + base64) ────────────────────────────────────

    private async Task DeploySbrAsync()
    {
        if (_sbrDeploying || _sbrViewerFiles.Count == 0) return;
        _sbrDeploying = true;
        _sbrDeployBase64 = null;
        StateHasChanged();

        string? buildDir = null;
        try
        {
            buildDir = Path.Combine(Path.GetTempPath(), $"sbr_deploy_{Guid.NewGuid():N}");
            Directory.CreateDirectory(buildDir);

            foreach (var (relPath, content) in _sbrViewerFiles)
            {
                var fullPath = Path.Combine(buildDir, relPath);
                var dir = Path.GetDirectoryName(fullPath);
                if (dir is not null) Directory.CreateDirectory(dir);
                await File.WriteAllTextAsync(fullPath, content);
            }

            var psi = new System.Diagnostics.ProcessStartInfo("dotnet", "build --nologo --configuration Release")
            {
                WorkingDirectory = buildDir,
                RedirectStandardOutput = true,
                RedirectStandardError = true,
                UseShellExecute = false,
                CreateNoWindow = true
            };

            using var proc = System.Diagnostics.Process.Start(psi);
            if (proc is null)
            {
                _sbrBuildOutput = "Failed to start dotnet build process.";
                return;
            }

            await proc.StandardOutput.ReadToEndAsync();
            await proc.StandardError.ReadToEndAsync();
            await proc.WaitForExitAsync();

            if (proc.ExitCode != 0)
            {
                _sbrBuildOutput = "❌ Build failed. Fix errors and try again.";
                return;
            }

            // Find the output DLL
            var dllFiles = Directory.GetFiles(buildDir, "*.dll", SearchOption.AllDirectories)
                .Where(f => f.Contains(Path.Combine("bin", "Release")))
                .Where(f => !Path.GetFileName(f).StartsWith("System.") && !Path.GetFileName(f).StartsWith("Microsoft."))
                .ToList();

            var targetDll = dllFiles.FirstOrDefault(f =>
                Path.GetFileNameWithoutExtension(f).Equals(_sbrViewerSbr?.Name, StringComparison.OrdinalIgnoreCase))
                ?? dllFiles.FirstOrDefault();

            if (targetDll is null)
            {
                _sbrBuildOutput = "Build succeeded but no output DLL found.";
                return;
            }

            var dllBytes = await File.ReadAllBytesAsync(targetDll);
            _sbrDeployBase64 = Convert.ToBase64String(dllBytes);

            // Download the DLL
            var safeName = _sbrViewerSbr?.Name?.Replace(" ", "_") ?? "sbr";
            using var stream = new DotNetStreamReference(new MemoryStream(dllBytes));
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", $"{safeName}.dll", stream);

            // Also copy the base64 to clipboard
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _sbrDeployBase64);
            _sbrBuildOutput = $"✅ Build succeeded. DLL downloaded and base64 string copied to clipboard ({_sbrDeployBase64.Length:N0} chars).";
        }
        catch (Exception ex)
        {
            _sbrBuildOutput = $"Deploy error: {ex.Message}";
        }
        finally
        {
            _sbrDeploying = false;
            try { if (buildDir is not null && Directory.Exists(buildDir)) Directory.Delete(buildDir, true); } catch { }
            StateHasChanged();
        }
    }

