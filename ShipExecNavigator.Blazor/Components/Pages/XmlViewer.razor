    private void ImportVariancesFromJson()
    {
        _importVariancesError = null;
        try
        {
            var options = new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            };
            var imported = System.Text.Json.JsonSerializer.Deserialize<List<Variance>>(_importVariancesJson, options);
            if (imported is null || imported.Count == 0)
            {
                _importVariancesError = "No variances found in the provided JSON.";
                return;
            }
            foreach (var v in imported)
            {
                if (v.Id == Guid.Empty) v.Id = Guid.NewGuid();
                v.Timestamp = DateTime.Now;
                _varianceEntries.Insert(0, v);
            }
            _showImportVariancesDialog = false;
            _importVariancesJson = string.Empty;
            _variancePanelVisible = true;
        }
        catch (System.Text.Json.JsonException ex)
