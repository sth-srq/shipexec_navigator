    private void HandleShipperVariancesForPanel(List<Variance> variances)
    {
        var opts = new System.Text.Json.JsonSerializerOptions { WriteIndented = false };
        foreach (var v in variances)
        {
            if (v.NewObject is not PSI.Sox.Shipper incoming) continue;
            var symbol = incoming.Symbol ?? string.Empty;
            var name   = incoming.Name   ?? string.Empty;
            var action = v.IsAdd ? "Import Add" : "Import Update";
            var changeType = v.IsAdd ? "Added" : "Modified";
            _varianceEntries.Insert(0, new Variance
            {
                NodeId          = Guid.Empty,
                PathDescription = $"Shippers \u203a {symbol}",
                Description     = $"{action}: {name}",
                ChangeType      = changeType,
                OriginalXML    = v.OriginalObject is PSI.Sox.Shipper orig
                    ? System.Text.Json.JsonSerializer.Serialize(orig, opts)
                    : string.Empty,
                NewXML         = System.Text.Json.JsonSerializer.Serialize(incoming, opts),
            });
            _pendingShipperVariances.Add(v);
            ApplyShipperToTree(v);
        }
        if (rootNode is not null)
            XmlRefLookupService.Rebuild(rootNode);
        MarkDirty();
        _version++;
    }

    private async Task HandleAiShipperDeletions(List<ShipperDeleteItem> items)
    {
        if (rootNode is null || items.Count == 0) return;
        var shippersNode = rootNode.Children
            .FirstOrDefault(c => c.NodeName.Equals("Shippers", StringComparison.OrdinalIgnoreCase));
        if (shippersNode is null) return;
        await EnsureCategoryLoadedAsync(shippersNode);

        var opts = new System.Text.Json.JsonSerializerOptions { WriteIndented = false };
        foreach (var item in items)
        {
            // Find the shipper tree node by symbol first, fall back to name
            var shipperNode = shippersNode.Children.FirstOrDefault(c =>
                c.NodeName.Equals("Shipper", StringComparison.OrdinalIgnoreCase) &&
                c.Children.Any(gc =>
                    gc.NodeName.Equals("Symbol", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(gc.NodeValue, item.Symbol, StringComparison.OrdinalIgnoreCase)));

            if (shipperNode is null && !string.IsNullOrEmpty(item.Name))
            {
                shipperNode = shippersNode.Children.FirstOrDefault(c =>
                    c.NodeName.Equals("Shipper", StringComparison.OrdinalIgnoreCase) &&
                    c.Children.Any(gc =>
                        gc.NodeName.Equals("Name", StringComparison.OrdinalIgnoreCase) &&
                        string.Equals(gc.NodeValue, item.Name, StringComparison.OrdinalIgnoreCase)));
            }

            if (shipperNode is null) continue;

            // Build a PSI.Sox.Shipper from the tree node fields
            var shipper = BuildShipperFromTreeNode(shipperNode);

            // Create variance for the pending deletion
            var deleteVariance = new Variance
            {
                EntityName     = "Shipper",
                OriginalObject = shipper,
                IsRemove       = true,
                CompanyId      = shipper.CompanyId
            };
            _pendingShipperVariances.Add(deleteVariance);

            // Create a display variance entry
            var removePath = $"Shippers \u203a {shipper.Symbol}";
            var parentId = shippersNode.Id;
            var snapshotIndex = shippersNode.Children.IndexOf(shipperNode);

            _varianceEntries.Insert(0, new Variance
            {
                NodeId           = parentId,
                PathDescription  = removePath,
                Description      = $"AI Delete: {shipper.Name}",
                ChangeType       = "Removed",
                SnapshotNode     = shipperNode,
                SnapshotParentId = parentId,
                SnapshotIndex    = snapshotIndex,
                OriginalXML      = System.Text.Json.JsonSerializer.Serialize(shipper, opts),
            });

            // Remove from the tree
            XmlViewerService.RemoveNode(shipperNode);
        }

        XmlRefLookupService.Rebuild(rootNode);
        MarkDirty();
        _version++;
        InvokeAsync(StateHasChanged);
    }

    private static PSI.Sox.Shipper BuildShipperFromTreeNode(XmlNodeViewModel shipperNode)
    {
        string? Field(string name) =>
            shipperNode.Children
                .FirstOrDefault(c => c.NodeName.Equals(name, StringComparison.OrdinalIgnoreCase))
                ?.NodeValue;

        var shipper = new PSI.Sox.Shipper();
        if (int.TryParse(Field("Id"), out var id)) shipper.Id = id;
        shipper.Symbol        = Field("Symbol");
        shipper.Name          = Field("Name");
        shipper.Code          = Field("Code");
        shipper.Address1      = Field("Address1");
        shipper.Address2      = Field("Address2");
        shipper.Address3      = Field("Address3");
        shipper.City          = Field("City");
        shipper.StateProvince = Field("StateProvince");
        shipper.PostalCode    = Field("PostalCode");
        shipper.Country       = Field("Country");
        shipper.Company       = Field("Company");
        shipper.Contact       = Field("Contact");
        shipper.Phone         = Field("Phone");
        shipper.Fax           = Field("Fax");
        shipper.Email         = Field("Email");
        shipper.Sms           = Field("Sms");
        if (Guid.TryParse(Field("CompanyId"), out var companyId)) shipper.CompanyId = companyId;
        if (Guid.TryParse(Field("SiteId"), out var siteId)) shipper.SiteId = siteId;
        if (bool.TryParse(Field("PoBox"), out var poBox)) shipper.PoBox = poBox;
        if (bool.TryParse(Field("Residential"), out var res)) shipper.Residential = res;
        return shipper;
    }

    private async Task HandleAiShipperEdits(List<ShipperEditItem> items)
    {
        if (rootNode is null || items.Count == 0) return;
        var shippersNode = rootNode.Children
            .FirstOrDefault(c => c.NodeName.Equals("Shippers", StringComparison.OrdinalIgnoreCase));
        if (shippersNode is null) return;
        await EnsureCategoryLoadedAsync(shippersNode);

        var opts = new System.Text.Json.JsonSerializerOptions { WriteIndented = false };
        foreach (var item in items)
        {
            if (item.Edits is null || item.Edits.Count == 0) continue;

            // Find the shipper tree node by symbol first, fall back to name
            var shipperNode = shippersNode.Children.FirstOrDefault(c =>
                c.NodeName.Equals("Shipper", StringComparison.OrdinalIgnoreCase) &&
                c.Children.Any(gc =>
                    gc.NodeName.Equals("Symbol", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(gc.NodeValue, item.Symbol, StringComparison.OrdinalIgnoreCase)));

            if (shipperNode is null && !string.IsNullOrEmpty(item.Name))
            {
                shipperNode = shippersNode.Children.FirstOrDefault(c =>
                    c.NodeName.Equals("Shipper", StringComparison.OrdinalIgnoreCase) &&
                    c.Children.Any(gc =>
                        gc.NodeName.Equals("Name", StringComparison.OrdinalIgnoreCase) &&
                        string.Equals(gc.NodeValue, item.Name, StringComparison.OrdinalIgnoreCase)));
            }

            if (shipperNode is null) continue;

            // Snapshot the original shipper before changes
            var originalShipper = BuildShipperFromTreeNode(shipperNode);

            // Apply each field edit to the tree node
            foreach (var (field, value) in item.Edits)
            {
                UpdateShipperFieldInTree(shipperNode, field, value);
            }

            // Build the modified shipper after changes
            var modifiedShipper = BuildShipperFromTreeNode(shipperNode);

            // Create a BL variance for the edit
            var editVariance = new Variance
            {
                EntityName     = "Shipper",
                OriginalObject = originalShipper,
                NewObject      = modifiedShipper,
                IsUpdated      = true,
                CompanyId      = originalShipper.CompanyId,
            };
            _pendingShipperVariances.Add(editVariance);

            // Build a description of the changes
            var changedFields = string.Join(", ", item.Edits.Select(e => $"{e.Key}=\"{e.Value}\""));
            var editPath = $"Shippers \u203a {originalShipper.Symbol}";

            _varianceEntries.Insert(0, new Variance
            {
                NodeId          = Guid.Empty,
                PathDescription = editPath,
                Description     = $"AI Edit: {changedFields}",
                ChangeType      = "Modified",
                OriginalXML     = System.Text.Json.JsonSerializer.Serialize(originalShipper, opts),
                NewXML          = System.Text.Json.JsonSerializer.Serialize(modifiedShipper, opts),
            });
        }

        XmlRefLookupService.Rebuild(rootNode);
        MarkDirty();
        _version++;
        InvokeAsync(StateHasChanged);
    }

