    private void ApplyShipperToTree(Variance v)
    {
        if (rootNode is null || v.NewObject is not PSI.Sox.Shipper shipper) return;
        var shippersNode = rootNode.Children
            .FirstOrDefault(c => c.NodeName.Equals("Shippers", StringComparison.OrdinalIgnoreCase));
        if (shippersNode is null) return;

        if (v.IsAdd)
        {
            var fields = new List<(string, string)>();
            void AddField(string name, string? val)
            {
                if (!string.IsNullOrWhiteSpace(val)) fields.Add((name, val!.Trim()));
            }
            AddField("Id",            shipper.Id.ToString());
            AddField("Symbol",        shipper.Symbol);
            AddField("Name",          shipper.Name);
            AddField("Code",          shipper.Code);
            if (shipper.SiteId.HasValue && shipper.SiteId.Value != Guid.Empty)
                fields.Add(("SiteId", shipper.SiteId.Value.ToString()));
            AddField("Address1",      shipper.Address1);
            AddField("Address2",      shipper.Address2);
            AddField("Address3",      shipper.Address3);
            AddField("City",          shipper.City);
            AddField("StateProvince", shipper.StateProvince);
            AddField("PostalCode",    shipper.PostalCode);
            AddField("Country",       shipper.Country);
            AddField("Company",       shipper.Company);
            AddField("Contact",       shipper.Contact);
            AddField("Phone",         shipper.Phone);
            AddField("Fax",           shipper.Fax);
            AddField("Email",         shipper.Email);
            AddField("Sms",           shipper.Sms);
            if (shipper.PoBox)       fields.Add(("PoBox",       "true"));
            if (shipper.Residential) fields.Add(("Residential", "true"));

            XmlViewerService.AddChild(shippersNode, "Shipper",
                Enumerable.Empty<(string, string)>(), null, fields);

            var sorted = shippersNode.Children
                .OrderByDescending(c =>
                {
                    var idNode = c.Children.FirstOrDefault(gc =>
                        gc.NodeName.Equals("Id", StringComparison.OrdinalIgnoreCase));
                    return int.TryParse(idNode?.NodeValue, out var id) ? id : 0;
                })
                .ToList();
            shippersNode.Children.Clear();
            foreach (var child in sorted) shippersNode.Children.Add(child);
        }
        else
        {
            var lookupSymbol = v.OriginalObject is PSI.Sox.Shipper original ? original.Symbol : shipper.Symbol;
            var shipperNode = shippersNode.Children.FirstOrDefault(c =>
                c.NodeName.Equals("Shipper", StringComparison.OrdinalIgnoreCase) &&
                c.Children.Any(gc =>
                    gc.NodeName.Equals("Symbol", StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(gc.NodeValue, lookupSymbol, StringComparison.OrdinalIgnoreCase)));
            if (shipperNode is null) return;

            UpdateShipperFieldInTree(shipperNode, "Symbol",        shipper.Symbol);
            UpdateShipperFieldInTree(shipperNode, "Name",          shipper.Name);
            UpdateShipperFieldInTree(shipperNode, "Code",          shipper.Code);
            UpdateShipperFieldInTree(shipperNode, "SiteId",        shipper.SiteId.HasValue && shipper.SiteId.Value != Guid.Empty ? shipper.SiteId.Value.ToString() : null);
            UpdateShipperFieldInTree(shipperNode, "Address1",      shipper.Address1);
            UpdateShipperFieldInTree(shipperNode, "Address2",      shipper.Address2);
            UpdateShipperFieldInTree(shipperNode, "Address3",      shipper.Address3);
            UpdateShipperFieldInTree(shipperNode, "City",          shipper.City);
            UpdateShipperFieldInTree(shipperNode, "StateProvince", shipper.StateProvince);
            UpdateShipperFieldInTree(shipperNode, "PostalCode",    shipper.PostalCode);
            UpdateShipperFieldInTree(shipperNode, "Country",       shipper.Country);
            UpdateShipperFieldInTree(shipperNode, "Company",       shipper.Company);
            UpdateShipperFieldInTree(shipperNode, "Contact",       shipper.Contact);
            UpdateShipperFieldInTree(shipperNode, "Phone",         shipper.Phone);
            UpdateShipperFieldInTree(shipperNode, "Fax",           shipper.Fax);
            UpdateShipperFieldInTree(shipperNode, "Email",         shipper.Email);
            UpdateShipperFieldInTree(shipperNode, "Sms",           shipper.Sms);
            UpdateShipperFieldInTree(shipperNode, "PoBox",       shipper.PoBox       ? "true" : "false");
            UpdateShipperFieldInTree(shipperNode, "Residential", shipper.Residential ? "true" : "false");
        }
    }

    private void UpdateShipperFieldInTree(XmlNodeViewModel shipperNode, string fieldName, string? value)
    {
        var fieldNode = shipperNode.Children.FirstOrDefault(c =>
            c.NodeName.Equals(fieldName, StringComparison.OrdinalIgnoreCase));
        var trimmed = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
        if (fieldNode is null)
        {
            // Create the node if a non-empty value is being set (e.g. SiteId on a shipper that lacked it)
            if (trimmed is null) return;
            XmlViewerService.AddChild(shipperNode, fieldName,
                Enumerable.Empty<(string, string)>(), trimmed,
                Enumerable.Empty<(string, string)>());
            return;
        }
        if (string.Equals(fieldNode.NodeValue, trimmed, StringComparison.Ordinal)) return;
        XmlViewerService.UpdateNodeValue(fieldNode, value ?? string.Empty);
        // If the restored value matches the original loaded value, clear the modified flag
        if (string.Equals(trimmed, fieldNode.OriginalNodeValue?.Trim(), StringComparison.Ordinal))
            fieldNode.IsModified = false;
    }

    private XmlNodeViewModel? FindShipperNodeBySymbol(string? symbol)
    {
        if (rootNode is null || symbol is null) return null;
        var shippersNode = rootNode.Children.FirstOrDefault(c =>
            c.NodeName.Equals("Shippers", StringComparison.OrdinalIgnoreCase));
        return shippersNode?.Children.FirstOrDefault(c =>
            c.NodeName.Equals("Shipper", StringComparison.OrdinalIgnoreCase) &&
            c.Children.Any(gc =>
                gc.NodeName.Equals("Symbol", StringComparison.OrdinalIgnoreCase) &&
                string.Equals(gc.NodeValue, symbol, StringComparison.OrdinalIgnoreCase)));
    }

