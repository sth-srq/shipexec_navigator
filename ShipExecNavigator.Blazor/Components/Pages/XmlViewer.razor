    private void ExecutePaste(XmlNodeViewModel parent)
    {
        CloseContextMenu();
        var clipboard = XmlViewerService.Clipboard;
        if (clipboard is null) return;

        var pasted = XmlViewerService.CloneNode(clipboard, parent);

        ResetIds(pasted);

        parent.NodeValue = null;
        parent.IsExpanded = true;
        parent.Children.Add(pasted);
        XmlRefLookupService.Rebuild(rootNode!);

        _varianceEntries.Insert(0, new Variance
        {
            NodeId = pasted.Id,
            PathDescription = BuildNodePath(pasted),
            Description = $"Pasted <{pasted.NodeName}>",
            ChangeType = "Added"
        });

        MarkDirty();
        _version++;
    }

    private static void ResetIds(XmlNodeViewModel node)
    {
        if (node.NodeName.Equals("Id", StringComparison.OrdinalIgnoreCase))
            node.NodeValue = "-1";

        foreach (var child in node.Children)
            ResetIds(child);
    }

    private void ExecuteAddChild(XmlAddChildDialog.AddChildData data)
    {
        var target = _addChildTarget;
        CloseAddChildDialog();
        if (target is null) return;

        XmlViewerService.AddChild(
            target,
            data.ElementName,
            data.Attributes.Select(f => (f.Name, f.Value)),
            data.Value,
            data.ChildElements.Select(f => (f.Name, f.Value)));
        XmlRefLookupService.Rebuild(rootNode!);

        var newNode = target.Children.Count > 0 ? target.Children[^1] : null;
        if (newNode is not null)
        {
            _varianceEntries.Insert(0, new Variance
            {
                NodeId = newNode.Id,
                PathDescription = BuildNodePath(newNode),
                Description = $"Added <{data.ElementName}>",
                ChangeType = "Added"
            });
        }

        MarkDirty();
        _version++;
    }

