@page "/"
@page "/ask"
@layout ChatLayout
@implements IDisposable

@using ShipExecNavigator.Shared.Interfaces
@using UglyToad.PdfPig
@using System.IO.Compression
@inject IAiChatService AiChat
@inject IJSRuntime JS
@inject IShipExecService ShipExecService
@inject IWebHostEnvironment Env

<PageTitle>ShipExec Navigator</PageTitle>

<div class="chat-page">

    @{ var _currentCompany = ShipExecService.GetCurrentCompany(); }
    @if (_currentCompany is not null)
    {
        <div class="company-heading">@_currentCompany.DisplayName</div>
    }

    <div class="page-tab-bar">
        <span class="page-tab page-tab--active">&#x1F916; ShipExec Copilot</span>
        <a class="page-tab" href="/studio">&#x1F5FA; Navigator</a>
        <a class="page-tab" href="/tools">&#x1F527; Tools</a>
        <a class="page-tab" href="/debug" style="display:none">&#x1F41B; Debug</a>
        @if (_messages.Count > 0)
        {
            <button class="chat-export-btn" @onclick="ExportChatAsync" title="Save chat log">&#x1F4BE; Export</button>
            <button class="chat-clear-btn" @onclick="ClearChat" title="Clear conversation">&#x1F5D1; Clear</button>
        }
    </div>

    <div class="chat-messages" id="chat-messages-scroll">
        @foreach (var msg in _messages)
        {
            <div class="chat-bubble chat-bubble--@msg.Role">
                <div class="chat-bubble-label">@(msg.Role == "user" ? "You" : "ShipExec Copilot")</div>
                <div class="chat-bubble-body">@((MarkupString)FormatMessage(msg.Content))</div>
            </div>
        }
        @if (_thinking)
        {
            <div class="chat-bubble chat-bubble--assistant">
                <div class="chat-bubble-label">ShipExec Copilot</div>
                <div class="chat-bubble-body chat-thinking">
                    <span></span><span></span><span></span>
                </div>
            </div>
        }
    </div>

    <div class="chat-input-row">
        <textarea class="chat-textarea"
                  id="chat-textarea"
                  placeholder="Type your message…"
                  @bind="_input"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  @onkeydown:preventDefault="_suppressEnter"
                  rows="1"
                  disabled="@_thinking"></textarea>
        <button class="chat-send-btn" @onclick="SendAsync" disabled="@(string.IsNullOrWhiteSpace(_input) || _thinking)">
            &#x27A4; Send
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="chat-error">&#9888; @_error</div>
    }

    <div class="new-company-row">
        <button class="btn-new-company" @onclick="() => _showNewCompanyWizard = true">
            &#x2795; New Company
        </button>
        <button class="btn-upload-doc" @onclick="TriggerFileUpload">
            &#x1F4C4; Upload Document
        </button>
        <InputFile @ref="_fileInput" OnChange="OnDocumentSelected" accept=".txt,.pdf"
                   style="display:none" id="home-doc-upload" />
    </div>

    @if (_uploadedFileName is not null)
    {
        <div class="upload-badge">
            &#x1F4CE; @_uploadedFileName
            <button class="upload-badge-remove" @onclick="ClearUploadedDocument">&#x2715;</button>
        </div>
    }

    @if (_analysisComplete)
    {
        <div class="create-project-row">
            <button class="btn-create-project" @onclick="CreateProjectAsync" disabled="@_thinking">
                &#x1F4E6; Create Project
            </button>
        </div>
    }
</div>

<CreateCompanyWizard IsVisible="_showNewCompanyWizard"
                     OnClose="() => _showNewCompanyWizard = false"
                     OnCompanyConnected="HandleNewCompanyConnected" />

@code {
    private readonly List<ChatMessage> _messages = [];
    private readonly List<string> _inputHistory = [];
    private string _input = string.Empty;
    private bool _thinking = true;
    private string? _error;
    private int _historyIndex = -1;
    private string _historyDraft = string.Empty;
    private bool _suppressEnter;
    private bool _showNewCompanyWizard;
    private InputFile? _fileInput;
    private string? _uploadedFileName;
    private byte[]? _uploadedFileContent;
    private bool _analysisComplete;
    private string? _lastAnalysisResult;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ShipExecService.OnDisconnected += HandleDisconnected;
            ShipExecService.OnConnected    += HandleConnected;
            await JS.InvokeVoidAsync("initChatInputHistory", "chat-textarea", DotNetObjectReference.Create(this));
            await GreetAsync();
        }
    }

    public void Dispose()
    {
        ShipExecService.OnDisconnected -= HandleDisconnected;
        ShipExecService.OnConnected    -= HandleConnected;
    }

    private void HandleDisconnected()
    {
        InvokeAsync(() =>
        {
            _messages.Clear();
            _inputHistory.Clear();
            _input = string.Empty;
            _error = null;
            _thinking = false;
            _historyIndex = -1;
            _historyDraft = string.Empty;
            StateHasChanged();
        });
    }

    private void HandleConnected()
    {
        InvokeAsync(async () =>
        {
            // Re-greet when a new company is connected
            _messages.Clear();
            _error = null;
            StateHasChanged();
            await GreetAsync();
        });
    }

    private async Task TriggerFileUpload()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('home-doc-upload').click()");
    }

    private async Task OnDocumentSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        _uploadedFileName = file.Name;
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
        _uploadedFileContent = ms.ToArray();

        // Extract text and trigger analysis
        var docText = ExtractText(_uploadedFileName, _uploadedFileContent);
        if (!string.IsNullOrWhiteSpace(docText))
            await AnalyseDocumentAsync(_uploadedFileName, docText);
    }

    private void ClearUploadedDocument()
    {
        _uploadedFileName = null;
        _uploadedFileContent = null;
    }

    private string ExtractText(string fileName, byte[] content)
    {
        if (fileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                using var pdf = PdfDocument.Open(content);
                var sb = new System.Text.StringBuilder();
                foreach (var page in pdf.GetPages())
                {
                    sb.AppendLine(page.Text);
                }
                return sb.ToString();
            }
            catch
            {
                return System.Text.Encoding.UTF8.GetString(content);
            }
        }
        return System.Text.Encoding.UTF8.GetString(content);
    }

    private async Task AnalyseDocumentAsync(string fileName, string documentText)
    {
        _messages.Add(new ChatMessage("user",
            $"I uploaded **{fileName}**. Please analyse this document for business rules " +
            $"and map them to ShipExec CBR and SBR hooks with detailed program flow."));
        _thinking = true;
        _error = null;
        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            // Load the hook reference
            var hookRefPath = Path.Combine(Env.ContentRootPath, "..", "Docs", "CBR_SBR_Hook_Reference.md");
            var hookReference = File.Exists(hookRefPath)
                ? await File.ReadAllTextAsync(hookRefPath)
                : "(Hook reference not available)";

            var prompt =
                $"""  
                You are a ShipExec business rules architect with deep expertise in both
                Client Business Rules (CBR — JavaScript, browser-side) and
                Server Business Rules (SBR — .NET DLL, server-side).

                ## Context
                The user has uploaded a document that describes shipping business requirements.
                Your job is to:
                1. Identify every high-level business rule in the document.
                2. For each rule, determine which CBR hook(s) AND/OR SBR hook(s) it maps to.
                3. Detail the **program flow** for each rule — step-by-step execution order
                   including branching logic (if/else conditions, loops, early returns).
                4. Indicate whether the rule is client-side (CBR), server-side (SBR), or both,
                   and explain why.

                ## Output format
                Respond with a structured report using this exact format:

                ### Business Rules Analysis — {fileName}

                ---

                **Rule 1: <short name>**
                - **Description:** <what the rule does>
                - **Type:** CBR / SBR / Both
                - **Hook(s):** <hook names, e.g. PreShip (CBR), PreShip (SBR)>
                - **Program Flow:**
                  1. <first step>
                  2. IF <condition> THEN
                     - <action A>
                  3. ELSE
                     - <action B>
                  4. <next step>
                  ...
                - **Branching Logic:**
                  - <condition 1> → <outcome>
                  - <condition 2> → <outcome>
                - **CBR Implementation:** <JavaScript logic/pseudocode for client-side, or "N/A">
                - **SBR Implementation:** <.NET logic/pseudocode for server-side, or "N/A">

                ---

                **Rule 2: <short name>**
                ... (repeat for each rule)

                ---

                ### Execution Flow Diagram

                Provide a text-based flow showing the overall execution order across all rules:
                ```
                User Action → CBR PreShip → [validation] → Server receives request
                    → SBR PreShip → [server validation/enrichment]
                    → Carrier API call
                    → SBR PostShip → [server post-processing]
                    → Response to client
                    → CBR PostShip → [UI updates]
                ```
                (Adapt this to reflect the actual rules found in the document)

                ### Summary
                - Total rules identified: <N>
                - CBR hooks used: <list>
                - SBR hooks used: <list>
                - Rules requiring BOTH CBR + SBR: <list>
                - Hooks NOT needed: <any hooks from the reference that aren't relevant>

                ## Hook Reference
                {hookReference}

                ## Uploaded Document
                {documentText}
                """;

            var reply = await AiChat.SendMessageAsync(
                _messages.SkipLast(1).ToList(),
                prompt,
                useRag: false);

            _messages.Add(new ChatMessage("assistant", reply.Message));
            _lastAnalysisResult = reply.Message;
            _analysisComplete = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _thinking = false;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private async Task CreateProjectAsync()
    {
        try
        {
            _thinking = true;
            StateHasChanged();

            // Load template files
            var templateRoot = Path.Combine(Env.ContentRootPath, "..", "CodeStandards", "TemplateCodeShipExec20BusinessRules");
            var templateFiles = new Dictionary<string, string>();

            foreach (var file in Directory.GetFiles(templateRoot, "*.*", SearchOption.AllDirectories))
            {
                var relativePath = Path.GetRelativePath(templateRoot, file);
                templateFiles[relativePath] = await File.ReadAllTextAsync(file);
            }

            // Build the modified SBR with analysis comments
            var analysisComment = _lastAnalysisResult ?? "No analysis available";
            var sbrHeader = $"/*\n * AUTO-GENERATED BUSINESS RULES PROJECT\n * Generated: {DateTime.Now:yyyy-MM-dd HH:mm:ss}\n *\n * Analysis Results:\n * {analysisComment.Replace("\n", "\n * ").Substring(0, Math.Min(analysisComment.Length, 2000))}\n */\n\n";
            var cbrHeader = $"/**\n * AUTO-GENERATED BUSINESS RULES PROJECT\n * Generated: {DateTime.Now:yyyy-MM-dd HH:mm:ss}\n *\n * Analysis Results:\n * {analysisComment.Replace("\n", "\n * ").Substring(0, Math.Min(analysisComment.Length, 2000))}\n */\n\n";

            // Create zip in memory
            using var zipStream = new MemoryStream();
            using (var archive = new System.IO.Compression.ZipArchive(zipStream, System.IO.Compression.ZipArchiveMode.Create, true))
            {
                foreach (var (relativePath, content) in templateFiles)
                {
                    var entry = archive.CreateEntry(Path.Combine("BusinessRulesProject", relativePath));
                    using var writer = new StreamWriter(entry.Open());

                    // Prepend analysis comments to the main SBR and CBR files
                    if (relativePath.EndsWith("SoxBusinessRules.cs", StringComparison.OrdinalIgnoreCase))
                        await writer.WriteAsync(sbrHeader + content);
                    else if (relativePath.EndsWith(".js", StringComparison.OrdinalIgnoreCase))
                        await writer.WriteAsync(cbrHeader + content);
                    else
                        await writer.WriteAsync(content);
                }

                // Add the full analysis as a separate markdown file
                var analysisEntry = archive.CreateEntry(Path.Combine("BusinessRulesProject", "ANALYSIS_RESULTS.md"));
                using var analysisWriter = new StreamWriter(analysisEntry.Open());
                await analysisWriter.WriteAsync($"# Business Rules Analysis\n\nGenerated: {DateTime.Now:yyyy-MM-dd HH:mm:ss}\n\n{_lastAnalysisResult}");
            }

            // Trigger download via JS File System Access API with fallback
            var zipBytes = zipStream.ToArray();
            var base64 = Convert.ToBase64String(zipBytes);
            var fileName = $"BusinessRulesProject_{DateTime.Now:yyyyMMdd_HHmmss}.zip";

            await JS.InvokeVoidAsync("saveProjectZip", fileName, base64);

            _messages.Add(new ChatMessage("assistant", $"\u2705 Project created and downloaded as **{fileName}**. The zip contains the template business rules with your analysis results embedded as comments."));
        }
        catch (Exception ex)
        {
            _error = $"Failed to create project: {ex.Message}";
        }
        finally
        {
            _thinking = false;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private async Task HandleNewCompanyConnected((Guid Id, string Name) company)
    {
        _showNewCompanyWizard = false;
        // If the service is connected, set up the company and trigger connected flow
        try
        {
            await ShipExecService.SetupCompanyAsync(company.Id, company.Name);
        }
        catch { /* may not be connected — that's fine */ }
        StateHasChanged();
    }

    private async Task GreetAsync()
    {
        _error    = null;
        _thinking = true;
        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            var reply = await AiChat.SendMessageAsync(
                [],
                "greet yourself",
                useRag: false);
            _messages.Add(new ChatMessage("assistant", reply.Message));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _thinking = false;
            StateHasChanged();
            await ScrollToBottomAsync();
            await JS.InvokeVoidAsync("eval", "document.getElementById('chat-textarea')?.focus()");
        }
    }

    private async Task SendAsync()
    {
        var text = _input.Trim();
        if (string.IsNullOrEmpty(text) || _thinking) return;

        _input   = string.Empty;
        _error   = null;
        _thinking = true;

        if (_inputHistory.Count == 0 || _inputHistory[^1] != text)
            _inputHistory.Add(text);
        if (_inputHistory.Count > 50)
            _inputHistory.RemoveAt(0);
        _historyIndex = -1;
        _historyDraft = string.Empty;

        _messages.Add(new ChatMessage("user", text));
        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            var reply = await AiChat.SendMessageAsync(_messages.SkipLast(1).ToList(), text, useRag: true);
            _messages.Add(new ChatMessage("assistant", reply.Message));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _thinking = false;
            StateHasChanged();
            await ScrollToBottomAsync();
            await JS.InvokeVoidAsync("eval", "document.getElementById('chat-textarea')?.focus()");
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            _suppressEnter = true;
            await SendAsync();
        }
        else
        {
            _suppressEnter = false;
        }
    }

    [JSInvokable]
    public string? HandleHistoryKey(string key)
    {
        if (key == "ArrowUp")
        {
            if (_inputHistory.Count == 0) return null;
            if (_historyIndex == -1)
            {
                _historyDraft  = _input;
                _historyIndex  = _inputHistory.Count - 1;
            }
            else if (_historyIndex > 0)
            {
                _historyIndex--;
            }
            else
            {
                return null;
            }
            _input = _inputHistory[_historyIndex];
            StateHasChanged();
            return _input;
        }

        if (key == "ArrowDown")
        {
            if (_historyIndex == -1) return null;
            if (_historyIndex < _inputHistory.Count - 1)
            {
                _historyIndex++;
                _input = _inputHistory[_historyIndex];
            }
            else
            {
                _historyIndex = -1;
                _input        = _historyDraft;
                _historyDraft = string.Empty;
            }
            StateHasChanged();
            return _input;
        }

        return null;
    }

    private async Task ClearChat()
    {
        _messages.Clear();
        _error = null;
        await GreetAsync();
    }

    private async Task ExportChatAsync()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("ShipExec Copilot — Chat Log");
        sb.AppendLine($"Exported: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
        sb.AppendLine(new string('─', 60));
        sb.AppendLine();

        foreach (var msg in _messages)
        {
            var label = msg.Role == "user" ? "You" : "ShipExec Copilot";
            sb.AppendLine($"[{label}]");
            sb.AppendLine(msg.Content);
            sb.AppendLine();
        }

        var fileName = $"ShipExec_ChatLog_{DateTime.Now:yyyyMMdd_HHmmss}.txt";
        await JS.InvokeVoidAsync("downloadFile", fileName, sb.ToString(), "text/plain");
    }

    private async Task ScrollToBottomAsync()
    {
        await JS.InvokeVoidAsync("eval",
            "var el=document.getElementById('chat-messages-scroll');if(el)el.scrollTop=el.scrollHeight;");
    }

    private static string FormatMessage(string text)
    {
        // ── Strip JSON action payloads and dangerous structures ───────────
        try
        {
            if (text.TrimStart().StartsWith("{") && text.TrimEnd().EndsWith("}"))
            {
                var json = System.Text.Json.JsonDocument.Parse(text);
                if (json.RootElement.TryGetProperty("message", out var msgProp))
                {
                    text = msgProp.GetString() ?? text;
                }
            }
        }
        catch
        {
            // Not JSON or invalid, continue with original text
        }

        // ── Normalize line endings ────────────────────────────────────────
        text = text.Replace("\r\n", "\n").Replace("\r", "\n");

        var lines  = text.Split('\n');
        var sb     = new System.Text.StringBuilder();
        int i      = 0;
        int total  = lines.Length;

        while (i < total)
        {
            var raw = lines[i];
            var line = raw.TrimEnd();

            // ── Fenced code block  ```lang … ``` ──────────────────────────
            if (line.StartsWith("```"))
            {
                var lang = line.Length > 3 ? line[3..].Trim() : string.Empty;
                var code = new System.Text.StringBuilder();
                i++;
                while (i < total && !lines[i].TrimEnd().StartsWith("```"))
                {
                    code.AppendLine(lines[i]);
                    i++;
                }
                var codeHtml = System.Net.WebUtility.HtmlEncode(code.ToString().TrimEnd('\n'));
                var langLabel = string.IsNullOrWhiteSpace(lang)
                    ? string.Empty
                    : $"<span class=\"chat-code-lang\">{System.Net.WebUtility.HtmlEncode(lang)}</span>";
                sb.Append($"<div class=\"chat-code-wrap\">{langLabel}<pre class=\"chat-code\">{codeHtml}</pre></div>");
                i++; // consume closing ```
                continue;
            }

            // ── Heading  #, ##, ###, ####  ──────────────────────────────
            var headMatch = System.Text.RegularExpressions.Regex.Match(line, @"^(#{1,4})\s+(.+)$");
            if (headMatch.Success)
            {
                int level = headMatch.Groups[1].Length;
                var content = InlineFormat(headMatch.Groups[2].Value);
                sb.Append($"<h{level} class=\"chat-h{level}\">{content}</h{level}>");
                i++;
                continue;
            }

            // ── Horizontal rule  --- / *** / ___  ────────────────────────
            if (System.Text.RegularExpressions.Regex.IsMatch(line, @"^(\-{3,}|\*{3,}|_{3,})$"))
            {
                sb.Append("<hr class=\"chat-hr\" />");
                i++;
                continue;
            }

            // ── Blockquote  > text  ───────────────────────────────────────
            if (line.StartsWith(">"))
            {
                var bq = new System.Text.StringBuilder();
                while (i < total && lines[i].TrimEnd().StartsWith(">"))
                {
                    bq.Append("<p>" + InlineFormat(lines[i].TrimEnd().TrimStart('>').TrimStart()) + "</p>");
                    i++;
                }
                sb.Append($"<blockquote class=\"chat-blockquote\">{bq}</blockquote>");
                continue;
            }

            // ── Unordered list  - / * / +  ────────────────────────────────
            if (System.Text.RegularExpressions.Regex.IsMatch(line, @"^(\s*)([-*+])\s+"))
            {
                sb.Append("<ul class=\"chat-ul\">");
                while (i < total && System.Text.RegularExpressions.Regex.IsMatch(lines[i].TrimEnd(), @"^(\s*)([-*+])\s+"))
                {
                    var itemText = System.Text.RegularExpressions.Regex.Replace(lines[i].TrimEnd(), @"^\s*[-*+]\s+", "");
                    sb.Append($"<li>{InlineFormat(itemText)}</li>");
                    i++;
                }
                sb.Append("</ul>");
                continue;
            }

            // ── Ordered list  1. / 1)  ────────────────────────────────────
            if (System.Text.RegularExpressions.Regex.IsMatch(line, @"^\s*\d+[.)]\s+"))
            {
                sb.Append("<ol class=\"chat-ol\">");
                while (i < total && System.Text.RegularExpressions.Regex.IsMatch(lines[i].TrimEnd(), @"^\s*\d+[.)]\s+"))
                {
                    var itemText = System.Text.RegularExpressions.Regex.Replace(lines[i].TrimEnd(), @"^\s*\d+[.)]\s+", "");
                    sb.Append($"<li>{InlineFormat(itemText)}</li>");
                    i++;
                }
                sb.Append("</ol>");
                continue;
            }

            // ── Table  | col | col |  ─────────────────────────────────────
            if (line.StartsWith("|") && line.EndsWith("|"))
            {
                // Collect all consecutive table lines
                var tableLines = new List<string>();
                while (i < total && lines[i].TrimEnd().StartsWith("|"))
                {
                    tableLines.Add(lines[i].TrimEnd());
                    i++;
                }

                sb.Append("<div class=\"chat-table-wrap\"><table class=\"chat-table\">");
                bool headerDone = false;
                foreach (var tl in tableLines)
                {
                    // Skip separator row (contains only |, -, :, space)
                    if (System.Text.RegularExpressions.Regex.IsMatch(tl, @"^\|[\s\-:|]+\|$"))
                    {
                        headerDone = true;
                        continue;
                    }
                    var cells = tl.Split('|', StringSplitOptions.RemoveEmptyEntries)
                                   .Select(c => c.Trim())
                                   .ToArray();
                    var tag = !headerDone ? "th" : "td";
                    var rowClass = !headerDone ? "chat-thead-row" : "chat-tbody-row";
                    sb.Append($"<tr class=\"{rowClass}\">");
                    foreach (var cell in cells)
                        sb.Append($"<{tag}>{InlineFormat(cell)}</{tag}>");
                    sb.Append("</tr>");
                }
                sb.Append("</table></div>");
                continue;
            }

            // ── Blank line ─────────────────────────────────────────────────
            if (string.IsNullOrWhiteSpace(line))
            {
                sb.Append("<div class=\"chat-spacer\"></div>");
                i++;
                continue;
            }

            // ── Normal paragraph line ──────────────────────────────────────
            sb.Append($"<p class=\"chat-p\">{InlineFormat(line)}</p>");
            i++;
        }

        return sb.ToString();
    }

    /// <summary>Applies inline Markdown formatting to a single line of text.</summary>
    private static string InlineFormat(string text)
    {
        // Encode HTML entities first to prevent XSS
        text = System.Net.WebUtility.HtmlEncode(text);

        // Bold+Italic  ***text*** or ___text___
        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"\*\*\*(.+?)\*\*\*|___(.+?)___",
            m => {
                var v = m.Groups[1].Success ? m.Groups[1].Value : m.Groups[2].Value;
                return $"<strong><em>{v}</em></strong>";
            });

        // Bold  **text** or __text__
        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"\*\*(.+?)\*\*|__(.+?)__",
            m => {
                var v = m.Groups[1].Success ? m.Groups[1].Value : m.Groups[2].Value;
                return $"<strong>{v}</strong>";
            });

        // Italic  *text* or _text_
        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"\*([^*]+?)\*|(?<!\w)_([^_]+?)_(?!\w)",
            m => {
                var v = m.Groups[1].Success ? m.Groups[1].Value : m.Groups[2].Value;
                return $"<em>{v}</em>";
            });

        // Strikethrough  ~~text~~
        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"~~(.+?)~~",
            m => $"<s>{m.Groups[1].Value}</s>");

        // Inline code  `code`
        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"`([^`]+)`",
            m => $"<code class=\"chat-inline-code\">{m.Groups[1].Value}</code>");

        // Link  [text](url)
        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"\[([^\]]+)\]\((https?://[^\)]+)\)",
            m => $"<a class=\"chat-link\" href=\"{m.Groups[2].Value}\" target=\"_blank\" rel=\"noopener noreferrer\">{m.Groups[1].Value}</a>");

        return text;
    }
}
