                private async Task<XmlNodeViewModel?> ParseXmlToTreeAsync(string xml)
                {
                    try
                    {
                        using var ms = new System.IO.MemoryStream(System.Text.Encoding.UTF8.GetBytes(xml));
                        var tree = await XmlViewerService.LoadStreamAsync(ms);
                        XmlViewerService.ExpandToDepth(tree, 2);
                        return tree;
                    }
                    catch
                    {
                        return null;
                    }
                }

                private async Task OnUserXmlTreeModifiedAsync(Guid userId)
                {
                    if (!_userXmlTrees.TryGetValue(userId, out var tree) || tree is null) return;
                    var newXml = await XmlViewerService.SerializeAsync(tree);
                    OnXmlInput(userId, newXml);
                    _xmlVersion++;
                }
            }
