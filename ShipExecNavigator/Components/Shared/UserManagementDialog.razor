                private async Task SetTab(Guid userId, string tab)
                {
                    if (tab == "xml" && _userDetails.TryGetValue(userId, out var xmlUser) && xmlUser is not null)
                    {
                        var xml = SerializeUserXml(xmlUser);
                        _xmlText[userId] = xml;
                        _xmlErrors.Remove(userId);
                        var tree = await ParseXmlToTreeAsync(xml);
                        _userXmlTrees[userId] = tree;
                        if (tree is not null) { XmlRefLookupService.Extend(tree); _xmlVersion++; }
                    }
                    _activeTab[userId] = tab;
                }

                private static string SerializeUserXml(User user)
                {
                    try
                    {
                        var sb = new System.Text.StringBuilder();
                        using var writer = new System.IO.StringWriter(sb);
                        var ns = new System.Xml.Serialization.XmlSerializerNamespaces();
                        ns.Add(string.Empty, string.Empty);
                        var ser = new System.Xml.Serialization.XmlSerializer(typeof(User));
                        ser.Serialize(writer, user, ns);
                        return sb.ToString();
                    }
                    catch (Exception ex)
                    {
                        return $"<!-- Serialization error: {ex.Message} -->";
                    }
                }

                private static bool TryDeserializeUserXml(string xml, out User? user)
                {
                    user = null;
                    try
                    {
                        var ser = new System.Xml.Serialization.XmlSerializer(typeof(User));
                        using var reader = new System.IO.StringReader(xml);
                        user = ser.Deserialize(reader) as User;
                        return user is not null;
                    }
                    catch
                    {
                        return false;
                    }
                }

                private void OnXmlInput(Guid userId, string newXml)
                {
                    _xmlText[userId] = newXml;
                    if (TryDeserializeUserXml(newXml, out var parsed) && parsed is not null)
                    {
                        parsed.Address ??= new NameAddress();
                        parsed.DefaultConfiguration ??= new DefaultConfiguration();
                        _userDetails[userId] = parsed;
                        _permChecked[userId] = parsed.Permissions?.Select(p => p.Id).ToHashSet() ?? [];
                        _roleChecked[userId] = parsed.Roles?.Select(r => r.Id).ToHashSet() ?? [];
                        _addressDirty.Add(userId);
                        _configDirty.Add(userId);
                        _permDirty.Add(userId);
                        _roleDirty.Add(userId);
                        _xmlErrors.Remove(userId);
                    }
                    else
                    {
                        _xmlErrors[userId] = "Invalid XML \u2014 fix errors before changes propagate.";
                    }
                }

