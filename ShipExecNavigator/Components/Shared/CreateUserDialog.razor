    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Guid> OnUserCreated { get; set; }
    [Parameter] public string CompanyName { get; set; } = string.Empty;
    [Parameter] public Guid CompanyId { get; set; }

