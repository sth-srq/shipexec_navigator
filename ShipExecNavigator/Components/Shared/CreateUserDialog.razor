@using PSI.Sox
@inject IShipExecService ShipExecService

@if (IsVisible)
{
    <div class="au-backdrop" @onclick="HandleClose">
        <div class="au-dlg" @onclick:stopPropagation>

            <div class="au-header">
                <span class="au-title">&#x2795; Create User</span>
                <button class="au-close" @onclick="HandleClose">&#x2715;</button>
            </div>

            <div class="au-body">

                <div class="au-field">
                    <label class="au-label">Company</label>
                    <input class="au-input au-input--readonly" value="@CompanyName" readonly />
                </div>

                <div class="au-field">
                    <label class="au-label">Campus</label>
                    @if (_loadingSites)
                    {
                        <span class="au-loading-inline">Loading&hellip;</span>
                    }
                    else
                    {
                        <select class="au-select" @bind="_siteId">
                            <option value="">— None —</option>
                            @foreach (var site in _availableSites)
                            {
                                <option value="@site.Id">@site.Name</option>
                            }
                        </select>
                    }
                </div>

                <div class="au-field">
                    <label class="au-label">Email <span class="au-required">*</span></label>
                    <input class="au-input" type="email" @bind="_email" @bind:event="oninput" placeholder="Enter email" />
                </div>

                <div class="au-field">
                    <label class="au-label">Password <span class="au-required">*</span></label>
                    <input class="au-input" type="password" @bind="_password" @bind:event="oninput" placeholder="Enter password" />
                </div>

                <div class="au-tab-bar">
                    <button class='au-tab @(_activeTab == "address" ? "au-tab--active" : "")' @onclick='() => _activeTab = "address"'>Address</button>
                    <button class='au-tab @(_activeTab == "roles" ? "au-tab--active" : "")' @onclick='() => _activeTab = "roles"'>Roles</button>
                    <button class='au-tab @(_activeTab == "permissions" ? "au-tab--active" : "")' @onclick='() => _activeTab = "permissions"'>Permissions</button>
                    <button class='au-tab @(_activeTab == "config" ? "au-tab--active" : "")' @onclick='() => _activeTab = "config"'>Default Config</button>
                </div>

                <div class="au-tab-content">

                    <div class='au-tab-panel @(_activeTab != "address" ? "au-tab-hidden" : "")'>
                        <div class="au-form-grid">
                            <label class="au-label">Company</label>
                            <input class="au-input" @bind="_address.Company" @bind:event="oninput" placeholder="Company" />
                            <label class="au-label">Contact</label>
                            <input class="au-input" @bind="_address.Contact" @bind:event="oninput" placeholder="Contact" />
                            <label class="au-label">Address 1</label>
                            <input class="au-input" @bind="_address.Address1" @bind:event="oninput" placeholder="Address 1" />
                            <label class="au-label">Address 2</label>
                            <input class="au-input" @bind="_address.Address2" @bind:event="oninput" placeholder="Address 2" />
                            <label class="au-label">Address 3</label>
                            <input class="au-input" @bind="_address.Address3" @bind:event="oninput" placeholder="Address 3" />
                            <label class="au-label">City</label>
                            <input class="au-input" @bind="_address.City" @bind:event="oninput" placeholder="City" />
                            <label class="au-label">State / Province</label>
                            <input class="au-input" @bind="_address.StateProvince" @bind:event="oninput" placeholder="State / Province" />
                            <label class="au-label">Postal Code</label>
                            <input class="au-input" @bind="_address.PostalCode" @bind:event="oninput" placeholder="Postal Code" />
                            <label class="au-label">Country</label>
                            <select class="au-select" @bind="_address.Country">
                                <option value="">— Select country —</option>
                                @foreach (var (isoCode, countryName) in _countries)
                                {
                                    <option value="@isoCode">@countryName</option>
                                }
                            </select>
                            <label class="au-label">Phone</label>
                            <input class="au-input" @bind="_address.Phone" @bind:event="oninput" placeholder="Phone" />
                            <label class="au-label">Fax</label>
                            <input class="au-input" @bind="_address.Fax" @bind:event="oninput" placeholder="Fax" />
                            <label class="au-label">Email</label>
                            <input class="au-input" @bind="_address.Email" @bind:event="oninput" placeholder="Email" />
                        </div>
                    </div>

                    <div class='au-tab-panel @(_activeTab != "roles" ? "au-tab-hidden" : "")'>
                        @if (_loadingRoles)
                        {
                            <div class="au-loading">
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Loading roles&hellip;
                            </div>
                        }
                        else if (_availableRoles.Count == 0)
                        {
                            <span class="au-empty">No roles available.</span>
                        }
                        else
                        {
                            <div class="au-check-grid">
                                @foreach (var role in _availableRoles.OrderBy(r => r.Name))
                                {
                                    <label class="au-check-item">
                                        <input type="checkbox"
                                               checked="@_selectedRoleIds.Contains(role.Id)"
                                               @onchange="e => ToggleRole(role.Id, (bool)e.Value!)" />
                                        @role.Name
                                    </label>
                                }
                            </div>
                        }
                    </div>

                    <div class='au-tab-panel @(_activeTab != "permissions" ? "au-tab-hidden" : "")'>
                        @if (_loadingPerms)
                        {
                            <div class="au-loading">
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                Loading permissions&hellip;
                            </div>
                        }
                        else if (_availablePerms.Count == 0)
                        {
                            <span class="au-empty">No permissions available.</span>
                        }
                        else
                        {
                            <div class="au-check-grid">
                                @foreach (var perm in _availablePerms.OrderBy(p => p.Name))
                                {
                                    <label class="au-check-item">
                                        <input type="checkbox"
                                               checked="@_selectedPermIds.Contains(perm.Id)"
                                               @onchange="e => TogglePerm(perm.Id, (bool)e.Value!)" />
                                        @perm.Name
                                    </label>
                                }
                            </div>
                        }
                    </div>

                    <div class='au-tab-panel @(_activeTab != "config" ? "au-tab-hidden" : "")'>
                        <div class="au-form-grid">
                            <label class="au-label">Delimiter</label>
                            <select class="au-select" @bind="_defaultConfig.ExportFileDelimiter">
                                @foreach (var v in Enum.GetValues<Delimiter>())
                                {
                                    <option value="@v">@v</option>
                                }
                            </select>
                            <label class="au-label">Qualifier</label>
                            <select class="au-select" @bind="_defaultConfig.ExportFileQualifier">
                                @foreach (var v in Enum.GetValues<Qualifier>())
                                {
                                    <option value="@v">@v</option>
                                }
                            </select>
                            <label class="au-label">Group Separator</label>
                            <select class="au-select" @bind="_defaultConfig.ExportFileGroupSeparator">
                                @foreach (var v in Enum.GetValues<GroupSeparator>())
                                {
                                    <option value="@v">@v</option>
                                }
                            </select>
                            <label class="au-label">Decimal Separator</label>
                            <select class="au-select" @bind="_defaultConfig.ExportFileDecimalSeparator">
                                @foreach (var v in Enum.GetValues<DecimalSeparator>())
                                {
                                    <option value="@v">@v</option>
                                }
                            </select>
                        </div>
                    </div>

                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="au-error">&#9888; @_errorMessage</div>
                }

            </div>

            <div class="au-footer">
                <button class="au-btn-secondary" @onclick="HandleClose" disabled="@_isSaving">Cancel</button>
                <button class="au-btn-primary" @onclick="CreateUserAsync"
                        disabled="@(!IsValid || _isSaving)">
                    @if (_isSaving)
                    {
                        <span class="au-spinner"></span>
                    }
                    Create User
                </button>
            </div>

        </div>
    </div>
}

@code {
