    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_email) &&
        !string.IsNullOrWhiteSpace(_password);

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !_wasVisible)
        {
            _wasVisible = true;
            await LoadRolesAndPermsAsync();
        }
        else if (!IsVisible)
        {
            _wasVisible = false;
        }
    }

    private async Task LoadRolesAndPermsAsync()
    {
        _loadingRoles = true;
        _loadingPerms = true;
        _loadingSites = true;
        try
        {
            _availableRoles = await ShipExecService.GetRolesAsync();
        }
        catch
        {
            _availableRoles = [];
        }
        finally
        {
            _loadingRoles = false;
        }

        try
        {
            _availableSites = await ShipExecService.GetSitesAsync();
        }
        catch
        {
            _availableSites = [];
        }
        finally
        {
            _loadingSites = false;
        }

        try
        {
            _availablePerms = await ShipExecService.GetPermissionsAsync(Guid.Empty);
        }
        catch
        {
            _availablePerms = [];
        }
        finally
        {
            _loadingPerms = false;
        }
    }

    private void ToggleRole(Guid id, bool on)
    {
        if (on) _selectedRoleIds.Add(id);
        else _selectedRoleIds.Remove(id);
    }

    private void TogglePerm(Guid id, bool on)
    {
        if (on) _selectedPermIds.Add(id);
        else _selectedPermIds.Remove(id);
    }

    private void HandleClose()
    {
        _email = string.Empty;
        _password = string.Empty;
        _errorMessage = string.Empty;
        _activeTab = "address";
        _address = new();
        _defaultConfig = new();
        _selectedRoleIds = [];
        _selectedPermIds = [];
        _siteId = null;
        OnClose.InvokeAsync();
    }

    private async Task CreateUserAsync()
    {
        if (!IsValid) return;

        _isSaving = true;
        _errorMessage = string.Empty;
        try
        {
            var user = new User
            {
                UserName = _email.Trim(),
                Email = _email.Trim(),
                PasswordHash = _password,
                CompanyId = CompanyId,
                SiteId = _siteId,
                Address = _address,
                DefaultConfiguration = _defaultConfig,
                Permissions = _availablePerms.Where(p => _selectedPermIds.Contains(p.Id)).ToList(),
                Roles = _availableRoles.Where(r => _selectedRoleIds.Contains(r.Id)).ToList(),
            };
            var newId = await ShipExecService.CreateUserAsync(user);
            await OnUserCreated.InvokeAsync(newId);
            HandleClose();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }
