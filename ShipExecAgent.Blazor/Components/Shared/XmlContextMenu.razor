@using ShipExecAgent.Shared.Models

@if (IsVisible && Node is not null)
{
    <div class="ctx-backdrop" @onclick="HandleClose"></div>

    <div class="ctx-menu" style="left:@(X)px; top:@(Y)px" @onclick:stopPropagation>

        <button class="ctx-item" @onclick="HandleAdd">
            <span class="ctx-icon">&#xFF0B;</span>
            Add
        </button>

        <div class="ctx-sep"></div>

        <button class="ctx-item" @onclick="HandleCopy">
            <span class="ctx-icon">&#x2398;</span>
            Copy
        </button>

        @if (CanPaste)
        {
            <button class="ctx-item" @onclick="HandlePaste">
                <span class="ctx-icon">&#x2399;</span>
                Paste
            </button>
        }

        @if (IsShippersNode)
        {
            <div class="ctx-sep"></div>

            <button class="ctx-item" @onclick="HandleImportShippers">
                <span class="ctx-icon">&#x1F69A;</span>
                Import Shippers
            </button>

            <button class="ctx-item" @onclick="HandleExportShippers">
                <span class="ctx-icon">&#x2B07;</span>
                Export Shippers
            </button>
        }

        @if (IsProfilesNode)
        {
            <div class="ctx-sep"></div>

            <button class="ctx-item" @onclick="HandleCompareProfiles">
                <span class="ctx-icon">&#x1F4CA;</span>
                Compare Profiles
            </button>
        }

        @if (IsUsersNode)
        {
            <div class="ctx-sep"></div>

            <button class="ctx-item" @onclick="HandleExportUsers">
                <span class="ctx-icon">&#x2B07;</span>
                Export Users
            </button>
        }

        @if (Node.Parent is not null)
        {
            <div class="ctx-sep"></div>

            <button class="ctx-item ctx-item--danger" @onclick="HandleDelete">
                <span class="ctx-icon">&#x2715;</span>
                Delete
            </button>
        }
    </div>
}

@code {
    [Parameter] public XmlNodeViewModel? Node { get; set; }
    [Parameter] public double X { get; set; }
    [Parameter] public double Y { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public bool CanPaste { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<XmlNodeViewModel> OnAdd { get; set; }
    [Parameter] public EventCallback<XmlNodeViewModel> OnRemove { get; set; }
    [Parameter] public EventCallback<XmlNodeViewModel> OnCopy { get; set; }
    [Parameter] public EventCallback<XmlNodeViewModel> OnPaste { get; set; }
    [Parameter] public EventCallback OnImportShippers { get; set; }
    [Parameter] public EventCallback OnExportShippers { get; set; }
    [Parameter] public EventCallback OnCompareProfiles { get; set; }
    [Parameter] public EventCallback OnExportUsers { get; set; }

    private bool IsShippersNode =>
        Node is not null
        && string.Equals(Node.NodeName, "Shippers", StringComparison.OrdinalIgnoreCase);

    private bool IsProfilesNode =>
        Node is not null
        && string.Equals(Node.NodeName, "Profiles", StringComparison.OrdinalIgnoreCase);

    private bool IsUsersNode =>
        Node is not null
        && string.Equals(Node.NodeName, "Users", StringComparison.OrdinalIgnoreCase);

    private Task HandleClose() => OnClose.InvokeAsync();
    private Task HandleAdd() => OnAdd.InvokeAsync(Node);
    private Task HandleCopy() => OnCopy.InvokeAsync(Node);
    private Task HandlePaste() => OnPaste.InvokeAsync(Node);
    private Task HandleDelete() => OnRemove.InvokeAsync(Node);
    private Task HandleImportShippers() => OnImportShippers.InvokeAsync();
    private Task HandleExportShippers() => OnExportShippers.InvokeAsync();
    private Task HandleCompareProfiles() => OnCompareProfiles.InvokeAsync();
    private Task HandleExportUsers() => OnExportUsers.InvokeAsync();
}
